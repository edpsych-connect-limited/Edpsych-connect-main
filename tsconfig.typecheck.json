{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // Type-check only the source; exclude Next build artifacts.
    // Next.js may append distDir `types` globs to tsconfig.json during `next build`,
    // which can cause `tsc --noEmit` to fail on generated files.
    "noEmit": true,
    "incremental": false
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "video_scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".next_*",
    "cypress",
    "cypress.config.ts",
    "INSTRUCTION-FILES",
    "scripts",
    "tools",
    "prisma",
    "docs"
  ]
}
