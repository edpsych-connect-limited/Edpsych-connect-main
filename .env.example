# Database
DATABASE_URL="postgresql://user:REPLACE_ME@localhost:5432/edpsych"

# Redis / KV (optional)
REDIS_URL="redis://localhost:6379"
KV_URL=""
KV_REDIS_URL=""
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Edge rate limiting (optional; defense-in-depth for RSC/Server Actions)
# Only active when UPSTASH_REDIS_REST_URL/TOKEN are set.
EDGE_RSC_RATE_LIMIT_ENABLED="1"
EDGE_RSC_RATE_LIMIT_WINDOW_SECONDS="60"
EDGE_RSC_RATE_LIMIT="120"
EDGE_SERVER_ACTIONS_RATE_LIMIT="60"

# Production redeploy verification (ops script)
# Base URL to validate (defaults to https://edpsychconnect.com if unset)
PRODUCTION_BASE_URL=""
# Optional: require that /api/version reports this commit SHA (prefix match allowed)
EXPECTED_GIT_COMMIT_SHA=""
# Optional: set to "false" to allow /api/health?deep=1 returning 503 without failing verification
REQUIRE_DEEP_DB_OK="true"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="REPLACE_WITH_32+_CHAR_SECRET"
JWT_SECRET="REPLACE_WITH_32+_CHAR_SECRET"
JWT_REFRESH_SECRET="REPLACE_WITH_32+_CHAR_SECRET"

# App / public URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000/api"

# Security (required in production)
ENCRYPTION_KEY="REPLACE_WITH_STRONG_SECRET"
OBFUSCATION_KEY="REPLACE_WITH_STRONG_SECRET"

# Audit log integrity (tamper-evident)
# - off: no integrity envelope
# - hash-chain: SHA-256 hash chain per tenant (detects edits/reordering if attacker cannot recompute all hashes)
# - hmac-sha256: hash chain + HMAC signature (recommended for production)
AUDIT_LOG_INTEGRITY_MODE="off"
AUDIT_LOG_HMAC_KEY=""
AUDIT_LOG_HMAC_KEY_ID=""

# AI providers (optional; enable only what you use)
ENABLE_AI="false"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.2-preview"
CLAUDE_API_KEY=""
XAI_API_KEY=""
GEMINI_API_KEY=""
AI_DAILY_BUDGET_USD="50"

# Video generation (HeyGen)
HEYGEN_API_KEY=""

# Optional: webhook callback URL used by some local HeyGen tooling.
# If you do not use webhooks, leave blank.
HEYGEN_WEBHOOK_URL=""

# HeyGen identity configuration (truth-by-code)
# These MUST be set explicitly when generating videos for a real person.
# Do not ship or generate 'Dr Scott' videos using proxy avatar/voice IDs.
HEYGEN_DR_SCOTT_AVATAR_ID=""
HEYGEN_DR_SCOTT_VOICE_ID=""

# Option B: materialize Cloudinary fallbacks (local tooling only; CI remains network-free)
# - tools/materialize-cloudinary-fallbacks.ts reads these flags.
# - Generation is intentionally opt-in to avoid accidental HeyGen credit spend.
OPTION_B_GENERATE_MISSING="0"
# Sync Cloudinary evidence -> registry mappings (network-free mode)
OPTION_B_SYNC_FROM_EVIDENCE="0"
# If set, the tool will exit non-zero when it made no new uploads.
OPTION_B_FAIL_IF_NO_UPLOADS="0"
# Polling timeout for HeyGen completion checks
OPTION_B_HEYGEN_TIMEOUT_MINUTES="25"
# Optional: process only specific keys (comma/whitespace separated)
OPTION_B_KEYS=""
# Optional: cap batch size
OPTION_B_MAX_KEYS=""

# Payments (Stripe)
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_FREE=""
STRIPE_PRICE_BASIC=""
STRIPE_PRICE_PROFESSIONAL=""
STRIPE_PRICE_ENTERPRISE=""

# Email
SENDGRID_API_KEY=""
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT="587"
EMAIL_FROM="\"EdPsych Connect\" <noreply@edpsychconnect.com>"
ADMIN_EMAIL="admin@edpsychconnect.com"

# Media (Cloudinary)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_WEBHOOK_URL=""

# Monitoring / Analytics (optional)
ENABLE_MONITORING="false"
ENABLE_MONITORING_IN_DEV="false"
DEPLOYMENT_ENV=""
ENV_TYPE=""
LOG_LEVEL="info"
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
GOOGLE_SITE_VERIFICATION=""

# AWS (optional; only if using CloudWatch / secrets manager)
AWS_REGION="eu-west-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
ENABLE_CLOUDWATCH="false"
CLOUDWATCH_NAMESPACE="EdPsych/Connect"
CLOUDWATCH_LOG_RETENTION_DAYS="30"
CLOUDWATCH_ALARM_SNS_TOPIC_ARN=""

# Prisma
PRISMA_GENERATE_SKIP_AUTOINSTALL="false"

# Integrations
# Data Warehouse export (server-to-server). Do NOT commit real keys.
DATA_WAREHOUSE_EXPORT_API_KEY=""

# Seed scripts
# Used by prisma/seed-admin.ts
SEED_ADMIN_PASSWORD=""
# Used by prisma/seed-test-users.ts and Cypress role login
SEED_TEST_USERS_PASSWORD=""
# Set to "true" to print SEED_ADMIN_PASSWORD in seed output logs
PRINT_SEED_PASSWORD="false"

# Secrets manager (real implementation)
# 32-byte (64 hex chars) key for AES-256-GCM, e.g. generated via: openssl rand -hex 32
SECRETS_ENCRYPTION_KEY=""