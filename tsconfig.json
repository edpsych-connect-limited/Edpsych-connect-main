{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "downlevelIteration": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": [
      "node"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "video_scripts/**/*.ts",
    ".next_build_local/types/**/*.ts",
    ".next_build_local/dev/types/**/*.ts",
    ".next_build_gate/types/**/*.ts",
    ".next_build_gate/dev/types/**/*.ts",
    ".next_build_gate_alt/types/**/*.ts",
    ".next_build_gate_alt/dev/types/**/*.ts",
    ".next_build_8gb_nosourcemap/types/**/*.ts",
    ".next_build_8gb_nosourcemap/dev/types/**/*.ts",
    ".next_build_local_1768072089670_483408/types/**/*.ts",
    ".next_build_local_1768072089670_483408/dev/types/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next_local/types/**/*.ts",
    ".next_local/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".next_temp*",
    "cypress",
    "cypress.config.ts",
    "INSTRUCTION-FILES",
    "scripts",
    "tools",
    "prisma",
    "docs",
    ".next_build_local",
    ".next_build_gate",
    ".next_build*"
  ]
}
