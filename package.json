{
  "name": "edpsych-connect-web-v2",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x || 22.x"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" node ./scripts/next-cli-patched.cjs dev",
    "build": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" node ./scripts/next-cli-patched.cjs build --webpack",
    "build:safe": "npm run build",
    "clean:next": "node ./scripts/clean-next.cjs",
    "build:clean": "npm run clean:next && npm run build",
    "start": "node ./scripts/next-cli-patched.cjs start",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=true node -r ./scripts/patch-fs-runtime.cjs ./node_modules/eslint/bin/eslint.js src --ext .ts,.tsx --no-ignore --max-warnings 0 --format stylish",
    "type-check": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" node -r ./scripts/patch-fs-runtime.cjs node_modules/typescript/bin/tsc --project tsconfig.typecheck.json --noEmit --skipLibCheck",
    "type-check:strict": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" node node_modules/typescript/bin/tsc --project tsconfig.typecheck.json --noEmit --strict",
    "smoke:ci": "cross-env CI=true NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/smoke-ci.ts",
    "security:scan": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/security-scan-secrets.ts",
    "verify:prod": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/verify-production.ts",
    "verify:prod:optional-db": "cross-env REQUIRE_DEEP_DB_OK=false NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/verify-production.ts",
    "preverify:ci": "node tools/assert-node20.cjs",
    "verify:ci": "npm run lint && npm run type-check && npm run test:ai-governance && npm run test:ai-nontraining && npm run test:security-by-design && npm run test:intervention-validation-scale && npm run test:video-registry && npm run test:video-assets && npm run test:video-claims && npm run test:video-script-coverage && npm run test:video-script-provenance && npm run smoke:ci && npm run security:scan",
    "verify:ci:capture": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/capture-verify-ci.ts",
    "gate:beta": "npm run verify:ci",
    "build:vercel": "npm run verify:ci && npm run build",
    "build:vercel:phase1": "npm run build",
    "test:pii-redaction": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/test-pii-redaction.ts",
    "test:ai-governance": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/test-ai-governance.ts",
    "test:ai-nontraining": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/validate-ai-nontraining.ts",
    "test:security-by-design": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/validate-security-by-design.ts",
    "test:intervention-validation-scale": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/validate-intervention-validation-scale.ts",
    "test:byod-db-url": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/test-byod-db-url.ts",
    "test:video-registry": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/validate-video-registry.ts",
    "test:video-assets": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/validate-video-assets.ts",
    "test:video-claims": "cross-env VIDEO_CLAIMS_AUDIT=1 VIDEO_CLAIMS_STRICT=1 VIDEO_CLAIMS_REQUIRE_VERIFIED=1 NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/validate-video-claims.ts",
    "test:video-script-coverage": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/validate-video-script-coverage.ts",
    "generate:video-claims-manifest": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/generate-video-claims-manifest.ts",
    "generate:video-script-provenance": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/generate-video-script-provenance.ts",
    "sync:cloudinary-inventory": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/sync-cloudinary-inventory.ts",
    "test:video-script-provenance": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/validate-video-script-provenance.ts",
    "test:routes": "tsx tools/audit-routes.ts",
    "audit:script-code": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/audit-video-scripts-against-code.ts",
    "audit:video-delivery": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/audit-video-delivery.ts",
    "test:contextual-help-coverage": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/validate-contextual-help-coverage.ts",
    "test:db-connectivity": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/audit-db-test.ts",
    "test:audit-integrity": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/test-audit-integrity.ts",
    "verify:audit-integrity": "cross-env NODE_OPTIONS=\"--require ./scripts/patch-fs-runtime.cjs\" tsx tools/verify-audit-log-integrity.ts",
    "type-enforce": "bash tools/enforce-types.sh check",
    "type-fix": "bash tools/enforce-types.sh fix",
    "validate": "npx validate-code validate-dir src",
    "validate:strict": "npx validate-code validate-dir src --strict",
    "validate:build": "bash tools/build-validation.sh . false",
    "validate:report": "npx validate-code report src",
    "validate:setup": "bash tools/setup-validation.sh",
    "test:e2e": "cross-env CYPRESS_CACHE_FOLDER=E:\\cypress-cache cypress run",
    "test:e2e:smoke": "npm run test:e2e -- --spec \"cypress/e2e/sanity.cy.ts,cypress/e2e/auth.cy.ts,cypress/e2e/parent-portal.cy.ts,cypress/e2e/guidance-evidence.cy.ts\"",
    "test:e2e:regression": "npm run test:e2e -- --spec \"cypress/e2e/sanity.cy.ts,cypress/e2e/auth.cy.ts,cypress/e2e/auth/login.cy.ts,cypress/e2e/auth/role-smoke-test.cy.ts,cypress/e2e/onboarding.cy.ts,cypress/e2e/help-center.cy.ts,cypress/e2e/demo.cy.ts,cypress/e2e/ehcp.cy.ts,cypress/e2e/la-portal.cy.ts,cypress/e2e/researcher.cy.ts,cypress/e2e/safety-net.cy.ts,cypress/e2e/assessment-collaboration.cy.ts,cypress/e2e/coding-curriculum.cy.ts,cypress/e2e/student-lesson.cy.ts,cypress/e2e/extended-features.cy.ts,cypress/e2e/functionality.cy.ts,cypress/e2e/routing.cy.ts,cypress/e2e/ai-tutoring.cy.ts\"",
    "test:e2e:a11y": "npm run test:e2e -- --spec \"cypress/e2e/ui-ux.cy.ts\"",
    "test:e2e:dev": "powershell -ExecutionPolicy Bypass -File run-e2e-dev.ps1",
    "gate:release": "powershell -ExecutionPolicy Bypass -File tools/gate-release.ps1",
    "test:open": "cross-env CYPRESS_CACHE_FOLDER=E:\\cypress-cache cypress open",
    "postinstall": "node tools/postinstall.mjs"
  },
