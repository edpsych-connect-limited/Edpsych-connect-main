{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "NODE_ENV": "production",
    "NEXT_TELEMETRY_DISABLED": "1",
    "VERCEL_SKIP_OPTIMIZE": "true"
  },
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/:path*"
    }
  ],
  "functions": {
    "api/**": {
      "excludeFiles": "**/*.{spec,test}.{js,ts}",
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/blog/generate",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/predictions",
      "schedule": "0 2 * * *"
    }
  ]
}
