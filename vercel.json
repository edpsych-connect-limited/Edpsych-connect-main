{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": ".next/static"
      }
    },
    {
      "src": ".next/standalone/server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "memory": 512,
        "excludeFiles": ".vercel/output/**"
      }
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "NEXT_TELEMETRY_DISABLED": "1"
  },
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/blog/generate",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/predictions",
      "schedule": "0 2 * * *"
    }
  ]
}