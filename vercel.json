{
  "version": 2,
  "buildCommand": "npm run build:vercel:phase1",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "NODE_ENV": "production",
    "NEXT_TELEMETRY_DISABLED": "1",
    "VERCEL_SKIP_OPTIMIZE": "true",
    "SKIP_POSTINSTALL": "true"
  },
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/blog/generate",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/predictions",
      "schedule": "0 2 * * *"
    }
  ]
}
