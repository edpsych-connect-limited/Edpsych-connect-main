// ============================================================================
// ALGORITHM MARKETPLACE
// ============================================================================

model Algorithm {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  tags        String[]
  price       Float
  currency    String   @default("GBP")
  
  creatorId   Int
  creator     users    @relation(fields: [creatorId], references: [id])
  
  versions    AlgorithmVersion[]
  licenses    AlgorithmLicense[]
  usages      AlgorithmUsage[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  
  @@index([creatorId])
}

model AlgorithmVersion {
  id          String   @id @default(cuid())
  algorithmId String
  version     String
  code        String?  // Or URL to code
  changelog   String?
  status      String   @default("draft") // draft, published, deprecated
  
  algorithm   Algorithm @relation(fields: [algorithmId], references: [id], onDelete: Cascade)
  usages      AlgorithmUsage[]
  
  createdAt   DateTime @default(now())
  
  @@index([algorithmId])
}

model AlgorithmLicense {
  id          String   @id @default(cuid())
  algorithmId String
  tenantId    Int
  type        String   // subscription, perpetual, usage-based
  status      String   @default("active")
  
  startsAt    DateTime @default(now())
  expiresAt   DateTime?
  
  algorithm   Algorithm @relation(fields: [algorithmId], references: [id])
  tenant      tenants   @relation(fields: [tenantId], references: [id])
  
  @@index([algorithmId])
  @@index([tenantId])
}

model AlgorithmUsage {
  id          String   @id @default(cuid())
  algorithmId String
  versionId   String?
  tenantId    Int
  userId      Int?
  
  executionTime Int    // ms
  status      String   // success, failure
  cost        Float    @default(0)
  
  timestamp   DateTime @default(now())
  
  algorithm   Algorithm @relation(fields: [algorithmId], references: [id])
  version     AlgorithmVersion? @relation(fields: [versionId], references: [id])
  tenant      tenants   @relation(fields: [tenantId], references: [id])
  user        users?    @relation(fields: [userId], references: [id])
  
  @@index([algorithmId])
  @@index([tenantId])
  @@index([timestamp])
}

