// ============================================================================
// COMMUNICATION SENTIMENT ANALYSIS (Risk Prediction)
// ============================================================================

model CommunicationSentimentAnalysis {
  id              String   @id @default(cuid())
  
  // Source
  source_type     String   // email, message, note, call_log
  source_id       String?  // Reference to original communication
  
  // Context
  ehcp_id         String?
  student_id      Int?
  parent_id       Int?
  
  // Analysis Results
  sentiment_score Float    // -1.0 (very negative) to 1.0 (very positive)
  sentiment_label String   // very_negative, negative, neutral, positive, very_positive
  
  // Escalation Indicators
  urgency_detected     Boolean @default(false)
