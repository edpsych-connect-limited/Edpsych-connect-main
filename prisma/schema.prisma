// ============================================================================
// RESEARCH FOUNDATION (TENANT-SCOPED)
// ============================================================================

model research_studies {
  id               String    @id @default(cuid())
  tenant_id        Int
  title            String
  description      String
  objective        String
  methodology      String
  ethics_approval  Boolean   @default(false)
  ethics_reference String?
  start_date       DateTime
  end_date         DateTime?
  status           String    @default("draft")
  is_public        Boolean   @default(false)
  creator_id       Int
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now())

  // Relations
  tenants       tenants                  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  creator       users                    @relation(fields: [creator_id], references: [id])
  collaborators research_collaborators[]
  datasets      research_datasets[]
  participants  research_participants[]
  publications  research_publications[]
  surveys       research_surveys[]

  @@index([tenant_id])
  @@index([creator_id])
  @@index([status])
}

model research_collaborators {
  id                String   @id @default(cuid())
  study_id          String
  user_id           Int
  role              String   @default("researcher")
  permissions       String[]
  invitation_status String   @default("pending")
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now())

  // Relations
  study research_studies @relation(fields: [study_id], references: [id], onDelete: Cascade)
  user  users            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([study_id, user_id])
  @@index([study_id])
  @@index([user_id])
}

model research_datasets {
  id            String   @id @default(cuid())
  study_id      String
  name          String
  description   String
  data_type     String
  format        String
  size          Int
  location      String
  is_anonymized Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())

  // Relations
  study    research_studies    @relation(fields: [study_id], references: [id], onDelete: Cascade)
  analyses research_analyses[]

  @@index([study_id])
}

model research_analyses {
  id            String   @id @default(cuid())
  dataset_id    String
  researcher_id Int
  title         String
  description   String
  methodology   String
  results       String
  status        String   @default("in-progress")
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())

  // Relations
  dataset    research_datasets @relation(fields: [dataset_id], references: [id], onDelete: Cascade)
  researcher users             @relation(fields: [researcher_id], references: [id])

  @@index([dataset_id])
  @@index([researcher_id])
}

model research_participants {
  id                String    @id @default(cuid())
  study_id          String
  user_id           Int?
  consent_provided  Boolean   @default(false)
  consent_date      DateTime?
  participant_code  String    @unique
  status            String    @default("enrolled")
  enrollment_date   DateTime  @default(now())
  completion_date   DateTime?
  withdrawal_date   DateTime?
  withdrawal_reason String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now())

  // Relations
  study     research_studies     @relation(fields: [study_id], references: [id], onDelete: Cascade)
  user      users?               @relation(fields: [user_id], references: [id])
  responses research_responses[]

  @@unique([study_id, user_id])
  @@index([study_id])
  @@index([user_id])
}

model research_surveys {
  id                 String    @id @default(cuid())
  study_id           String
  title              String
  description        String
  instructions       String
  questions          Json
  estimated_duration Int?
  is_anonymous       Boolean   @default(false)
  status             String    @default("draft")
  start_date         DateTime?
  end_date           DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @default(now())

  // Relations
  study     research_studies     @relation(fields: [study_id], references: [id], onDelete: Cascade)
  responses research_responses[]

  @@index([study_id])
}

model research_responses {
  id              String    @id @default(cuid())
  survey_id       String
  participant_id  String
  answers         Json
  completion_time Int?
  started_at      DateTime  @default(now())
  completed_at    DateTime?
  ip_address      String?
  user_agent      String?
  created_at      DateTime  @default(now())

  // Relations
  survey      research_surveys      @relation(fields: [survey_id], references: [id], onDelete: Cascade)
  participant research_participants @relation(fields: [participant_id], references: [id], onDelete: Cascade)

  @@index([survey_id])
  @@index([participant_id])
}

model research_publications {
  id               String    @id @default(cuid())
  study_id         String
  title            String
  authors          String[]
  abstract         String
  publication_date DateTime?
  journal          String?
  doi              String?
  url              String?
  citation         String?
  publication_type String    @default("article")
  status           String    @default("draft")
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now())

  // Relations
  study research_studies @relation(fields: [study_id], references: [id], onDelete: Cascade)

  @@index([study_id])
}

model research_ethics_approvals {
  id               String    @id @default(cuid())
  user_id          Int
  approval_body    String
  reference_number String
  approval_date    DateTime
  expiry_date      DateTime?
  document_url     String?
  status           String    @default("approved")
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now())

  // Relations
  user users @relation(fields: [user_id], references: [id])

  @@index([user_id])
}

// ============================================================================
// ACCESSIBILITY & PREFERENCES
// ============================================================================

model accessibility_settings {
  id             String   @id @default(cuid())
  user_id        Int      @unique
  high_contrast  Boolean  @default(false)
  large_text     Boolean  @default(false)
  screen_reader  Boolean  @default(false)
  reduced_motion Boolean  @default(false)
  text_to_speech Boolean  @default(false)
  speech_to_text Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now())

  // Relations
  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model user_preferences {
  id         String   @id @default(cuid())
  user_id    Int      @unique
  theme      String   @default("light")
  language   String   @default("en")
  timezone   String   @default("UTC")
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model learning_style {
  id          String   @id @default(cuid())
  user_id     Int      @unique
  visual      Int      @default(0)
  auditory    Int      @default(0)
  kinesthetic Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  // Relations
  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model speech_recognition_logs {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  text       String
  confidence Float
  language   String
  provider   String
  timestamp  DateTime @default(now())

  // Relations
  user users? @relation(fields: [user_id], references: [id])

  @@index([user_id])
}

model speech_synthesis_logs {
  id              Int      @id @default(autoincrement())
  user_id         Int?
  text            String
  language        String
  provider        String
  voice_name      String
  voice_gender    String
  character_count Int
  timestamp       DateTime @default(now())

  // Relations
  user users? @relation(fields: [user_id], references: [id])

  @@index([user_id])
}

model translation_logs {
  id              Int      @id @default(autoincrement())
  user_id         Int?
  original_text   String
  translated_text String
  source_language String
  target_language String
  provider        String
  character_count Int
  timestamp       DateTime @default(now())

  // Relations
  user users? @relation(fields: [user_id], references: [id])

  @@index([user_id])
}

// ============================================================================
// HELP & ONBOARDING SYSTEM
// ============================================================================

model help_preferences {
  user_id              Int      @id
  show_contextual_help Boolean  @default(true)
  enable_tours         Boolean  @default(true)
  show_help_button     Boolean  @default(true)
  updated_at           DateTime @default(now())

  // Relations
  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model help_viewed_items {
  user_id   Int
  item_id   String
  viewed_at DateTime @default(now())

  // Relations
  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, item_id])
}

// ============================================================================
// HELP CENTER & DOCUMENTATION
// ============================================================================

model HelpCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String? // Icon name or emoji
  order_index Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  // Relations
  articles HelpArticle[]

  @@index([slug])
  @@index([is_active])
}

model HelpArticle {
  id              String   @id @default(uuid())
  category_id     String
  title           String
  slug            String   @unique
  content         String   @db.Text
  excerpt         String?
  search_keywords String[] @default([])

  // Metadata
  author      String? // Author name
  views       Int     @default(0)
  helpful_yes Int     @default(0)
  helpful_no  Int     @default(0)
  order_index Int     @default(0)

  // Status
  is_published Boolean @default(true)
  is_featured  Boolean @default(false)

  // Context-sensitive help
  page_context String[] @default([]) // Pages where this appears contextually

  // Dates
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())
  published_at DateTime?

  // Relations
  category HelpCategory         @relation(fields: [category_id], references: [id], onDelete: Cascade)
  related  HelpArticleRelated[] @relation("ArticleRelated")

  @@index([category_id])
  @@index([slug])
  @@index([is_published])
  @@index([page_context])
}

model HelpArticleRelated {
  article_id String
  related_id String

  article HelpArticle @relation("ArticleRelated", fields: [article_id], references: [id], onDelete: Cascade)

  @@id([article_id, related_id])
}

model HelpFAQ {
  id          String   @id @default(uuid())
  question    String
  answer      String   @db.Text
  category    String? // General, Technical, Billing, etc.
  order_index Int      @default(0)
  views       Int      @default(0)
  helpful_yes Int      @default(0)
  helpful_no  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  @@index([category])
  @@index([is_active])
}

model HelpSearchLog {
  id         String   @id @default(uuid())
  user_id    Int?
  query      String
  results    Int      @default(0)
  clicked_id String? // Article ID that was clicked
  created_at DateTime @default(now())

  @@index([query])
  @@index([created_at])
}

// ============================================================================
// BLOG & CONTENT MARKETING
// ============================================================================

model BlogCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  color       String? // Hex color for category badge
  order_index Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  // Relations
  posts BlogPost[]

  @@index([slug])
  @@index([is_active])
}

model BlogPost {
  id             String  @id @default(uuid())
  category_id    String
  title          String
  slug           String  @unique
  content        String  @db.Text
  excerpt        String?
  featured_image String? // URL to featured image

  // SEO
  meta_title       String?
  meta_description String?
  keywords         String[] @default([])

  // Author
  author_name  String
  author_email String?
  author_bio   String?

  // Metadata
  views        Int  @default(0)
  reading_time Int? // Minutes
  order_index  Int  @default(0)

  // Status
  is_published Boolean @default(false)
  is_featured  Boolean @default(false)

  // Dates
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())
  published_at DateTime?

  // Relations
  category BlogCategory  @relation(fields: [category_id], references: [id], onDelete: Cascade)
  tags     BlogPostTag[]
  comments BlogComment[]

  @@index([category_id])
  @@index([slug])
  @@index([is_published])
  @@index([published_at])
}

model BlogTag {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  created_at DateTime @default(now())

  // Relations
  posts BlogPostTag[]

  @@index([slug])
}

model BlogPostTag {
  post_id String
  tag_id  String

  post BlogPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([post_id, tag_id])
}

model BlogComment {
  id           String   @id @default(uuid())
  post_id      String
  author_name  String
  author_email String
  content      String   @db.Text
  is_approved  Boolean  @default(false)
  created_at   DateTime @default(now())

  // Relations
  post BlogPost @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@index([post_id])
  @@index([is_approved])
}

// ============================================================================
// SUBSCRIPTION & BILLING (STRIPE INTEGRATED)
// ============================================================================

model subscriptions {
  id        Int @id @default(autoincrement())
  tenant_id Int

  // Tier-based access control
  tier         SubscriptionTier @default(FREE)
  max_schools  Int?
  max_users    Int?
  max_students Int?

  // Legacy fields (backward compatibility)
  plan_type      String
  payment_status String
  amount_paid    Decimal

  // Dates
  start_date DateTime
  end_date   DateTime
  is_active  Boolean  @default(true)

  // Stripe integration
  stripe_customer_id     String? @unique
  stripe_subscription_id String? @unique
  stripe_price_id        String?

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  tenants       tenants         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  feature_usage feature_usage[] @relation("SubscriptionFeatureUsage")

  @@index([tenant_id])
  @@index([tier])
  @@index([is_active])
  @@index([stripe_customer_id])
}

// ============================================================================
// MISSING MODELS RESTORED
// ============================================================================

model feature_usage {
  id              Int              @id @default(autoincrement())
  subscription_id Int
  tenant_id       Int
  feature         Feature
  tier            SubscriptionTier
  duration        Int?
  metadata        Json?
  timestamp       DateTime         @default(now())

  // Relations
  subscription subscriptions @relation("SubscriptionFeatureUsage", fields: [subscription_id], references: [id], onDelete: Cascade)
  tenant       tenants       @relation("TenantFeatureUsage", fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([subscription_id])
  @@index([tenant_id])
  @@index([feature])
  @@index([timestamp])
}

model ParentTeacherMessage {
  id         String    @id @default(uuid())
  tenantId   Int
  senderId   Int
  receiverId Int
  content    String
  subject    String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now())

  tenant    tenants   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sender    users     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver  users     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  studentId Int?
  student   students? @relation(fields: [studentId], references: [id])

  @@index([tenantId])
  @@index([senderId])
  @@index([receiverId])
}

model Institution {
  id                 String    @id @default(uuid())
  name               String
  type               String
  size               String
  address            String?
  city               String?
  region             String?
  postcode           String?
  country            String?
  phone              String?
  email              String
  website            String?
  logoUrl            String?
  notes              String?   @db.Text
  tags               String[]  @default([])
  customFields       Json?
  verificationStatus String    @default("PENDING")
  verifiedAt         DateTime?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now())
  createdBy          String?

  contacts      InstitutionContact[]
  departments   Department[]
  subscriptions InstitutionSubscription[]
  admins        InstitutionAdmin[]

  @@index([name])
  @@index([type])
  @@index([verificationStatus])
  @@index([isActive])
  @@index([email])
}

model InstitutionContact {
  id               String   @id @default(uuid())
  institutionId    String
  firstName        String
  lastName         String
  email            String
  phone            String?
  role             String?
  isPrimaryContact Boolean  @default(false)
  jobTitle         String?
  notes            String?  @db.Text
  departmentId     String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([institutionId])
  @@index([email])
  @@index([isPrimaryContact])
  @@index([departmentId])
}

model Department {
  id                 String   @id @default(uuid())
  institutionId      String
  name               String
  description        String?  @db.Text
  type               String
  parentDepartmentId String?
  headOfDepartmentId String?
  status             String   @default("ACTIVE")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now())
  createdBy          String

  institution      Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  parentDepartment Department?          @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments Department[]         @relation("DepartmentHierarchy")
  contacts         InstitutionContact[]
  users            DepartmentMember[]
  managers         DepartmentManager[]

  @@index([institutionId])
  @@index([name])
  @@index([type])
  @@index([status])
  @@index([parentDepartmentId])
  @@index([headOfDepartmentId])
}

// Join table for Department members
model DepartmentMember {
  id           String   @id @default(uuid())
  departmentId String
  userId       Int
  role         String?
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       users      @relation("DepartmentMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

// Join table for Department managers
model DepartmentManager {
  id           String   @id @default(uuid())
  departmentId String
  userId       Int
  assignedAt   DateTime @default(now())
  assignedBy   String?
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       users      @relation("DepartmentManagers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

// Institution Subscription model
model InstitutionSubscription {
  id                 String   @id @default(uuid())
  institutionId      String
  plan               String
  status             String
  licenseCount       Int      @default(1)
  price              Float    @default(0)
  paymentMethod      String?
  billingCycle       String   @default("ANNUALLY")
  autoRenew          Boolean  @default(true)
  discountPercentage Float?
  discountCode       String?
  startDate          DateTime
  endDate            DateTime
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

// Join table for Institution admins
model InstitutionAdmin {
  id            String   @id @default(uuid())
  institutionId String
  userId        Int
  assignedAt    DateTime @default(now())
  assignedBy    String?
  createdAt     DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user        users       @relation("InstitutionAdmins", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([institutionId, userId])
  @@index([institutionId])
  @@index([userId])
}

// ============================================================================
// PLATFORM ORCHESTRATION LAYER
// ============================================================================

model StudentProfile {
  id         String @id @default(cuid())
  tenant_id  Int
  student_id Int    @unique

  // Auto-Built Learning Profile
  learning_style        Json?
  pace_level            String?
  difficulty_preference String?

  // Strengths & Struggles
  current_strengths String[] @default([])
  current_struggles String[] @default([])

  // Behavioral Patterns
  engagement_score    Float @default(0.5)
  persistence_score   Float @default(0.5)
  collaboration_score Float @default(0.5)

  // Readiness Predictions
  ready_to_level_up    Boolean @default(false)
  needs_intervention   Boolean @default(false)
  intervention_urgency String?

  // Cross-Year Continuity
  historical_sen_needs String[] @default([])
  effective_strategies Json[]

  // Metadata
  profile_confidence Float    @default(0)
  last_synced_at     DateTime @default(now())
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now())

  // Relations
  tenant             tenants                   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  student            students                  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  lesson_assignments StudentLessonAssignment[]
  progress_snapshots StudentProgressSnapshot[]
  automated_actions  AutomatedAction[]

  @@index([tenant_id])
  @@index([student_id])
  @@index([needs_intervention])
}

model ClassRoster {
  id         String @id @default(cuid())
  tenant_id  Int
  teacher_id Int

  // Class Details
  class_name    String
  subject       String?
  year_group    String
  academic_year String

  // Auto-Grouping
  urgent_students Int[] @default([])
  needs_support   Int[] @default([])
  on_track        Int[] @default([])
  exceeding       Int[] @default([])

  // Settings
  auto_assign   Boolean @default(true)
  voice_enabled Boolean @default(true)

  // Metadata
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  tenant       tenants      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  teacher      users        @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  lesson_plans LessonPlan[]

  @@index([tenant_id])
  @@index([teacher_id])
  @@index([academic_year])
}

model LessonPlan {
  id              String @id @default(cuid())
  tenant_id       Int
  class_roster_id String
  teacher_id      Int

  // Lesson Details
  title                String
  subject              String
  year_group           String
  curriculum_reference String?
  learning_objectives  String[]

  // Content
  description  String?
  base_content Json

  // Differentiation Levels
  has_differentiation Boolean  @default(false)
  difficulty_levels   String[] @default([])

  // Schedule
  scheduled_for    DateTime?
  duration_minutes Int       @default(60)

  // Status
  status String @default("draft")

  // Metadata
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  tenant              tenants                   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  class_roster        ClassRoster               @relation(fields: [class_roster_id], references: [id], onDelete: Cascade)
  teacher             users                     @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  activities          LessonActivity[]
  student_assignments StudentLessonAssignment[]

  @@index([tenant_id])
  @@index([class_roster_id])
  @@index([teacher_id])
  @@index([status])
}

model LessonActivity {
