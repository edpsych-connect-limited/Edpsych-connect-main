  description String?
  color       String? // Hex color for category badge
  order_index Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  // Relations
  posts BlogPost[]

  @@index([slug])
  @@index([is_active])
}

model BlogPost {
  id             String  @id @default(uuid())
  category_id    String
  title          String
  slug           String  @unique
  content        String  @db.Text
  excerpt        String?
  featured_image String? // URL to featured image

  // SEO
  meta_title       String?
  meta_description String?
  keywords         String[] @default([])

  // Author
  author_name  String
  author_email String?
  author_bio   String?

  // Metadata
  views        Int  @default(0)
  reading_time Int? // Minutes
  order_index  Int  @default(0)

