  is_published Boolean @default(true)
  is_featured  Boolean @default(false)

  // Context-sensitive help
  page_context String[] @default([]) // Pages where this appears contextually

  // Dates
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())
  published_at DateTime?

  // Relations
  category HelpCategory         @relation(fields: [category_id], references: [id], onDelete: Cascade)
  related  HelpArticleRelated[] @relation("ArticleRelated")

  @@index([category_id])
  @@index([slug])
  @@index([is_published])
  @@index([page_context])
