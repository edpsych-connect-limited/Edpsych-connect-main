  @@index([is_approved])
}

// ============================================================================
// SUBSCRIPTION & BILLING (STRIPE INTEGRATED)
// ============================================================================

model subscriptions {
  id        Int @id @default(autoincrement())
  tenant_id Int

  // Tier-based access control
  tier         SubscriptionTier @default(FREE)
  max_schools  Int?
  max_users    Int?
  max_students Int?

  // Legacy fields (backward compatibility)
  plan_type      String
  payment_status String
  amount_paid    Decimal

  // Dates
  start_date DateTime
  end_date   DateTime
  is_active  Boolean  @default(true)

  // Stripe integration
  stripe_customer_id     String? @unique
  stripe_subscription_id String? @unique
  stripe_price_id        String?

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  tenants       tenants         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  feature_usage feature_usage[] @relation("SubscriptionFeatureUsage")

  @@index([tenant_id])
  @@index([tier])
  @@index([is_active])
  @@index([stripe_customer_id])
}

// ============================================================================
// MISSING MODELS RESTORED
// ============================================================================

model feature_usage {
  id              Int              @id @default(autoincrement())
  subscription_id Int
  tenant_id       Int
  feature         Feature
  tier            SubscriptionTier
  duration        Int?
  metadata        Json?
  timestamp       DateTime         @default(now())

  // Relations
  subscription subscriptions @relation("SubscriptionFeatureUsage", fields: [subscription_id], references: [id], onDelete: Cascade)
  tenant       tenants       @relation("TenantFeatureUsage", fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([subscription_id])
  @@index([tenant_id])
  @@index([feature])
  @@index([timestamp])
}

model ParentTeacherMessage {
  id         String    @id @default(uuid())
  tenantId   Int
  senderId   Int
  receiverId Int
  content    String
  subject    String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now())

  tenant    tenants   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sender    users     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver  users     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  studentId Int?
  student   students? @relation(fields: [studentId], references: [id])

  @@index([tenantId])
  @@index([senderId])
  @@index([receiverId])
}

model Institution {
  id                 String    @id @default(uuid())
  name               String
  type               String
  size               String
  address            String?
  city               String?
  region             String?
  postcode           String?
  country            String?
  phone              String?
  email              String
  website            String?
  logoUrl            String?
  notes              String?   @db.Text
  tags               String[]  @default([])
  customFields       Json?
  verificationStatus String    @default("PENDING")
  verifiedAt         DateTime?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now())
  createdBy          String?

  contacts      InstitutionContact[]
  departments   Department[]
  subscriptions InstitutionSubscription[]
  admins        InstitutionAdmin[]

  @@index([name])
  @@index([type])
  @@index([verificationStatus])
  @@index([isActive])
  @@index([email])
}

model InstitutionContact {
  id               String   @id @default(uuid())
  institutionId    String
  firstName        String
  lastName         String
  email            String
  phone            String?
  role             String?
  isPrimaryContact Boolean  @default(false)
  jobTitle         String?
  notes            String?  @db.Text
  departmentId     String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([institutionId])
  @@index([email])
  @@index([isPrimaryContact])
  @@index([departmentId])
}

model Department {
  id                 String   @id @default(uuid())
  institutionId      String
  name               String
  description        String?  @db.Text
  type               String
  parentDepartmentId String?
  headOfDepartmentId String?
  status             String   @default("ACTIVE")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now())
  createdBy          String

  institution      Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  parentDepartment Department?          @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments Department[]         @relation("DepartmentHierarchy")
  contacts         InstitutionContact[]
  users            DepartmentMember[]
  managers         DepartmentManager[]

  @@index([institutionId])
  @@index([name])
  @@index([type])
  @@index([status])
  @@index([parentDepartmentId])
  @@index([headOfDepartmentId])
}

// Join table for Department members
model DepartmentMember {
  id           String   @id @default(uuid())
  departmentId String
  userId       Int
  role         String?
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       users      @relation("DepartmentMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

// Join table for Department managers
model DepartmentManager {
  id           String   @id @default(uuid())
  departmentId String
  userId       Int
  assignedAt   DateTime @default(now())
  assignedBy   String?
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       users      @relation("DepartmentManagers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

// Institution Subscription model
model InstitutionSubscription {
  id                 String   @id @default(uuid())
  institutionId      String
  plan               String
  status             String
  licenseCount       Int      @default(1)
