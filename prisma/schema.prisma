  message     String   @db.Text
  rating      Int?
  status      String   @default("new") // new, reviewing, accepted, rejected, completed
  
  metadata    Json?    // Browser info, page url, etc.
  
  user        users?   @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([status])
}

model SurveyResponse {
  id          String   @id @default(cuid())
  surveyId    String
  userId      Int?
  
  answers     Json     // Object of { questionId: answer }
  
  user        users?   @relation(fields: [userId], references: [id])
  
  completedAt DateTime @default(now())

  @@index([surveyId])
  @@index([userId])
}

model UserInterview {
  id          String   @id @default(cuid())
  userId      Int
  scheduledAt DateTime
  status      String   // scheduled, completed, cancelled, no_show
  notes       String?  @db.Text
  recordingUrl String?
  
  user        users    @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([userId])
  @@index([status])
}

// ============================================================================
// AI ANALYTICS
// ============================================================================

model AnalyticsEvent {
  id          String   @id @default(cuid())
  userId      Int?
  eventType   String   // completion, error, feedback, latency
  model       String?
  tokensIn    Int?
  tokensOut   Int?
  latencyMs   Int?
  cost        Float?
  
  metadata    Json?    // Prompt hash, error details, etc.
  
  user        users?   @relation(fields: [userId], references: [id])
  
  timestamp   DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([timestamp])
}

// ============================================================================
// PARENTAL ENGAGEMENT
// ============================================================================

model ParentalTip {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  category    String   // behavior, learning, emotional
  ageRange    String?  // 5-7, 8-10, etc.
  
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
}

model ParentEngagementActivity {
  id          String   @id @default(cuid())
  parentId    Int
  activityType String  // login, read_tip, completed_task
  details     Json?
  
  parent      parents  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@index([parentId])
}

// ============================================================================
// TENANT DATABASE CONFIGURATION (BYOD)
// ============================================================================

model TenantDatabaseConfig {
  id          String   @id @default(cuid())
  tenant_id   Int      @unique
  
  // Connection Details
  provider    String   @default("postgresql") // postgresql, mysql, sqlserver
  host        String
  port        Int      @default(5432)
  database    String
  username    String
  password    String   // Encrypted at rest
  ssl_mode    String   @default("require")
  
  // Status
  is_active   Boolean  @default(true)
  last_check  DateTime?
  status      String   @default("connected") // connected, error, maintenance
  
  // Metadata
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
  
  tenant      tenants  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  
  @@index([tenant_id])
}
