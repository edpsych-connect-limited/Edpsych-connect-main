model Certificate {
  id               String   @id @default(uuid())
  userId           Int      // Changed to Int to match users.id
  courseId         String
  verificationCode String   @unique
  issueDate        DateTime @default(now())
  completionDate   DateTime
  grade            String?
  skills           String[]
  status           String   @default("issued")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Restrict)
  user   users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
}

model CourseQuiz {
  id           String   @id @default(uuid())
  courseId     String
  moduleId     String?
  lessonId     String?
  title        String
  description  String?  @db.Text
  timeLimit    Int?
  passingScore Int      @default(70)
  orderIndex   Int
  isRequired   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())

  // Relations
  course    Course         @relation(fields: [courseId], references: [id])
  module    CourseModule?  @relation(fields: [moduleId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([courseId])
}

model QuizQuestion {
  id            String   @id @default(uuid())
  quizId        String
  questionText  String   @db.Text
  questionType  String
  options       Json?
  correctAnswer String   @db.Text
  explanation   String?  @db.Text
  points        Int      @default(1)
  orderIndex    Int
  difficulty    String   @default("medium")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())

  // Relations
  quiz    CourseQuiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
}

model QuizAttempt {
  id          String    @id @default(uuid())
  quizId      String
  userId      String    // Keeping String if it's not linked to users directly or if users.id is Int. I should probably change to Int.
  score       Int
  maxScore    Int
  isPassed    Boolean
  timeSpent   Int
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  // Relations
  quiz    CourseQuiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
  @@index([userId])
}

model QuizAnswer {
  id           String   @id @default(uuid())
  attemptId    String
  questionId   String
  userAnswer   String   @db.Text
  isCorrect    Boolean
  pointsEarned Int      @default(0)
  createdAt    DateTime @default(now())

  // Relations
  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

model LessonProgress {
  id           String    @id @default(uuid())
  userId       String
  courseId     String
  moduleId     String
  lessonId     String
  status       String    @default("not_started")
  progress     Int       @default(0)
  timeSpent    Int       @default(0)
  lastPosition Int?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([courseId])
}

// ============================================================================
// TRAINING MONETIZATION
// ============================================================================

model TrainingProduct {
  id                    String   @id @default(uuid())
  type                  String
  name                  String
  description           String   @db.Text
  slug                  String   @unique
  price_gbp             Int
  original_price_gbp    Int?
  currency              String   @default("GBP")
  cpd_hours             Float?
  course_id             String?
  included_course_ids   String[]
  access_duration_days  Int?
  stripe_product_id     String?  @unique
  stripe_price_id       String?  @unique
  status                String   @default("active")
  is_featured           Boolean  @default(false)
  sort_order            Int      @default(0)
  promotional_text      String?
  benefits              String[]
  target_audience       String[]
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())

  purchases             TrainingPurchase[]

  @@index([type])
  @@index([status])
  @@index([slug])
}

model TrainingPurchase {
  id                    String    @id @default(uuid())
  user_id               Int
  email                 String
  product_id            String
  product_name          String
  product_type          String
  amount_paid_pence     Int
  currency              String    @default("GBP")
  discount_code         String?
  discount_amount_pence Int?
  course_ids            String[]
  access_duration_days  Int?
  access_granted_at     DateTime  @default(now())
  access_expires_at     DateTime?
  stripe_customer_id    String?
  stripe_payment_intent_id String? @unique
  stripe_invoice_id     String?
  payment_method        String?
  payment_status        String    @default("pending")
  receipt_url           String?
  invoice_number        String?   @unique
  status                String    @default("active")
  refunded_at           DateTime?
  refund_amount_pence   Int?
  refund_reason         String?
  purchase_metadata     Json?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now())

  product               TrainingProduct    @relation(fields: [product_id], references: [id])
  enrollments           CourseEnrollment[]
  legacy_enrollments    enrollments[]
  user                  users              @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([product_id])
  @@index([payment_status])
}

model DiscountCode {
  id                    String    @id @default(uuid())
  code                  String    @unique
  name                  String
  description           String?
  discount_type         String
  discount_value        Int
  applies_to            String
  applicable_product_ids String[]
  min_purchase_pence    Int?
  max_uses              Int?
  max_uses_per_user     Int       @default(1)
  current_uses          Int       @default(0)
  valid_from            DateTime  @default(now())
  valid_until           DateTime?
  is_active             Boolean   @default(true)
  created_by            String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now())

  @@index([code])
  @@index([is_active])
}

model InteractiveElement {
  id                    String   @id @default(uuid())
  lesson_id             String
  order_index           Int
  type                  String
  title                 String?
  content               Json
  is_required           Boolean  @default(false)
  passing_score         Int?
  max_attempts          Int?
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())

  responses             InteractiveResponse[]

  @@index([lesson_id])
  @@index([type])
}

model InteractiveResponse {
  id                    String   @id @default(uuid())
  user_id               Int
  element_id            String
  enrollment_id         String
  response_data         Json
  score                 Float?
  is_correct            Boolean?
  attempt_number        Int      @default(1)
  time_spent_seconds    Int?
  submitted_at          DateTime @default(now())
  feedback_shown        String?  @db.Text

  element               InteractiveElement @relation(fields: [element_id], references: [id])
  user                  users              @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([element_id])
}

model LearningPath {
  id                    String   @id @default(uuid())
  name                  String
  description           String   @db.Text
  slug                  String   @unique
  course_ids            String[]
  total_cpd_hours       Float
  estimated_duration    Int
  price_gbp             Int?
  status                String   @default("active")
  is_featured           Boolean  @default(false)
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())

  enrollments           LearningPathEnrollment[]

  @@index([slug])
  @@index([status])
}

model LearningPathEnrollment {
  id                    String   @id @default(uuid())
  user_id               Int
  path_id               String
  current_course_index  Int      @default(0)
  completed_course_ids  String[] @default([])
  progress_percentage   Int      @default(0)
  status                String   @default("active")
  started_at            DateTime @default(now())
  completed_at          DateTime?

  path                  LearningPath @relation(fields: [path_id], references: [id])
  user                  users        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, path_id])
  @@index([user_id])
  @@index([path_id])
}

model CertificateTemplate {
  id                    String   @id @default(uuid())
  name                  String
  template_type         String
  background_image_url  String?
  logo_url              String?
  layout_config         Json
  title_template        String
  body_template         String   @db.Text
  footer_text           String?
  includes_qr_code      Boolean  @default(true)
  includes_verification_url Boolean @default(true)
  is_active             Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())

  @@index([template_type])
  @@index([is_active])
}

model CPDLog {
  id                    String   @id @default(uuid())
  user_id               Int
  activity_type         String
  activity_title        String
  activity_description  String?  @db.Text
  cpd_hours             Float
  cpd_category          String
  certificate_id        String?
  evidence_urls         String[]
  activity_date         DateTime
  logged_at             DateTime @default(now())
  status                String   @default("pending")
  verified_by           String?
  verified_at           DateTime?
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())

  user                  users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([activity_date])
}

// ============================================================================
// MARKETPLACE & COMPLIANCE
// ============================================================================

model ProfessionalCompliance {
  id                    String   @id @default(uuid())
  userId                Int      @unique
  hcpcNumber            String?
  hcpcStatus            String?  @default("pending")
  dbsNumber             String?
  dbsUpdateServiceId    String?
  insurancePolicyNo     String?
  insuranceDocUrl       String?
  insuranceExpiryDate   DateTime?
  insuranceCoverageAmount Float?
  dbsCertificateUrl     String?
  hcpcExpiryDate        DateTime?
  verificationStatus    String   @default("pending")
  verifiedAt            DateTime?
  verifiedBy            Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now())

  user                  users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MarketplaceProfessional {
  id                    String   @id @default(uuid())
  userId                Int      @unique
  bio                   String?  @db.Text
  specialties           String[]
  hourlyRate            Float?
  availability          Json?
  rating                Float    @default(0)
  reviewCount           Int      @default(0)
  
  // LA Panel Fields
  la_panel_status       String   @default("NOT_APPLIED") // APPROVED, PENDING, REJECTED, NOT_APPLIED
  la_panel_regions      String[] @default([])
  commission_rate       Float    @default(15.0)
  la_panel_approved_at  DateTime?
  panel_membership_tier String?
  
  qualifications_documents String[] @default([])
  references              Json?
  cv_document_url         String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now())

  user                  users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews               MarketplaceReview[]
}

model ServiceListing {
  id                    String   @id @default(uuid())
  userId                Int
  title                 String
  description           String   @db.Text
  price                 Float
  durationMinutes       Int?
  serviceType           String
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now())

  user                  users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contracts             ServiceContract[]
}

model ServiceContract {
  id                    String   @id @default(uuid())
  listingId             String?
  epId                  Int
  tenantId              Int
  status                String   @default("draft")
  totalAmount           Float
  platformFee           Float
  epPayout              Float
  escrowStatus          String   @default("pending")
  stripePaymentIntentId String?
  stripeTransferId      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now())

  listing               ServiceListing? @relation(fields: [listingId], references: [id])
  ep                    users           @relation("EPContracts", fields: [epId], references: [id])
  tenant                tenants         @relation(fields: [tenantId], references: [id])
}

model MarketplaceReview {
  id                    String   @id @default(uuid())
  professionalId        String
  authorId              Int
  rating                Int
  comment               String?  @db.Text
  createdAt             DateTime @default(now())

  professional          MarketplaceProfessional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  author                users                     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

