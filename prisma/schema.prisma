  @@index([order_index])
}

model AssessmentInstance {
  id           String @id @default(uuid())
  tenant_id    Int
  framework_id String
  case_id      Int
  student_id   Int

  title           String?
  conducted_by    Int
  assessment_date DateTime?

  status              String @default("draft")
  progress_percentage Int    @default(0)

