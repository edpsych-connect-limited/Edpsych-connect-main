// ============================================================================
// HELP CENTER & DOCUMENTATION
// ============================================================================

model HelpCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String? // Icon name or emoji
  order_index Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  articles HelpArticle[]

  @@index([slug])
  @@index([is_active])
}

model HelpArticle {
  id              String   @id @default(uuid())
  category_id     String
  title           String
  slug            String   @unique
  content         String   @db.Text
  excerpt         String?
  search_keywords String[] @default([])

  // Metadata
  author      String? // Author name
  views       Int     @default(0)
  helpful_yes Int     @default(0)
  helpful_no  Int     @default(0)
  order_index Int     @default(0)

  // Status
  is_published Boolean @default(true)
  is_featured  Boolean @default(false)

  // Context-sensitive help
  page_context String[] @default([]) // Pages where this appears contextually

  // Dates
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  published_at DateTime?

  // Relations
  category HelpCategory         @relation(fields: [category_id], references: [id], onDelete: Cascade)
  related  HelpArticleRelated[] @relation("ArticleRelated")

  @@index([category_id])
  @@index([slug])
  @@index([is_published])
  @@index([page_context])
}

model HelpArticleRelated {
  article_id String
  related_id String

  article HelpArticle @relation("ArticleRelated", fields: [article_id], references: [id], onDelete: Cascade)

  @@id([article_id, related_id])
}

model HelpFAQ {
  id          String   @id @default(uuid())
  question    String
  answer      String   @db.Text
  category    String? // General, Technical, Billing, etc.
  order_index Int      @default(0)
  views       Int      @default(0)
  helpful_yes Int      @default(0)
  helpful_no  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([category])
  @@index([is_active])
}

model HelpSearchLog {
  id         String   @id @default(uuid())
  user_id    Int?
  query      String
  results    Int      @default(0)
  clicked_id String? // Article ID that was clicked
  created_at DateTime @default(now())

  @@index([query])
  @@index([created_at])
}

// ============================================================================
// BLOG & CONTENT MARKETING
// ============================================================================

model BlogCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  color       String? // Hex color for category badge
  order_index Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  posts BlogPost[]

  @@index([slug])
  @@index([is_active])
}

model BlogPost {
  id             String  @id @default(uuid())
  category_id    String
  title          String
  slug           String  @unique
  content        String  @db.Text
  excerpt        String?
  featured_image String? // URL to featured image

  // SEO
  meta_title       String?
  meta_description String?
  keywords         String[] @default([])

  // Author
  author_name  String
  author_email String?
  author_bio   String?

  // Metadata
  views        Int  @default(0)
  reading_time Int? // Minutes
  order_index  Int  @default(0)

  // Status
  is_published Boolean @default(false)
  is_featured  Boolean @default(false)

  // Dates
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  published_at DateTime?

  // Relations
  category BlogCategory  @relation(fields: [category_id], references: [id], onDelete: Cascade)
  tags     BlogPostTag[]
  comments BlogComment[]

  @@index([category_id])
  @@index([slug])
  @@index([is_published])
  @@index([published_at])
}

model BlogTag {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  created_at DateTime @default(now())

  // Relations
  posts BlogPostTag[]

  @@index([slug])
}

model BlogPostTag {
  post_id String
  tag_id  String

  post BlogPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([post_id, tag_id])
}

model BlogComment {
  id           String   @id @default(uuid())
  post_id      String
  author_name  String
  author_email String
  content      String   @db.Text
  is_approved  Boolean  @default(false)
  created_at   DateTime @default(now())

  // Relations
  post BlogPost @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@index([post_id])
  @@index([is_approved])
}

// ============================================================================
// SUBSCRIPTION & BILLING (STRIPE INTEGRATED)
// ============================================================================

model subscriptions {
  id        Int @id @default(autoincrement())
  tenant_id Int

  // Tier-based access control
  tier         SubscriptionTier @default(TRIAL)
  max_schools  Int?
  max_users    Int?
  max_students Int?

  // Legacy fields (backward compatibility)
  plan_type      String
  payment_status String
  amount_paid    Decimal

  // Dates
  start_date DateTime
  end_date   DateTime
  is_active  Boolean  @default(true)

  // Stripe integration
  stripe_customer_id     String? @unique
  stripe_subscription_id String? @unique
  stripe_price_id        String?

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  tenants       tenants         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  feature_usage feature_usage[]

  @@index([tenant_id])
  @@index([tier])
  @@index([is_active])
  @@index([stripe_customer_id])
}

model feature_usage {
  id              Int              @id @default(autoincrement())
  subscription_id Int
  tenant_id       Int
  feature         Feature
  tier            SubscriptionTier
  duration        Int?
  metadata        Json?
  timestamp       DateTime         @default(now())

  // Relations
  subscription subscriptions @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@index([subscription_id])
  @@index([tenant_id])
  @@index([feature])
  @@index([timestamp])
}

// ============================================================================
// TRAINING & CPD MANAGEMENT MODELS
// ============================================================================

model Course {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  category    String
  level       String
  duration    Int // in minutes
  imageUrl    String?
  status      String   @default("draft") // draft, published, archived
  cpdHours    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  instructor   CourseInstructor?
  modules      CourseModule[]
  enrollments  CourseEnrollment[]
  reviews      CourseReview[]
  certificates Certificate[]
  CourseQuiz   CourseQuiz[]

  @@index([category])
  @@index([status])
  @@index([level])
}

model CourseInstructor {
  id        String   @id @default(uuid())
  courseId  String   @unique
  name      String
  title     String?
  bio       String?  @db.Text
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model CourseModule {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?  @db.Text
  orderIndex  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  course  Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons CourseLesson[]

  @@index([courseId])
  @@index([orderIndex])
}

model CourseLesson {
  id         String   @id @default(uuid())
  moduleId   String
  title      String
  content    String?  @db.Text
  videoUrl   String?
  duration   Int? // in minutes
  orderIndex Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@index([orderIndex])
}

model CourseEnrollment {
  id             String    @id @default(uuid())
  userId         String
  courseId       String
  status         String    @default("active") // active, completed, suspended
  progress       Int       @default(0) // 0-100
  timeSpent      Int       @default(0) // in minutes
  lastAccessedAt DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  course             Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  TrainingPurchase   TrainingPurchase? @relation(fields: [trainingPurchaseId], references: [id])
  trainingPurchaseId String?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model CourseReview {
  id        String   @id @default(uuid())
  courseId  String
  userId    String
  rating    Int // 1-5
  comment   String?  @db.Text
  status    String   @default("pending") // pending, published, rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([userId])
  @@index([status])
}

model Certificate {
  id               String   @id @default(uuid())
  userId           String
  courseId         String
  verificationCode String   @unique
  issueDate        DateTime @default(now())
  completionDate   DateTime
  grade            String?
  skills           String[] // Array of skills/competencies achieved
  status           String   @default("issued") // issued, revoked
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([courseId])
  @@index([verificationCode])
  @@index([status])
}

model CPDEntry {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime
  activity    String
  category    String
  hours       Float
  provider    String
  certificate Boolean  @default(false)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@index([category])
}

// ============================================================================
// ASSESSMENT MODELS
