model SquadCompetition {
  id                   String   @id @default(uuid())
  name                 String
  description          String   @db.Text
  type                 String
  format               String
  division             String?
  status               String   @default("upcoming")
  maxParticipants      Int
  entryMeritCost       Int      @default(0)
  prizePool            Json
  objectives           Json
  startDate            DateTime
  endDate              DateTime
