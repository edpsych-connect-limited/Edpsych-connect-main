// ============================================================================
// SUBSCRIPTION & BILLING (STRIPE INTEGRATED)
// ============================================================================

model subscriptions {
  id        Int @id @default(autoincrement())
  tenant_id Int

  // Tier-based access control
  tier         SubscriptionTier @default(TRIAL)
  max_schools  Int?
  max_users    Int?
  max_students Int?

  // Legacy fields (backward compatibility)
  plan_type      String
  payment_status String
  amount_paid    Decimal

  // Dates
  start_date DateTime
  end_date   DateTime
  is_active  Boolean  @default(true)

  // Stripe integration
  stripe_customer_id     String? @unique
  stripe_subscription_id String? @unique
  stripe_price_id        String?

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  tenants       tenants         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  feature_usage feature_usage[]

  @@index([tenant_id])
  @@index([tier])
  @@index([is_active])
  @@index([stripe_customer_id])
}

model feature_usage {
  id              Int              @id @default(autoincrement())
  subscription_id Int
  tenant_id       Int
  feature         Feature
  tier            SubscriptionTier
  duration        Int?
  metadata        Json?
  timestamp       DateTime         @default(now())

  // Relations
  subscription subscriptions @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@index([subscription_id])
  @@index([tenant_id])
  @@index([feature])
  @@index([timestamp])
}

// ============================================================================
// TRAINING & CPD MANAGEMENT MODELS
// ============================================================================

model Course {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  category    String
  level       String
  duration    Int // in minutes
  imageUrl    String?
  status      String   @default("draft") // draft, published, archived
  cpdHours    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  instructor   CourseInstructor?
  modules      CourseModule[]
  enrollments  CourseEnrollment[]
  reviews      CourseReview[]
  certificates Certificate[]
  CourseQuiz   CourseQuiz[]

  @@index([category])
  @@index([status])
  @@index([level])
}

model CourseInstructor {
  id        String   @id @default(uuid())
  courseId  String   @unique
  name      String
  title     String?
  bio       String?  @db.Text
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model CourseModule {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?  @db.Text
  orderIndex  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  course  Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons CourseLesson[]

  @@index([courseId])
  @@index([orderIndex])
}

model CourseLesson {
  id         String   @id @default(uuid())
  moduleId   String
  title      String
  content    String?  @db.Text
  videoUrl   String?
  duration   Int? // in minutes
  orderIndex Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@index([orderIndex])
}

model CourseEnrollment {
  id             String    @id @default(uuid())
  userId         String
  courseId       String
  status         String    @default("active") // active, completed, suspended
  progress       Int       @default(0) // 0-100
  timeSpent      Int       @default(0) // in minutes
  lastAccessedAt DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  course             Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  TrainingPurchase   TrainingPurchase? @relation(fields: [trainingPurchaseId], references: [id])
  trainingPurchaseId String?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model CourseReview {
  id        String   @id @default(uuid())
  courseId  String
  userId    String
  rating    Int // 1-5
  comment   String?  @db.Text
  status    String   @default("pending") // pending, published, rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([userId])
  @@index([status])
}

model Certificate {
  id               String   @id @default(uuid())
  userId           String
  courseId         String
  verificationCode String   @unique
  issueDate        DateTime @default(now())
  completionDate   DateTime
  grade            String?
  skills           String[] // Array of skills/competencies achieved
  status           String   @default("issued") // issued, revoked
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([courseId])
  @@index([verificationCode])
  @@index([status])
}

model CPDEntry {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime
  activity    String
  category    String
  hours       Float
  provider    String
  certificate Boolean  @default(false)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@index([category])
}

// ============================================================================
// ASSESSMENT MODELS
// ============================================================================

model Assessment {
  id             String    @id @default(uuid())
  studentId      String
  assessmentType String
  title          String
  description    String?   @db.Text
  status         String    @default("draft") // draft, in_progress, completed
  assessedBy     String
  assessmentDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  results AssessmentResult[]

  @@index([studentId])
  @@index([status])
  @@index([assessmentType])
  @@index([assessmentDate])
}

model AssessmentResult {
  id           String   @id @default(uuid())
  assessmentId String
  domain       String
  score        Float
  maxScore     Float
  percentile   Float?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([domain])
}

// ============================================================================
// SECURE STORAGE MODEL
// ============================================================================

model SecureDocument {
  id        String   @id @default(uuid())
  path      String   @unique
  content   String   @db.Text
  metadata  Json?
  encrypted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([path])
  @@index([encrypted])
}

// ============================================================================
// BETA ACCESS MODEL
// ============================================================================

model BetaAccessCode {
  id            String    @id @default(uuid())
  code          String    @unique
  email         String?
  usedBy        String?
  usedAt        DateTime?
  maxUses       Int       @default(1)
  currentUses   Int       @default(0)
  remainingUses Int       @default(1)
  role          String?
  features      String[]  @default([])
  metadata      Json?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([code])
  @@index([email])
  @@index([usedBy])
}

model BetaAccessCodeUsage {
  id           String   @id @default(uuid())
  accessCodeId String
  userId       String?
  usedAt       DateTime @default(now())
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([accessCodeId])
  @@index([userId])
  @@index([usedAt])
}

model LegalSignature {
  id               String   @id @default(uuid())
  userId           String
  documentId       String?
  agreementType    String
  agreementVersion String
  signatureData    String   @db.Text
  signedAt         DateTime @default(now())
  timestamp        DateTime @default(now())
  ipAddress        String?
  userAgent        String?
  status           String   @default("active")
  verified         Boolean  @default(false)
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([documentId])
  @@index([timestamp])
  @@index([signedAt])
}

// ============================================================================
// AUDIT & LEGAL MODELS
// ============================================================================

model AuditLog {
  id             String   @id @default(uuid())
  userId         String?
  performedById  String?
  institutionId  String?
  subscriptionId String?
  action         String
  resource       String?
  description    String?
  details        Json?
  entityType     String?
  entityId       String?
  changes        Json?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  timestamp      DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([performedById])
  @@index([institutionId])
  @@index([subscriptionId])
  @@index([resource])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@index([action])
  @@map("audit_logs")
}

model LegalDocument {
  id            String   @id @default(uuid())
  type          String
  version       String
  content       String   @db.Text
  effectiveDate DateTime
  status        String   @default("active")
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
  @@index([version])
  @@index([status])
  @@index([effectiveDate])
}

// ============================================================================
// USER PREFERENCES MODEL
// ============================================================================

model UserPreference {
  id              String   @id @default(uuid())
  userId          String   @unique
  category        String?
  type            String?
  value           Json?
  theme           String?  @default("light")
  language        String?  @default("en")
  notifications   Json?
  accessibility   Json?
  privacy         Json?
  displaySettings Json?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([type])
}

// ============================================================================
// VOLUME DISCOUNT MODEL
// ============================================================================

model VolumeDiscountTier {
  id              String   @id @default(uuid())
  tier            String
  minQuantity     Int
  maxQuantity     Int?
  discountPercent Float
  description     String?
  isActive        Boolean  @default(true)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tier])
  @@index([minQuantity])
  @@index([isActive])
}

// ============================================================================
// INSTITUTIONAL MANAGEMENT MODELS
// ============================================================================

model Institution {
  id                 String    @id @default(uuid())
  name               String
  type               String
  size               String
  address            String?
  city               String?
  region             String?
  postcode           String?
  country            String?
  phone              String?
  email              String
  website            String?
  logoUrl            String?
  notes              String?   @db.Text
  tags               String[]  @default([])
  customFields       Json?
  verificationStatus String    @default("PENDING")
  verifiedAt         DateTime?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdBy          String?

  contacts      InstitutionContact[]
  departments   Department[]
  subscriptions InstitutionSubscription[]
  admins        InstitutionAdmin[]

  @@index([name])
  @@index([type])
  @@index([verificationStatus])
  @@index([isActive])
  @@index([email])
}

model InstitutionContact {
  id               String   @id @default(uuid())
  institutionId    String
  firstName        String
  lastName         String
  email            String
  phone            String?
  role             String?
  isPrimaryContact Boolean  @default(false)
  jobTitle         String?
  notes            String?  @db.Text
  departmentId     String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([institutionId])
  @@index([email])
  @@index([isPrimaryContact])
  @@index([departmentId])
}

model Department {
  id                 String   @id @default(uuid())
  institutionId      String
  name               String
  description        String?  @db.Text
  type               String
  parentDepartmentId String?
  headOfDepartmentId String?
  status             String   @default("ACTIVE")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          String

  institution      Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  parentDepartment Department?          @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments Department[]         @relation("DepartmentHierarchy")
  contacts         InstitutionContact[]
  users            DepartmentMember[]
  managers         DepartmentManager[]

  @@index([institutionId])
  @@index([name])
  @@index([type])
  @@index([status])
  @@index([parentDepartmentId])
  @@index([headOfDepartmentId])
}

// Join table for Department members
model DepartmentMember {
  id           String   @id @default(uuid())
  departmentId String
  userId       Int
  role         String?
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       users      @relation("DepartmentMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

// Join table for Department managers
model DepartmentManager {
  id           String   @id @default(uuid())
  departmentId String
  userId       Int
  assignedAt   DateTime @default(now())
  assignedBy   String?
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       users      @relation("DepartmentManagers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

// Institution Subscription model
model InstitutionSubscription {
  id                 String   @id @default(uuid())
  institutionId      String
  plan               String
  status             String
  licenseCount       Int      @default(1)
  price              Float    @default(0)
  paymentMethod      String?
  billingCycle       String   @default("ANNUALLY")
  autoRenew          Boolean  @default(true)
  discountPercentage Float?
  discountCode       String?
  startDate          DateTime
  endDate            DateTime
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

// Join table for Institution admins
model InstitutionAdmin {
  id            String   @id @default(uuid())
  institutionId String
  userId        Int
  assignedAt    DateTime @default(now())
  assignedBy    String?
  createdAt     DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user        users       @relation("InstitutionAdmins", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([institutionId, userId])
  @@index([institutionId])
  @@index([userId])
}

// ============================================================================
// PHASE 4: TRAINING PLATFORM EXTENSIONS
// ============================================================================

model CourseQuiz {
  id           String   @id @default(uuid())
  courseId     String
  moduleId     String?
  lessonId     String?
  title        String
  description  String?  @db.Text
  timeLimit    Int? // in minutes
  passingScore Int      @default(70) // percentage
  orderIndex   Int
  isRequired   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  course    Course         @relation(fields: [courseId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([courseId])
  @@index([moduleId])
  @@index([lessonId])
  @@index([orderIndex])
}

model QuizQuestion {
  id            String   @id @default(uuid())
  quizId        String
  questionText  String   @db.Text
  questionType  String // multiple_choice, true_false, short_answer, essay
  options       Json? // For multiple choice: ["Option 1", "Option 2", ...]
  correctAnswer String   @db.Text // JSON for flexibility
  explanation   String?  @db.Text
  points        Int      @default(1)
  orderIndex    Int
  difficulty    String   @default("medium") // easy, medium, hard
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  quiz    CourseQuiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

