model TenantDatabaseConfig {
  id          String   @id @default(cuid())
  tenant_id   Int      @unique
  
  // Connection Details
  provider    String   @default("postgresql") // postgresql, mysql, sqlserver
  host        String
  port        Int      @default(5432)
  database    String
  username    String
  password    String   // Encrypted at rest
  ssl_mode    String   @default("require")
  
  // Status
  is_active   Boolean  @default(true)
  last_check  DateTime?
  status      String   @default("connected") // connected, error, maintenance
  
  // Metadata
