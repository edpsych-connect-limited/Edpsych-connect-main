  instructor   CourseInstructor?
  modules      CourseModule[]
  enrollments  CourseEnrollment[]
  reviews      CourseReview[]
  certificates Certificate[]
  quizzes      CourseQuiz[]

  @@index([category])
  @@index([status])
}

