  tenant      tenants? @relation(fields: [tenant_id], references: [id])
  user_id_int Int?
  user        users?   @relation(fields: [user_id_int], references: [id])

  @@unique([squadId, userId])
  @@index([squadId])
  @@index([userId])
  @@index([role])
  @@index([isActive])
