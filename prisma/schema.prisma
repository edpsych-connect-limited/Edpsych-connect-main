// ============================================================================
// HELP CENTER & DOCUMENTATION
// ============================================================================

model HelpCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String? // Icon name or emoji
  order_index Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  // Relations
  articles HelpArticle[]

  @@index([slug])
  @@index([is_active])
}

model HelpArticle {
  id              String   @id @default(uuid())
  category_id     String
  title           String
  slug            String   @unique
  content         String   @db.Text
  excerpt         String?
  search_keywords String[] @default([])

  // Metadata
  author      String? // Author name
  views       Int     @default(0)
  helpful_yes Int     @default(0)
  helpful_no  Int     @default(0)
  order_index Int     @default(0)

  // Status
  is_published Boolean @default(true)
  is_featured  Boolean @default(false)

  // Context-sensitive help
  page_context String[] @default([]) // Pages where this appears contextually

  // Dates
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())
  published_at DateTime?

  // Relations
  category HelpCategory         @relation(fields: [category_id], references: [id], onDelete: Cascade)
  related  HelpArticleRelated[] @relation("ArticleRelated")

  @@index([category_id])
  @@index([slug])
  @@index([is_published])
  @@index([page_context])
}

model HelpArticleRelated {
  article_id String
  related_id String

  article HelpArticle @relation("ArticleRelated", fields: [article_id], references: [id], onDelete: Cascade)

  @@id([article_id, related_id])
}

model HelpFAQ {
  id          String   @id @default(uuid())
  question    String
  answer      String   @db.Text
  category    String? // General, Technical, Billing, etc.
  order_index Int      @default(0)
  views       Int      @default(0)
  helpful_yes Int      @default(0)
  helpful_no  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  @@index([category])
  @@index([is_active])
}

model HelpSearchLog {
  id         String   @id @default(uuid())
  user_id    Int?
  query      String
  results    Int      @default(0)
  clicked_id String? // Article ID that was clicked
  created_at DateTime @default(now())

  @@index([query])
  @@index([created_at])
}

// ============================================================================
// BLOG & CONTENT MARKETING
// ============================================================================

model BlogCategory {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  color       String? // Hex color for category badge
  order_index Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  // Relations
  posts BlogPost[]

  @@index([slug])
  @@index([is_active])
}

model BlogPost {
  id             String  @id @default(uuid())
  category_id    String
  title          String
  slug           String  @unique
  content        String  @db.Text
  excerpt        String?
  featured_image String? // URL to featured image

  // SEO
  meta_title       String?
  meta_description String?
  keywords         String[] @default([])

  // Author
  author_name  String
  author_email String?
  author_bio   String?

  // Metadata
  views        Int  @default(0)
  reading_time Int? // Minutes
  order_index  Int  @default(0)

  // Status
  is_published Boolean @default(false)
  is_featured  Boolean @default(false)

  // Dates
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())
  published_at DateTime?

  // Relations
  category BlogCategory  @relation(fields: [category_id], references: [id], onDelete: Cascade)
  tags     BlogPostTag[]
  comments BlogComment[]

  @@index([category_id])
  @@index([slug])
  @@index([is_published])
  @@index([published_at])
}

model BlogTag {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  created_at DateTime @default(now())

  // Relations
  posts BlogPostTag[]

  @@index([slug])
}

model BlogPostTag {
  post_id String
  tag_id  String

  post BlogPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([post_id, tag_id])
}

model BlogComment {
  id           String   @id @default(uuid())
  post_id      String
  author_name  String
  author_email String
  content      String   @db.Text
  is_approved  Boolean  @default(false)
  created_at   DateTime @default(now())

  // Relations
  post BlogPost @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@index([post_id])
  @@index([is_approved])
}

// ============================================================================
// SUBSCRIPTION & BILLING (STRIPE INTEGRATED)
// ============================================================================

model subscriptions {
  id        Int @id @default(autoincrement())
  tenant_id Int

  // Tier-based access control
  tier         SubscriptionTier @default(FREE)
  max_schools  Int?
  max_users    Int?
  max_students Int?

  // Legacy fields (backward compatibility)
  plan_type      String
  payment_status String
  amount_paid    Decimal

  // Dates
  start_date DateTime
  end_date   DateTime
  is_active  Boolean  @default(true)

  // Stripe integration
  stripe_customer_id     String? @unique
  stripe_subscription_id String? @unique
  stripe_price_id        String?

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  tenants       tenants         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  feature_usage feature_usage[] @relation("SubscriptionFeatureUsage")

  @@index([tenant_id])
  @@index([tier])
  @@index([is_active])
  @@index([stripe_customer_id])
}

// ============================================================================
// MISSING MODELS RESTORED
// ============================================================================

model feature_usage {
  id              Int              @id @default(autoincrement())
  subscription_id Int
  tenant_id       Int
  feature         Feature
  tier            SubscriptionTier
  duration        Int?
  metadata        Json?
  timestamp       DateTime         @default(now())

  // Relations
  subscription subscriptions @relation("SubscriptionFeatureUsage", fields: [subscription_id], references: [id], onDelete: Cascade)
  tenant       tenants       @relation("TenantFeatureUsage", fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([subscription_id])
  @@index([tenant_id])
  @@index([feature])
  @@index([timestamp])
}

model ParentTeacherMessage {
  id         String    @id @default(uuid())
  tenantId   Int
  senderId   Int
  receiverId Int
  content    String
  subject    String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now())

  tenant    tenants   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sender    users     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver  users     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  studentId Int?
  student   students? @relation(fields: [studentId], references: [id])

  @@index([tenantId])
  @@index([senderId])
  @@index([receiverId])
}

model Institution {
  id                 String    @id @default(uuid())
  name               String
  type               String
  size               String
  address            String?
  city               String?
  region             String?
  postcode           String?
  country            String?
  phone              String?
  email              String
  website            String?
  logoUrl            String?
  notes              String?   @db.Text
  tags               String[]  @default([])
  customFields       Json?
  verificationStatus String    @default("PENDING")
  verifiedAt         DateTime?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now())
  createdBy          String?

  contacts      InstitutionContact[]
  departments   Department[]
  subscriptions InstitutionSubscription[]
  admins        InstitutionAdmin[]

  @@index([name])
  @@index([type])
  @@index([verificationStatus])
  @@index([isActive])
  @@index([email])
}

model InstitutionContact {
  id               String   @id @default(uuid())
  institutionId    String
  firstName        String
  lastName         String
  email            String
  phone            String?
  role             String?
  isPrimaryContact Boolean  @default(false)
  jobTitle         String?
  notes            String?  @db.Text
  departmentId     String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([institutionId])
  @@index([email])
  @@index([isPrimaryContact])
  @@index([departmentId])
}

model Department {
  id                 String   @id @default(uuid())
  institutionId      String
  name               String
  description        String?  @db.Text
  type               String
  parentDepartmentId String?
  headOfDepartmentId String?
  status             String   @default("ACTIVE")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now())
  createdBy          String

  institution      Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  parentDepartment Department?          @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments Department[]         @relation("DepartmentHierarchy")
  contacts         InstitutionContact[]
  users            DepartmentMember[]
  managers         DepartmentManager[]

  @@index([institutionId])
  @@index([name])
  @@index([type])
  @@index([status])
  @@index([parentDepartmentId])
  @@index([headOfDepartmentId])
}

// Join table for Department members
model DepartmentMember {
  id           String   @id @default(uuid())
  departmentId String
  userId       Int
  role         String?
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       users      @relation("DepartmentMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

// Join table for Department managers
model DepartmentManager {
  id           String   @id @default(uuid())
  departmentId String
  userId       Int
  assignedAt   DateTime @default(now())
  assignedBy   String?
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
