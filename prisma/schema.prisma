  @@index([periodStart])
  @@index([generatedAt])
  @@map("time_savings_reports")
}

// ============================================================================
// DEVELOPERS OF TOMORROW - CODING CURRICULUM (Zero Gap Project)
// Complete coding curriculum supporting visual, block-based, and text-based
// programming from Reception through Year 11, aligned with UK Computing curriculum.
// ============================================================================

enum CodingLanguage {
  SCRATCH_JR     // Ages 4-7, visual drag-drop
  SCRATCH        // Ages 7-11, block-based
  PYTHON         // Ages 9+, text-based beginner
  JAVASCRIPT     // Ages 10+, web development
  HTML_CSS       // Ages 8+, web structure/styling
  SQL            // Ages 12+, database queries
  MICRO_BIT      // Ages 8+, physical computing
  ARDUINO        // Ages 11+, electronics
}

enum CodingDifficulty {
  FOUNDATION     // Pre-readers, purely visual
  EMERGING       // Early readers, supported text
  DEVELOPING     // Confident readers
  SECURE         // Independent coders
  ADVANCED       // Extension and challenge
}

enum CodingSkillArea {
  ALGORITHMS
  PROGRAMMING
  DATA_STRUCTURES
  DEBUGGING
  DECOMPOSITION
  ABSTRACTION
  PATTERN_RECOGNITION
  LOGICAL_REASONING
  EVALUATION
  COLLABORATION
}

model NCCurriculum {
  id              String   @id @default(cuid())
  tenant_id       Int
  
  // Curriculum Details
  name            String
  description     String   @db.Text
  
  // Target Audience
  key_stage       String   // EYFS, KS1, KS2, KS3, KS4
  year_groups     String[] // ["Reception", "Year 1"] etc.
  age_range_min   Int
  age_range_max   Int
  
  // UK Computing NC Alignment
  nc_objectives   String[] // National Curriculum objective codes
  
  // Progression
  prerequisite_id String?
  
  // Status
  status          String   @default("draft") // draft, published, archived
  published_at    DateTime?
  
  // Metadata
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())
  created_by_id   Int?
  
  // Relations
  tenant          tenants  @relation("TenantCodingCurricula", fields: [tenant_id], references: [id])
  created_by      users?   @relation("CodingCurriculumCreator", fields: [created_by_id], references: [id])
  lessons         NCLesson[]
  prerequisite    NCCurriculum? @relation("CurriculumPrerequisite", fields: [prerequisite_id], references: [id])
  dependents      NCCurriculum[] @relation("CurriculumPrerequisite")
  
  @@index([tenant_id])
  @@index([key_stage])
}

model NCLesson {
  id              String   @id @default(cuid())
  curriculum_id   String
  tenant_id       Int
  
  // Lesson Details
  title           String
  description     String   @db.Text
  learning_objectives String[] // Specific learning outcomes
  
  // Content
  lesson_number   Int      // Order within curriculum
  duration_minutes Int     @default(45)
  
  // Language and Approach
  language        CodingLanguage
  skill_areas     CodingSkillArea[]
  
  // Differentiation
  base_difficulty CodingDifficulty
  
  // Resources
  teacher_notes   String?  @db.Text
  resources_urls  String[] // Links to starter files, worksheets
  video_url       String?  // Demo video
  
  // Status
  status          String   @default("draft")
  
  // Metadata
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())
  created_by_id   Int?
  
  // Relations
  curriculum      NCCurriculum @relation(fields: [curriculum_id], references: [id], onDelete: Cascade)
  tenant          tenants  @relation("TenantCodingLessons", fields: [tenant_id], references: [id])
  created_by      users?   @relation("CodingLessonCreator", fields: [created_by_id], references: [id])
  exercises       NCExercise[]
  personalizations LessonPersonalization[]
  
  @@index([curriculum_id])
  @@index([tenant_id])
}

model NCExercise {
  id              String   @id @default(cuid())
  lesson_id       String
  tenant_id       Int
  
  // Exercise Details
  title           String
  instructions    String   @db.Text
  exercise_number Int      // Order within lesson
  
  // Type
  exercise_type   String   // guided, independent, challenge, debugging, peer_review
  difficulty      CodingDifficulty
  
  // Code Content
  starter_code    String?  @db.Text
  solution_code   String?  @db.Text
  test_cases      Json?    // [{input: "", expected_output: ""}]
  
  // Hints (graduated support)
  hints           String[] // Progressive hints
  
  // Points and assessments
  max_points      Int      @default(10)
  
  // Accessibility Adaptations Available
  has_audio_instructions    Boolean @default(false)
  has_visual_supports       Boolean @default(false)
  has_simplified_version    Boolean @default(false)
  
  // Metadata
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())
  created_by_id   Int?
  
  // Relations
  lesson          NCLesson @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  tenant          tenants  @relation("TenantCodingExercises", fields: [tenant_id], references: [id])
  created_by      users?   @relation("CodingExerciseCreator", fields: [created_by_id], references: [id])
  submissions     NCSubmission[]
  
  @@index([lesson_id])
  @@index([tenant_id])
}

model NCSubmission {
  id              String   @id @default(cuid())
  exercise_id     String
  student_id      Int
  tenant_id       Int
  
  // Submission Content
  submitted_code  String   @db.Text
  
  // Auto-grading Results
  test_results    Json?    // [{test_case: 1, passed: true, output: ""}]
  tests_passed    Int      @default(0)
  tests_total     Int      @default(0)
  auto_score      Float?
  
  // Teacher Grading
  teacher_score   Float?
  teacher_feedback String? @db.Text
  graded_by_id    Int?
  graded_at       DateTime?
  
  // Final Score
  final_score     Float?
  
  // Attempt Tracking
  attempt_number  Int      @default(1)
  
  // Timing
  time_spent_seconds Int?
  
  // Metadata
  submitted_at    DateTime @default(now())
  
  // Relations
  exercise        NCExercise @relation(fields: [exercise_id], references: [id], onDelete: Cascade)
  student         students @relation("CodingStudentSubmissions", fields: [student_id], references: [id])
  graded_by       users?   @relation("CodingSubmissionGrader", fields: [graded_by_id], references: [id])
  
  @@index([exercise_id])
  @@index([student_id])
  @@index([submitted_at])
}

model NCProgress {
  id              String   @id @default(cuid())
  student_id      Int
  tenant_id       Int
  
  // Overall Progress
  total_lessons_completed Int @default(0)
  total_exercises_completed Int @default(0)
  total_points_earned Int @default(0)
  
  // Current Level
  current_language CodingLanguage?
  current_difficulty CodingDifficulty @default(FOUNDATION)
  
  // Skill Mastery (0-100 for each area)
  algorithms_mastery      Int @default(0)
  programming_mastery     Int @default(0)
  data_structures_mastery Int @default(0)
  debugging_mastery       Int @default(0)
  decomposition_mastery   Int @default(0)
  
  // Badges Earned
  badges_earned   String[] // ["first_program", "bug_squasher", "algorithm_ace"]
  
  // Streak
  current_streak_days Int @default(0)
  longest_streak_days Int @default(0)
  last_activity_date  DateTime?
  
  // Metadata
  updated_at      DateTime @default(now())
  
  // Relations
  student         students @relation(fields: [student_id], references: [id], onDelete: Cascade)
  
  @@unique([student_id])
  @@index([student_id])
}

// ============================================================================
// LESSON PERSONALISATION ENGINE (Zero Gap Project)
// Supporting "30+ personalized versions" claim through adaptive content delivery
// ============================================================================

model LessonPersonalization {
  id              String   @id @default(cuid())
  lesson_id       String
  tenant_id       Int
  
  // Personalization Dimension
  dimension       String   // difficulty, learning_style, pace, support_level, language_complexity
  variant_name    String   // e.g., "Visual Learner - Foundation"
  
  // Content Modifications
  modified_instructions String? @db.Text
  modified_content      Json?   // Structured content changes
  
  // Visual Adaptations
  font_family     String?  // OpenDyslexic, Lexie, default
  font_size_increase Float? // 1.0 = normal, 1.5 = 50% larger
  line_spacing    Float?   // 1.0 = normal, 2.0 = double
  color_scheme    String?  // high_contrast, dyslexia_friendly, default
  
  // Audio Support
  has_text_to_speech Boolean @default(false)
  tts_voice       String?  // UK English voice ID
  tts_speed       Float?   // 0.5 = slow, 1.0 = normal, 2.0 = fast
  
  // Scaffolding
  extra_hints     String[]
  worked_examples String[] // Additional step-by-step examples
  sentence_starters String[]
  visual_aids_urls String[]
  
  // Timing
  extended_time_multiplier Float @default(1.0) // 1.5 = 50% extra time
  break_reminders Boolean @default(false)
  break_interval_minutes Int?
  
  // Complexity Adjustments
  simplified_vocabulary Boolean @default(false)
  reduced_question_count Boolean @default(false)
  chunked_content Boolean @default(false)
  
  // Metadata
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())
  created_by_id   Int?
  
  // Relations
  lesson          NCLesson @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  tenant          tenants  @relation("TenantLessonPersonalizations", fields: [tenant_id], references: [id])
  created_by      users?   @relation("LessonPersonalizationCreator", fields: [created_by_id], references: [id])
  
  @@unique([lesson_id, dimension, variant_name])
  @@index([lesson_id])
  @@index([tenant_id])
}

model StudentAdaptiveProfile {
  id              String   @id @default(cuid())
  student_id      Int      @unique
  tenant_id       Int
  
  // Learning Style Indicators (0-100)
  visual_preference       Int @default(50)
  auditory_preference     Int @default(50)
  kinesthetic_preference  Int @default(50)
  reading_preference      Int @default(50)
  
  // Cognitive Profile
  processing_speed       String @default("average") // slow, average, fast
  working_memory         String @default("average") // low, average, high
  attention_span_minutes Int    @default(20)
  
  // SEND Accommodations
  dyslexia_support       Boolean @default(false)
  dyscalculia_support    Boolean @default(false)
  adhd_support           Boolean @default(false)
  asd_support            Boolean @default(false)
  visual_impairment      Boolean @default(false)
  hearing_impairment     Boolean @default(false)
  
  // Preferred Settings
  preferred_font         String?
  preferred_font_size    Float   @default(1.0)
  preferred_color_scheme String?
  preferred_tts_voice    String?
  preferred_tts_speed    Float   @default(1.0)
  
  // Engagement Patterns
  best_time_of_day      String? // morning, afternoon, evening
  optimal_session_length Int?   // minutes
  prefers_breaks        Boolean @default(false)
  
  // Performance History
  average_score         Float   @default(0)
  completion_rate       Float   @default(0)
  struggle_areas        String[] // Areas needing extra support
  strength_areas        String[] // Areas of proficiency
  
  // Last assessments
  last_profile_update   DateTime @default(now())
  profile_confidence    Float   @default(0) // 0-1, how confident are we in this profile
  
  // Relations
  student               students @relation(fields: [student_id], references: [id], onDelete: Cascade)
  learning_adaptations  StudentLearningAdaptation[]
  
  @@index([student_id])
}

model StudentLearningAdaptation {
  id              String   @id @default(cuid())
  student_id      Int
  profile_id      String
  
  // What was adapted
  content_type    String   // lesson, exercise, assessment
  content_id      String
  
  // Adaptation Applied
  personalization_dimension String
  personalization_variant   String
  
  // Outcome
  engagement_score Float?  // 0-100, based on time on task, completion
  performance_score Float? // 0-100, based on correctness
  
  // Feedback
  student_rating  Int?     // 1-5 stars
  helpful         Boolean?
  
  // Metadata
  applied_at      DateTime @default(now())
  
  // Relations
  student         students @relation(fields: [student_id], references: [id], onDelete: Cascade)
  profile         StudentAdaptiveProfile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  
  @@index([student_id])
  @@index([profile_id])
  @@index([content_type, content_id])
}

// ============================================================================
// SEN2 CHILD RECORDS (Zero Gap Project)
