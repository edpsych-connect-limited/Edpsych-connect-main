// ============================================================================
// EHCP & SEND SUPPORT (TENANT-SCOPED) - ENTERPRISE LA SYSTEM
// ============================================================================
// UK SEND Code of Practice 2015 compliant
// Full statutory 20-week timeline management
// Multi-agency professional contribution workflow
// LA-centric dashboard with compliance monitoring
// ============================================================================

// Application Status Enum - Full statutory journey
enum EHCPApplicationStatus {
  // Initial Stage (Weeks 0-6)
  SUBMITTED                     // School/Parent submitted request
  EVIDENCE_GATHERING            // LA gathering initial evidence
  PANEL_REVIEW_PENDING          // Awaiting LA SEND Panel review
  
  // Decision Stage (Week 6 deadline)
  DECISION_TO_ASSESS            // LA agreed to statutory assessment
  DECISION_NOT_TO_ASSESS        // LA declined - not meeting threshold
  
  // assessments Stage (Weeks 6-16)
  PROFESSIONAL_REFERRALS_SENT   // Advice requests sent to professionals
  AWAITING_EP_ASSESSMENT        // Waiting for Educational Psychologist
  AWAITING_HEALTH_ASSESSMENT    // Waiting for Health professional
  AWAITING_SOCIAL_CARE          // Waiting for Social Care
  AWAITING_SCHOOL_ADVICE        // Waiting for School/Setting
  ALL_ADVICE_RECEIVED           // All professional contributions in
  
  // Drafting Stage (Week 16 deadline)
  DRAFT_IN_PROGRESS             // LA drafting EHCP document
  DRAFT_QUALITY_CHECK           // Internal QA review
  DRAFT_READY                   // Draft completed
  
  // Consultation Stage (Weeks 16-20)
  CONSULTATION_PARENT_SENT      // Sent to parent (15 calendar days minimum)
  CONSULTATION_SCHOOL_SENT      // Sent to proposed school
  CONSULTATION_FEEDBACK_RECEIVED // Responses received
  AMENDMENTS_IN_PROGRESS        // Making requested changes
  
  // Final Stage (Week 20 deadline)
  FINAL_REVIEW                  // Final checks before issue
  FINAL_EHCP_ISSUED             // Complete - plan issued
  
  // Exception Pathways
  MEDIATION_REQUESTED           // Parent requested mediation
  TRIBUNAL_LODGED               // Appeal to SEND Tribunal
  TRANSFERRED_IN                // Transfer from another LA (8 week timeline)
  CEASED                        // EHCP ceased
  ANNUAL_REVIEW_DUE             // Active plan - review approaching
}

// Urgency levels for prioritisation
enum EHCPUrgency {
  STANDARD                      // Normal 20-week process
  URGENT_SAFEGUARDING           // Safeguarding concerns - expedite
  URGENT_TRIBUNAL_DEADLINE      // Tribunal deadline approaching
  URGENT_SCHOOL_PLACEMENT       // Placement breakdown
  EMERGENCY_TRANSFER            // Emergency school transfer
}

// Primary Need Categories (DfE SEN2 Categories)
enum SENPrimaryNeed {
  SPLD                          // Specific Learning Difficulty
  MLD                           // Moderate Learning Difficulty
  SLD                           // Severe Learning Difficulty
  PMLD                          // Profound and Multiple Learning Difficulty
  SEMH                          // Social, Emotional and Mental Health
  SLCN                          // Speech, Language and Communication Needs
  HI                            // Hearing Impairment
  VI                            // Visual Impairment
  MSI                           // Multi-Sensory Impairment
  PD                            // Physical Disability
  ASD                           // Autism Spectrum Disorder
  OTH                           // Other Difficulty/Disability
}

// ============================================================================
// CORE EHCP APPLICATION MODEL - The Statutory Journey Tracker
// ============================================================================

model EHCPApplication {
  id                    String               @id @default(cuid())
  
  // Reference Numbers
  la_reference          String               @unique // LA's internal reference (e.g., "LA-2025-00123")
  dfe_reference         String?              // DfE unique identifier if applicable
  
  // Tenant Hierarchy
  la_tenant_id          Int                  // Local Authority tenant
  school_tenant_id      Int                  // Originating school/setting tenant
  
  // Child/Young Person Details
  student_id            String               // Link to student record
  child_name            String               // For quick reference
  child_dob             DateTime             // Date of birth
  child_upn             String?              // Unique Pupil Number
  nhs_number            String?              // NHS number (for health liaison)
  
  // Primary Need
  primary_need          SENPrimaryNeed
  secondary_needs       SENPrimaryNeed[]     @default([])
  
  // Request Details
  request_type          String               @default("initial") // initial, transfer_in, reassessment
  requested_by          String               // "parent", "school", "other_professional"
  requester_name        String
  requester_email       String
  requester_phone       String?
  request_reason        String               @db.Text
  
  // ============================================================================
  // STATUTORY TIMELINE (SEND Code of Practice 2015)
  // ============================================================================
  
  // Key Dates - Auto-calculated from referral_date
  referral_date         DateTime             @default(now())
  decision_due_date     DateTime             // Week 6: 42 days from referral
  draft_due_date        DateTime             // Week 16: 112 days from referral
  final_due_date        DateTime             // Week 20: 140 days from referral
  
  // Actual Completion Dates
  decision_actual_date  DateTime?
  draft_actual_date     DateTime?
  final_actual_date     DateTime?
  
  // Timeline Status
  status                EHCPApplicationStatus @default(SUBMITTED)
  urgency               EHCPUrgency          @default(STANDARD)
  current_week          Int                  @default(0)
  is_overdue            Boolean              @default(false)
  days_overdue          Int                  @default(0)
  
  // Decision to Assess
  decision_to_assess    Boolean?             // null = pending, true = yes, false = no
  decision_reason       String?              @db.Text
  decision_made_by_id   Int?
  
  // ============================================================================
  // ASSIGNED PROFESSIONALS (Multi-Agency)
  // ============================================================================
  
  caseworker_id         Int                  // LA SEND Caseworker (primary owner)
  assigned_ep_id        Int?                 // Educational Psychologist
  assigned_health_id    Int?                 // Health Professional (NHS)
  assigned_social_id    Int?                 // Social Worker
  panel_chair_id        Int?                 // SEND Panel Chair
  
  // ============================================================================
  // PROFESSIONAL CONTRIBUTIONS (Sections B-K)
  // ============================================================================
  
  // School Contribution (Section A + supporting evidence)
  school_contribution_id      String?        @unique
  school_contribution_status  String         @default("pending") // pending, in_progress, submitted, accepted
  school_contribution_due     DateTime?
  school_submitted_at         DateTime?
  
  // EP Contribution (Sections B, E, F primarily)
  ep_contribution_id          String?        @unique
  ep_contribution_status      String         @default("pending")
  ep_contribution_due         DateTime?
  ep_submitted_at             DateTime?
  
  // Health Contribution (Sections C, G)
  health_contribution_id      String?        @unique
  health_contribution_status  String         @default("pending")
  health_contribution_due     DateTime?
  health_submitted_at         DateTime?
  
  // Social Care Contribution (Sections D, H)
  social_contribution_id      String?        @unique
  social_contribution_status  String         @default("pending")
  social_contribution_due     DateTime?
  social_submitted_at         DateTime?
  
  // Other Professional Contributions (optional)
  other_contributions         Json?          // Array of {type, contributor, status, content}
  
  // ============================================================================
  // FINAL EHCP OUTPUT
  // ============================================================================
  
  // Draft EHCP
  draft_ehcp_id         String?
  draft_created_at      DateTime?
  draft_sent_to_parent  DateTime?
  
  // Consultation Responses
  parent_response       Json?                // {agreed: bool, comments: string, date: datetime}
  school_response       Json?                // {can_meet_needs: bool, comments: string}
  
  // Final EHCP
  final_ehcp_id         String?              // Links to ehcps table
  final_issued_at       DateTime?
  named_school_urn      String?              // DfE school URN
  named_school_name     String?
  placement_type        String?              // mainstream, special, independent, resourced
  
  // ============================================================================
  // EXCEPTIONS & EXTENSIONS
  // ============================================================================
  
  has_exception         Boolean              @default(false)
  exception_type        String?              // mediation, tribunal, transfer, other
  exception_reason      String?              @db.Text
  extension_weeks       Int                  @default(0)
  extension_approved_by Int?
  extension_approved_at DateTime?
  
  // ============================================================================
  // AUDIT & COMPLIANCE
  // ============================================================================
  
  // Compliance Flags
  statutory_compliant   Boolean              @default(true)
  breach_type           String?              // decision_breach, draft_breach, final_breach
  breach_reported_at    DateTime?
  breach_reason         String?              @db.Text
  
  // Audit Trail
  created_at            DateTime             @default(now())
  updated_at            DateTime             @default(now())
  created_by_id         Int
  last_updated_by_id    Int?
  
  // ============================================================================
  // RELATIONS
  // ============================================================================
  
  la_tenant             tenants              @relation("LAApplications", fields: [la_tenant_id], references: [id])
  school_tenant         tenants              @relation("SchoolApplications", fields: [school_tenant_id], references: [id])
  caseworker            users                @relation("CaseworkerApplications", fields: [caseworker_id], references: [id])
  assigned_ep           users?               @relation("EPApplications", fields: [assigned_ep_id], references: [id])
  assigned_health       users?               @relation("HealthApplications", fields: [assigned_health_id], references: [id])
  assigned_social       users?               @relation("SocialApplications", fields: [assigned_social_id], references: [id])
  decision_made_by      users?               @relation("DecisionMaker", fields: [decision_made_by_id], references: [id])
  created_by            users                @relation("ApplicationCreator", fields: [created_by_id], references: [id])
  
  // Child Relations
  contributions         EHCPContribution[]
  timeline_events       EHCPTimelineEvent[]
  communications        EHCPCommunication[]
  documents             EHCPDocument[]
  panel_decisions       EHCPPanelDecision[]
  
  @@index([la_tenant_id, status])
  @@index([school_tenant_id])
  @@index([student_id])
  @@index([referral_date])
  @@index([status])
  @@index([caseworker_id])
  @@index([is_overdue])
  @@index([la_reference])
}

// ============================================================================
// PROFESSIONAL CONTRIBUTIONS - Multi-Agency Section Submissions
// ============================================================================

model EHCPContribution {
  id                    String               @id @default(cuid())
  application_id        String
  
  // Contributor Details
  contributor_type      String               // school, ep, health, social_care, other
  contributor_id        Int                  // users ID
  contributor_name      String
  contributor_role      String               // e.g., "SENCO", "Educational Psychologist", "Paediatrician"
  contributor_org       String               // e.g., "Oakwood Primary School", "NHS Trust"
  
  // Contribution Content
  section_type          String               // A, B, C, D, E, F, G, H, I, J, K
  content               Json                 // Structured content per section
  
  // Supporting Evidence
  evidence_summary      String?              @db.Text
  assessment_date       DateTime?            // Date of assessment (if applicable)
  
  // Status
  status                String               @default("draft") // draft, submitted, revision_requested, accepted, rejected
  revision_notes        String?              @db.Text
  
  // Quality Assurance
  qa_reviewed           Boolean              @default(false)
  qa_reviewed_by_id     Int?
  qa_reviewed_at        DateTime?
  qa_score              Int?                 // 1-5 quality score
  qa_feedback           String?              @db.Text
  
  // Timestamps
  requested_at          DateTime             @default(now())
  due_date              DateTime
  submitted_at          DateTime?
  accepted_at           DateTime?
  
  // Relations
  application           EHCPApplication      @relation(fields: [application_id], references: [id], onDelete: Cascade)
  contributor           users                @relation("Contributor", fields: [contributor_id], references: [id])
  qa_reviewer           users?               @relation("QAReviewer", fields: [qa_reviewed_by_id], references: [id])
  
  @@index([application_id])
  @@index([contributor_id])
  @@index([status])
  @@index([due_date])
}

// ============================================================================
// TIMELINE EVENTS - Comprehensive Audit Trail
// ============================================================================

model EHCPTimelineEvent {
  id                    String               @id @default(cuid())
  application_id        String
  
  // Event Details
  event_type            String               // status_change, document_uploaded, professional_assigned, etc.
  event_category        String               // administrative, assessment, consultation, decision, compliance
  event_description     String
  
  // Actor
  triggered_by_id       Int?
  triggered_by_system   Boolean              @default(false)
  
  // Status Change Details (if applicable)
  previous_status       String?
  new_status            String?
  
  // Additional Data
  metadata              Json?                // Any additional event-specific data
  
  // Timestamp
  occurred_at           DateTime             @default(now())
  
  // Relations
  application           EHCPApplication      @relation(fields: [application_id], references: [id], onDelete: Cascade)
  triggered_by          users?               @relation("TimelineActor", fields: [triggered_by_id], references: [id])
  
  @@index([application_id])
  @@index([occurred_at])
  @@index([event_type])
}

// ============================================================================
// INTER-AGENCY COMMUNICATIONS - Secure Messaging
// ============================================================================

model EHCPCommunication {
  id                    String               @id @default(cuid())
  application_id        String
  
  // Message Details
  message_type          String               // internal_note, parent_communication, professional_request, escalation
  subject               String
  body                  String               @db.Text
  
  // Sender/Recipients
  sender_id             Int
  recipient_ids         Int[]                @default([])
  recipient_external    String?              // For external communications (email)
  
  // Status
  is_read               Boolean              @default(false)
  read_at               DateTime?
  requires_response     Boolean              @default(false)
  response_due          DateTime?
  
  // Threading
  parent_message_id     String?
  
  // Timestamps
  sent_at               DateTime             @default(now())
  
  // Relations
  application           EHCPApplication      @relation(fields: [application_id], references: [id], onDelete: Cascade)
  sender                users                @relation("MessageSender", fields: [sender_id], references: [id])
  parent_message        EHCPCommunication?   @relation("MessageThread", fields: [parent_message_id], references: [id])
  child_messages        EHCPCommunication[]  @relation("MessageThread")
  
  @@index([application_id])
  @@index([sender_id])
  @@index([sent_at])
}

// ============================================================================
// DOCUMENTS - Evidence & Attachments
// ============================================================================

model EHCPDocument {
  id                    String               @id @default(cuid())
  application_id        String
  
  // Document Details
  document_type         String               // assessment_report, school_evidence, health_report, draft_ehcp, final_ehcp, correspondence
  title                 String
  description           String?
  
  // File Storage
  file_name             String
  file_type             String               // pdf, docx, etc.
  file_size             Int                  // bytes
  file_url              String
  
  // Source
  uploaded_by_id        Int
  source_type           String               // school, la, ep, health, social_care, parent
  
  // Versioning
  version               Int                  @default(1)
  previous_version_id   String?
  is_current            Boolean              @default(true)
  
  // Sensitivity
  is_confidential       Boolean              @default(false)
  access_restricted_to  String[]             @default([]) // Role types that can view
  
  // Timestamps
  uploaded_at           DateTime             @default(now())
  
  // Relations
  application           EHCPApplication      @relation(fields: [application_id], references: [id], onDelete: Cascade)
  uploaded_by           users                @relation("DocumentUploader", fields: [uploaded_by_id], references: [id])
  
  @@index([application_id])
  @@index([document_type])
  @@index([uploaded_at])
}

// ============================================================================
// PANEL DECISIONS - LA SEND Panel Records
// ============================================================================

model EHCPPanelDecision {
  id                    String               @id @default(cuid())
  application_id        String
  
  // Panel Details
  panel_date            DateTime
  panel_type            String               // initial_decision, placement, annual_review, amendment
  
  // Attendees
  chair_id              Int
  panel_members         Json                 // Array of {id, name, role}
  
  // Decision
  decision              String               // agree_to_assess, decline_to_assess, issue_plan, etc.
  decision_rationale    String               @db.Text
  conditions            String?              @db.Text // Any conditions attached to decision
  
  // Voting (for transparency)
  votes_for             Int                  @default(0)
  votes_against         Int                  @default(0)
  votes_abstain         Int                  @default(0)
  
  // Documentation
  minutes_url           String?
  
  // Timestamps
  recorded_at           DateTime             @default(now())
  
  // Relations
  application           EHCPApplication      @relation(fields: [application_id], references: [id], onDelete: Cascade)
  chair                 users                @relation("PanelChair", fields: [chair_id], references: [id])
  
  @@index([application_id])
  @@index([panel_date])
}

// ============================================================================
// LA COMPLIANCE METRICS - Aggregated Statistics
// ============================================================================

model LAComplianceMetrics {
  id                    String               @id @default(cuid())
  la_tenant_id          Int
  
  // Period
  period_start          DateTime
  period_end            DateTime
  period_type           String               // monthly, quarterly, annual
  
  // Volume Metrics
  total_applications    Int                  @default(0)
  new_applications      Int                  @default(0)
  completed_applications Int                 @default(0)
  
  // Timeline Compliance
  decisions_on_time     Int                  @default(0)
  decisions_late        Int                  @default(0)
  decision_compliance_rate Float             @default(0)
  
  drafts_on_time        Int                  @default(0)
  drafts_late           Int                  @default(0)
  draft_compliance_rate Float                @default(0)
  
  finals_on_time        Int                  @default(0)
  finals_late           Int                  @default(0)
  final_compliance_rate Float                @default(0)
  
  // Overall
  overall_compliance_rate Float              @default(0)
  
  // Average Processing Times (days)
  avg_decision_time     Float                @default(0)
  avg_draft_time        Float                @default(0)
  avg_total_time        Float                @default(0)
  
  // Exception Metrics
  mediations_requested  Int                  @default(0)
  tribunals_lodged      Int                  @default(0)
  tribunal_success_rate Float                @default(0)
  
  // Need Distribution (for planning)
  need_distribution     Json?                // {ASD: 45, SEMH: 30, SLCN: 25, ...}
  
  // Calculated at
  calculated_at         DateTime             @default(now())
  
  // Relations
  la_tenant             tenants              @relation("LAMetrics", fields: [la_tenant_id], references: [id])
  
  @@unique([la_tenant_id, period_start, period_type])
  @@index([la_tenant_id])
  @@index([period_start])
}

// ============================================================================
// NOTIFICATION TEMPLATES - Automated Communications
// ============================================================================

model EHCPNotificationTemplate {
  id                    String               @id @default(cuid())
  la_tenant_id          Int?                 // null = system default
  
  // Template Details
  template_code         String               @unique // e.g., "DECISION_REMINDER_7_DAYS"
  template_name         String
  trigger_event         String               // status_change, deadline_approaching, etc.
  
  // Content
  subject_template      String
  body_template         String               @db.Text // Supports {{placeholders}}
  
  // Delivery
  delivery_channels     String[]             @default(["email"]) // email, sms, in_app
  
  // Timing (for automated triggers)
  days_before_deadline  Int?                 // For reminder notifications
  
  // Status
  is_active             Boolean              @default(true)
  
  // Timestamps
  created_at            DateTime             @default(now())
  updated_at            DateTime             @default(now())
  
  // Relations
  la_tenant             tenants?             @relation("LANotificationTemplates", fields: [la_tenant_id], references: [id])
  
  @@index([la_tenant_id])
  @@index([trigger_event])
}

// ============================================================================
// MEDIATION & TRIBUNAL TRACKING
// ============================================================================

model MediationCase {
  id                    String               @id @default(cuid())
  la_tenant_id          Int
  ehcp_application_id   String?
  
  // Case Details
  case_reference        String               @unique
  child_name            String
  parent_guardian_name  String
  parent_email          String?
  parent_phone          String?
  
  // Mediation Type
  mediation_type        String               // ehcp_decision, ehcp_content, provision, placement
  requested_by          String               // parent, advocate, solicitor
  
  // Key Dates
  request_date          DateTime
  certificate_due_date  DateTime?            // 30 days from request
  certificate_issued    DateTime?
  mediation_date        DateTime?
  
  // Status
  status                String               @default("requested") // requested, certificate_issued, scheduled, completed, withdrawn, escalated_to_tribunal
  outcome               String?              // resolved, unresolved, partial_agreement, withdrawn
  resolution_summary    String?              @db.Text
  
  // Mediator Details
  mediation_service     String?
  mediator_name         String?
  
  // Agreement Details (if resolved)
  agreements            Json?                // Array of agreed changes
  implementation_deadline DateTime?
  implementation_status String?              @default("pending") // pending, in_progress, completed
  
  // LA Case Officer
  case_officer_id       Int?
  
  // Costs
  mediation_cost        Float?
  
  // Timestamps
  created_at            DateTime             @default(now())
  updated_at            DateTime             @default(now())
  
  // Relations
  la_tenant             tenants              @relation("LAMediationCases", fields: [la_tenant_id], references: [id])
  case_officer          users?               @relation("MediationCaseOfficer", fields: [case_officer_id], references: [id])
  tribunal_case         TribunalCase?        @relation("MediationToTribunal")
  
  @@index([la_tenant_id])
  @@index([status])
  @@index([request_date])
}

model TribunalCase {
  id                    String               @id @default(cuid())
  la_tenant_id          Int
  mediation_case_id     String?              @unique
  ehcp_application_id   String?
  
  // Case Details
  tribunal_reference    String               @unique
  sendist_reference     String?              // SEND Tribunal reference
  child_name            String
  
  // Appeal Type
  appeal_type           String               // refusal_to_assess, refusal_to_issue, ehcp_content, placement, ceasing
  grounds_for_appeal    String               @db.Text
  
  // Key Dates (SEND Tribunal timeline)
  registration_date     DateTime
  response_due_date     DateTime             // 30 days from registration
  response_submitted    DateTime?
  
  // Working Document
  working_document_due  DateTime?
  working_document_sent DateTime?
  
  // Hearing
  hearing_date          DateTime?
  hearing_location      String?
  hearing_type          String?              // in_person, video, paper
  
  // Decision
  decision_date         DateTime?
  decision_outcome      String?              // upheld, partially_upheld, dismissed
  decision_summary      String?              @db.Text
  
  // Implementation
  ordered_changes       Json?                // Required changes from tribunal
  implementation_deadline DateTime?
  implementation_status String?
  
  // Status
  status                String               @default("registered") // registered, response_submitted, hearing_scheduled, decision_pending, closed
  
  // Legal Representation
  la_legal_rep          String?
  parent_legal_rep      String?
  
  // Costs
  legal_costs           Float?
  tribunal_costs        Float?
  total_costs           Float?
  
  // LA Team
  lead_officer_id       Int?
  
  // Timestamps
  created_at            DateTime             @default(now())
  updated_at            DateTime             @default(now())
  
  // Relations
  la_tenant             tenants              @relation("LATribunalCases", fields: [la_tenant_id], references: [id])
  mediation_case        MediationCase?       @relation("MediationToTribunal", fields: [mediation_case_id], references: [id])
  lead_officer          users?               @relation("TribunalLeadOfficer", fields: [lead_officer_id], references: [id])
  documents             TribunalDocument[]
  
  @@index([la_tenant_id])
  @@index([status])
  @@index([hearing_date])
}

model TribunalDocument {
  id                    String               @id @default(cuid())
  tribunal_case_id      String
  
  // Document Details
  document_type         String               // response, working_document, bundle, evidence, decision
  document_name         String
  file_url              String
  file_size             Int?
  
  // Submission
  submitted_by_id       Int?
  submitted_at          DateTime             @default(now())
  
  // Status
  status                String               @default("draft") // draft, submitted, accepted, rejected
  
  // Relations
  tribunal_case         TribunalCase         @relation(fields: [tribunal_case_id], references: [id], onDelete: Cascade)
  submitted_by          users?               @relation("TribunalDocSubmitter", fields: [submitted_by_id], references: [id])
  
  @@index([tribunal_case_id])
}

// ============================================================================
// PHASE TRANSFER WORKFLOW
// ============================================================================

model PhaseTransfer {
  id                    String               @id @default(cuid())
  la_tenant_id          Int
  ehcp_id               String?
  
  // Child Details
  child_id              String
  child_name            String
  date_of_birth         DateTime
  
  // Current Placement
  current_phase         String               // early_years, primary, secondary, post_16, post_19
  current_setting_id    Int?
  current_setting_name  String
  
  // Transfer Details
  target_phase          String
  transfer_year         Int                  // Academic year of transfer
  transfer_date         DateTime             // Expected transfer date
  
  // Key Deadlines
  consultation_start    DateTime             // When consultations should begin
  final_plan_deadline   DateTime             // When amended EHCP must be finalised
  placement_confirmed   DateTime?
  
  // Consultation Status
  consultation_status   String               @default("not_started") // not_started, in_progress, completed
  settings_consulted    Json?                // Array of setting IDs/responses
  
  // Preferred Settings (ranked)
  parent_preferences    Json?                // [{rank: 1, setting_id: x, setting_name: y, reason: z}]
  
  // Proposed Placement
  proposed_setting_id   Int?
  proposed_setting_name String?
  placement_decision_date DateTime?
  placement_agreed      Boolean?
  
  // Plan Amendments
  ehcp_amendments_required Json?             // Changes needed for new phase
  amended_plan_sent     DateTime?
  
  // Status
  status                String               @default("identified") // identified, consultations_sent, consultations_complete, placement_proposed, placement_agreed, plan_amended, transfer_complete
  risk_level            String               @default("standard") // standard, at_risk, high_risk
  
  // Case Officer
  case_officer_id       Int?
  
  // Notes
  notes                 String?              @db.Text
  
  // Timestamps
  created_at            DateTime             @default(now())
  updated_at            DateTime             @default(now())
  
  // Relations
  la_tenant             tenants              @relation("LAPhaseTransfers", fields: [la_tenant_id], references: [id])
  case_officer          users?               @relation("PhaseTransferOfficer", fields: [case_officer_id], references: [id])
  timeline_events       PhaseTransferEvent[]
  
  @@index([la_tenant_id])
  @@index([transfer_year])
  @@index([status])
  @@index([current_setting_id])
}

model PhaseTransferEvent {
  id                    String               @id @default(cuid())
  phase_transfer_id     String
  
  // Event Details
  event_type            String               // consultation_sent, response_received, meeting_scheduled, placement_offered, etc.
  event_date            DateTime
  description           String
  
  // Related Data
  related_setting_id    Int?
  related_document_url  String?
  
  // Recorded By
  recorded_by_id        Int?
  
  // Timestamps
  created_at            DateTime             @default(now())
  
  // Relations
  phase_transfer        PhaseTransfer        @relation(fields: [phase_transfer_id], references: [id], onDelete: Cascade)
  recorded_by           users?               @relation("PhaseTransferEventRecorder", fields: [recorded_by_id], references: [id])
  
  @@index([phase_transfer_id])
  @@index([event_date])
}

// ============================================================================
// ANNUAL REVIEW SCHEDULER
// ============================================================================

model AnnualReview {
  id                    String               @id @default(cuid())
  la_tenant_id          Int
  ehcpId                String               @map("ehcp_id")
  
  // Child Details
  child_id              String
  child_name            String
  
  // Review Period
  review_period_start   DateTime
  review_period_end     DateTime
  
  // Scheduling
  scheduledDate         DateTime?            @map("scheduled_date")
  reviewType            String               @default("standard") @map("review_type") // standard, phase_transfer, early_review, emergency
  
  // Setting Details
  setting_id            Int?
  setting_name          String?
  setting_senco_id      Int?
  
  // Key Deadlines
  paperwork_due         DateTime?            // 2 weeks before review
  decision_due          DateTime?            // 4 weeks after review meeting
  final_plan_due        DateTime?            // 8 weeks after review meeting
  
  // Invitees
  invitees              Json?                // Array of {role, name, email, invited, attending}
  
  // Meeting Details
  meeting_location      String?
  meeting_format        String?              // in_person, video, hybrid
  
  // Status
  status                String               @default("scheduled") // scheduled, paperwork_requested, paperwork_received, meeting_held, decision_made, plan_amended, completed
  
  // Review Outcome
  outcome               String?              // maintain, amend, cease, request_early_review
  outcome_date          DateTime?
  outcome_summary       String?              @db.Text
  
  // Parent Views
  parent_views_received Boolean              @default(false)
  child_views_received  Boolean              @default(false)
  setting_advice_received Boolean            @default(false)

  // Missing fields from code
  
  // Amendments
  amendments_required   Json?                // Specific changes required
  amended_plan_issued   DateTime?
  
  // Case Officer
  case_officer_id       Int?
  
  // Timestamps
  created_at            DateTime             @default(now())
  updated_at            DateTime             @default(now())
  
  // Relations
  la_tenant             tenants              @relation("LAAnnualReviews", fields: [la_tenant_id], references: [id])
  case_officer          users?               @relation("AnnualReviewOfficer", fields: [case_officer_id], references: [id])
  contributions         AnnualReviewContribution[]

  // New fields required by code
  studentId             String?
  coordinatorId         String?
  createdById           String?
  participants          Json?
  invitations           Json?
  preReviewDocuments    Json?
  parentViews           Json?
  childViews            Json?
  professionalReports   Json?
  meetingNotes          String?
  laNotificationSent    Boolean              @default(false)
  laDecision            String?
  completionChecklist   Json?
  actualDate            DateTime?
  agenda                Json?
  decisions             Json?
  outcomesReview        Json?
  newOutcomes           Json?
  recommendations       Json?
  
  @@index([la_tenant_id])
  @@index([scheduledDate])
  @@index([status])
  @@index([setting_id])
}

model AnnualReviewContribution {
  id                    String               @id @default(cuid())
  annual_review_id      String
  
  // Contributor Details
  contributor_type      String               // parent, child, school, health, social_care, ep, other
  contributor_name      String?
  contributor_email     String?
  contributor_id        Int?                 // If a registered user
  
  // Contribution
  contribution_type     String               // views, report, advice
  content               String?              @db.Text
  file_url              String?
  
  // Status
  status                String               @default("requested") // requested, submitted, reviewed
  requested_date        DateTime?
  submitted_date        DateTime?
  
  // Relations
  annual_review         AnnualReview         @relation(fields: [annual_review_id], references: [id], onDelete: Cascade)
  contributor           users?               @relation("AnnualReviewContributor", fields: [contributor_id], references: [id])
  
  @@index([annual_review_id])
}

// ============================================================================
// COMPLIANCE RISK PREDICTION
// ============================================================================

model ComplianceRiskPrediction {
  id                    String               @id @default(cuid())
  la_tenant_id          Int
  ehcp_application_id   String?
  
  // Prediction Details
  risk_score            Float                // 0-100
  risk_level            String               // low, medium, high, critical
  
  // Risk Factors (weights and scores)
  risk_factors          Json                 // [{factor: "time_elapsed", weight: 0.3, score: 75, contribution: 22.5}]
  
  // Individual Factor Scores
  timeline_risk         Float                @default(0) // Days remaining vs required
  complexity_risk       Float                @default(0) // Based on needs profile
  resource_risk         Float                @default(0) // EP availability, etc.
  historical_risk       Float                @default(0) // Past LA performance
  
  // Contributing Factors (human readable)
  primary_risk_factors  String[]             // Top 3 risk factors
  mitigation_actions    Json?                // Suggested actions
  
  // Prediction Confidence
  confidence            Float                @default(0.8) // Model confidence
  
  // Breach Probability
  decision_breach_prob  Float?               // Probability of missing 6-week decision
  draft_breach_prob     Float?               // Probability of missing 16-week draft
  final_breach_prob     Float?               // Probability of missing 20-week final
  
  // Model Version
  model_version         String               @default("v1")
  
  // Timestamps
  predicted_at          DateTime             @default(now())
  expires_at            DateTime?            // When prediction should be recalculated
  
  // Relations
  la_tenant             tenants              @relation("LARiskPredictions", fields: [la_tenant_id], references: [id])
  
  @@index([la_tenant_id])
  @@index([risk_level])
  @@index([predicted_at])
}

model ComplianceAlert {
  id                    String               @id @default(cuid())
  la_tenant_id          Int
  ehcp_application_id   String?
  
  // Alert Details
  alert_type            String               // deadline_approaching, deadline_breached, risk_escalated, resource_issue
  severity              String               // info, warning, critical
  
  // Content
  title                 String
  message               String
  
  // Related Data
  deadline_date         DateTime?
  days_remaining        Int?
  
  // Status
  status                String               @default("active") // active, acknowledged, resolved, expired
  acknowledged_by_id    Int?
  acknowledged_at       DateTime?
  resolved_at           DateTime?
  
  // Actions Taken
  actions_taken         Json?
  
  // Timestamps
  created_at            DateTime             @default(now())
  
  // Relations
  la_tenant             tenants              @relation("LAComplianceAlerts", fields: [la_tenant_id], references: [id])
  acknowledged_by       users?               @relation("ComplianceAlertAcknowledger", fields: [acknowledged_by_id], references: [id])
  
  @@index([la_tenant_id])
  @@index([status])
  @@index([severity])
}

// ============================================================================
// RESOURCE COSTING MODULE
// ============================================================================

model ProvisionCost {
  id                    String               @id @default(cuid())
  la_tenant_id          Int
  
  // provisions Details
  provision_type        String               // ep_assessment, salt, ot, specialist_teaching, 1to1_support, etc.
  provision_name        String
  description           String?
  
  // Cost Structure
  cost_model            String               // hourly, daily, annual, per_session, block
  unit_cost             Float                // Cost per unit
  currency              String               @default("GBP")
  
  // Typical Allocations
  min_units             Float?               // Minimum typical allocation
  max_units             Float?               // Maximum typical allocation
  typical_units         Float?               // Most common allocation
  
  // Funding Band (if applicable)
  funding_band_id       String?
  
  // Provider Information
  provider_type         String?              // la_internal, external_commissioned, health, social_care
  typical_providers     String[]             // List of typical provider types
  
  // Active Period
  effective_from        DateTime
  effective_to          DateTime?
  is_active             Boolean              @default(true)
  
  // Timestamps
  created_at            DateTime             @default(now())
  updated_at            DateTime             @default(now())
  
  // Relations
  la_tenant             tenants              @relation("LAProvisionCosts", fields: [la_tenant_id], references: [id])
  funding_band          FundingBand?         @relation(fields: [funding_band_id], references: [id])
  
  @@index([la_tenant_id])
  @@index([provision_type])
  @@index([is_active])
}

model FundingBand {
  id                    String               @id @default(cuid())
  la_tenant_id          Int
  
  // Band Details
  band_code             String               // A, B, C, D, E or descriptive
  band_name             String
  description           String?
  
  // Financial Values
  annual_value          Float                // Total annual funding
  element_1             Float                @default(0) // Core schools budget
  element_2             Float                @default(0) // Notional SEN budget (up to £6k)
  element_3             Float                @default(0) // Top-up funding
  
  // Need Profile Indicators
  typical_needs         String[]             // Need types typically in this band
  complexity_level      String               // low, medium, high, very_high
  
  // Active Period
  academic_year         String               // 2024-25
  is_active             Boolean              @default(true)
  
  // Timestamps
  created_at            DateTime             @default(now())
  updated_at            DateTime             @default(now())
  
  // Relations
  la_tenant             tenants              @relation("LAFundingBands", fields: [la_tenant_id], references: [id])
  provision_costs       ProvisionCost[]
  cost_calculations     EHCPCostCalculation[]
  
  @@unique([la_tenant_id, band_code, academic_year])
  @@index([la_tenant_id])
}

model EHCPCostCalculation {
  id                    String               @id @default(cuid())
  la_tenant_id          Int
  ehcp_id               String?
  ehcp_application_id   String?
  
  // Child Details
  child_id              String
  child_name            String
  
  // Calculation Details
  calculation_type      String               // estimate, actual, forecast
  academic_year         String
  
  // Funding Band
  funding_band_id       String?
  funding_band_code     String?
  
  // Cost Breakdown
  provisions            Json                 // [{provision_type, units, unit_cost, total, funded_by}]
  
  // Totals by Funder
  education_total       Float                @default(0)
  health_total          Float                @default(0)
  social_care_total     Float                @default(0)
  
  // Grand Total
  total_annual_cost     Float                @default(0)
  
  // Placement Costs
  placement_type        String?              // mainstream, resourced_provision, special_school, independent
  placement_cost        Float                @default(0)
  transport_cost        Float                @default(0)
  
  // Comparison to Average
  la_average_cost       Float?
  variance_from_average Float?
  
  // Status
  status                String               @default("draft") // draft, submitted, approved
  approved_by_id        Int?
  approved_at           DateTime?
  
  // Timestamps
  calculated_at         DateTime             @default(now())
  updated_at            DateTime             @default(now())
  
  // Relations
  la_tenant             tenants              @relation("LAEHCPCosts", fields: [la_tenant_id], references: [id])
  funding_band          FundingBand?         @relation(fields: [funding_band_id], references: [id])
  approved_by           users?               @relation("CostApprover", fields: [approved_by_id], references: [id])
  
  @@index([la_tenant_id])
  @@index([child_id])
  @@index([academic_year])
}

// ============================================================================
// GOLDEN THREAD ANALYSIS
// ============================================================================

model GoldenThreadAnalysis {
  id                    String               @id @default(cuid())
  la_tenant_id          Int?
  ehcp_id               String
  
  // Analysis Details
  analysis_version      Int                  @default(1)
  analysis_date         DateTime             @default(now())
  
  // Overall Scores
  overall_coherence     Float                // 0-100
  overall_quality       Float                // 0-100
  
  // Section Scores
  section_scores        Json                 // {needs: 85, outcomes: 72, provision: 68, ...}
  
  // Needs Analysis
  needs_identified      Json                 // Array of identified needs
  needs_categories      Json                 // Breakdown by category (SEMH, SLCN, etc.)
  needs_clarity_score   Float                // How clearly needs are described
  
  // Outcomes Analysis
  outcomes_extracted    Json                 // Array of outcomes
  outcomes_smart_score  Float                // How SMART the outcomes are
  outcomes_linked_to_needs Boolean           @default(false)
  
  // provisions Analysis
  provisions_mapped     Json                 // Array of provisions
  provisions_linked     Boolean              @default(false) // All linked to needs/outcomes
  provision_gaps        Json?                // Identified gaps
  
  // Linkage Analysis
  need_outcome_links    Json                 // Links between needs and outcomes
  outcome_provision_links Json               // Links between outcomes and provisions
  broken_links          Json?                // Identified broken links
  
  // Recommendations
  recommendations       Json                 // Suggested improvements
  priority_issues       String[]             // Top issues to address
  
  // AI Analysis (if used)
  ai_model_used         String?
  ai_confidence         Float?
  
  // Status
  status                String               @default("completed") // in_progress, completed, reviewed
  reviewed_by_id        Int?
  reviewed_at           DateTime?
  
  // Timestamps
  created_at            DateTime             @default(now())
  updated_at            DateTime             @default(now())
  
  // Relations
  la_tenant             tenants?             @relation("LAGoldenThreadAnalyses", fields: [la_tenant_id], references: [id])
  reviewed_by           users?               @relation("GoldenThreadReviewer", fields: [reviewed_by_id], references: [id])
  
  @@index([la_tenant_id])
  @@index([ehcp_id])
  @@index([analysis_date])
}

// ============================================================================
// SEN2 RETURN DATA
// ============================================================================

model SEN2ReturnData {
  id                    String               @id @default(cuid())
  la_tenant_id          Int
  
  // Return Period
  academic_year         String               // 2024-25
  census_date           DateTime             // January census date
  submission_deadline   DateTime
  
  // Return Status
  status                String               @default("draft") // draft, validated, submitted, accepted
  submitted_at          DateTime?
  dfe_reference         String?
  
  // Summary Statistics (SEN2 Tables)
  // Table 1: EHCPs by age
  ehcps_by_age          Json                 // {under5: x, 5to10: y, 11to15: z, 16to19: a, 20plus: b}
  
  // Table 2: Primary need type
  ehcps_by_need         Json                 // {ASD: x, SEMH: y, SLCN: z, MLD: a, ...}
  
  // Table 3: Placement type
  ehcps_by_placement    Json                 // {mainstream: x, resourced: y, special: z, independent: a}
  
  // Table 4: New EHCPs in year
  new_ehcps_in_year     Int
  initial_requests      Int
  requests_refused      Int
  
  // Table 5: Timeliness
  assessments_completed_20_weeks Int
  assessments_completed_over_20  Int
  timeliness_percentage Float
  
  // Table 6: Mediations and Tribunals
  mediations_held       Int
  tribunals_registered  Int
  tribunals_decided     Int
  
  // Table 7: Personal Budgets
  personal_budgets_active Int
  direct_payments_active Int
  
  // Validation
  validation_errors     Json?                // Array of validation issues
  validation_warnings   Json?
  last_validated        DateTime?
  
  // Timestamps
  created_at            DateTime             @default(now())
  updated_at            DateTime             @default(now())
  
  // Relations
  la_tenant             tenants              @relation("LASEN2Returns", fields: [la_tenant_id], references: [id])
  
  @@unique([la_tenant_id, academic_year])
  @@index([la_tenant_id])
  @@index([academic_year])
}

// ============================================================================
// ORIGINAL EHCP MODELS (Enhanced)
// ============================================================================

model ehcps {
  id           String   @id @default(cuid())
  tenant_id    Int
  student_id   String
  plan_details Json
  issued_at    DateTime @default(now())
  updated_at   DateTime @default(now())
  
