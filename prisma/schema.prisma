generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// SUBSCRIPTION TIER ACCESS CONTROL ENUMS
// ============================================================================

enum SubscriptionTier {
  FREE
  TRAINEE
  EP_INDEPENDENT
  EP_GROUP_SMALL
  EP_GROUP_LARGE
  SCHOOL_SMALL
  SCHOOL_LARGE
  MAT_SMALL
  MAT_LARGE
  LA_TIER1
  LA_TIER2
  LA_TIER3
  RESEARCH_INDIVIDUAL
  RESEARCH_INSTITUTION
  ENTERPRISE_CUSTOM
}

enum Feature {
  PROBLEM_SOLVER
  LESSON_DIFFERENTIATION
  EHCNA_SUPPORT
  BATTLE_ROYALE
  PROGRESS_MONITORING
  INTERVENTION_TRACKING
  BASIC_ANALYTICS
  ADVANCED_ANALYTICS
  CUSTOM_REPORTS
  DATA_EXPORT
  TEAM_COLLABORATION
  PARENT_PORTAL
  MULTI_SCHOOL_SHARING
  EMAIL_SUPPORT
  PHONE_SUPPORT
  PRIORITY_SUPPORT
  TRAINING_SESSIONS
  DEDICATED_ACCOUNT_MANAGER
  RESEARCH_API
  RESEARCH_DATA_ACCESS
  RESEARCH_DOCUMENTATION
  CUSTOM_FEATURE_DEVELOPMENT
  API_ACCESS
  MIS_INTEGRATION
  SINGLE_SIGN_ON
}

// ============================================================================
// CORE TENANT & USER MODELS
// ============================================================================

model tenants {
  id        Int    @id @default(autoincrement())
  name      String
  subdomain String @unique

  // Tenant Type & Hierarchy
  tenant_type      String    @default("SCHOOL") // "LA", "MAT", "SCHOOL", "RESEARCH"
  parent_tenant_id Int?
  parent_tenant    tenants?  @relation("TenantHierarchy", fields: [parent_tenant_id], references: [id])
  child_tenants    tenants[] @relation("TenantHierarchy")

  // UK-specific fields
  urn      String? @unique // Unique Reference Number
  la_code  String? // Local Authority code
  postcode String?

  // Configuration
  settings      Json?
  status        String  @default("active") // active, suspended, trial
  contact_email String?
  contact_phone String?

  // Metadata
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations - Core
  users                users[]
  students             students[]
  professionals        professionals[]
  assessments          assessments[]
  assessment_instances AssessmentInstance[]
  assessment_outcomes  AssessmentOutcome[]
  cases                cases[]
  interventions        interventions[]
  subscriptions        subscriptions[]

  // Relations - Training
  courses             courses[]
  enrollments         enrollments[]
  academic_years      academic_years[]
  terms               terms[]
  class_enrollments   class_enrollments[]
  subject_enrollments subject_enrollments[]
  teacher_subjects    teacher_subjects[]
  timetable_slots     timetable_slots[]

  // Relations - Gamification
  battle_stats       battle_stats[]
  merits             merits[]
  game_items         game_items[]
  equipped_items     equipped_items[]
  houses             houses[]
  squad_competitions squad_competitions[]
  squad_members      squad_members[]

  // Relations - Networking
  forums        forums[]
  forum_threads forum_threads[]
  forum_replies forum_replies[]
  friendships   friendships[]

  // Relations - EHCP/SEND
  ehcps         ehcps[]
  ehcp_versions ehcp_versions[]
  sen_details   sen_details[]
  attachments   attachments[]
  
  // Relations - LA EHCP System (Enterprise)
  la_ehcp_applications      EHCPApplication[]        @relation("LAApplications")
  school_ehcp_applications  EHCPApplication[]        @relation("SchoolApplications")
  la_compliance_metrics     LAComplianceMetrics[]    @relation("LAMetrics")
  la_notification_templates EHCPNotificationTemplate[] @relation("LANotificationTemplates")

  // Relations - Research
  research_studies research_studies[]

  // Relations - Study Buddy (AI Integration)
  study_buddy_recommendations StudyBuddyRecommendation[]
  user_learning_profiles      UserLearningProfile[]
  study_buddy_interactions    StudyBuddyInteraction[]
  predictive_insights         PredictiveInsight[]
  conversational_ai_sessions  ConversationalAISession[]
  study_buddy_agent_analytics StudyBuddyAgentAnalytics[]

  // Relations - Platform Orchestration Layer
  student_profiles           StudentProfile[]
  class_rosters              ClassRoster[]
  lesson_plans               LessonPlan[]
  student_lesson_assignments StudentLessonAssignment[]
  student_progress_snapshots StudentProgressSnapshot[]
  multi_agency_access        MultiAgencyAccess[]
  parent_child_links         ParentChildLink[]
  voice_commands             VoiceCommand[]
  automated_actions          AutomatedAction[]
  parent_teacher_messages    ParentTeacherMessage[]
  feature_usage              feature_usage[]           @relation("TenantFeatureUsage")

  // Relations - Tokenisation System
  // tokenisation_accounts  TokenisationAccount[]
  // tokenisation_transactions TokenisationTransaction[]
  // rewards                Reward[]
  // reward_claims          RewardClaim[]

  // Relations - Marketplace
  service_contracts ServiceContract[]

  // Relations - System & Security
  audit_logs         AuditLog[]
  secure_documents   SecureDocument[]
  claimed_beta_codes BetaAccessCode[]
  beta_access_usages BetaAccessCodeUsage[]

  // Relations - Integrations
  integration_settings IntegrationSettings?
  sync_logs            SyncLog[]
  squadMembers         SquadMember[]

  // Relations - Data Sovereignty (BYOD)
  database_config      TenantDatabaseConfig?

  // Relations - Algorithm Marketplace
  algorithmLicenses    AlgorithmLicense[]
  algorithmUsages      AlgorithmUsage[]

  // Relations - EHCP Module Extensions
  la_mediation_cases        MediationCase[]              @relation("LAMediationCases")
  la_tribunal_cases         TribunalCase[]               @relation("LATribunalCases")
  la_phase_transfers        PhaseTransfer[]              @relation("LAPhaseTransfers")
  la_annual_reviews         AnnualReview[]               @relation("LAAnnualReviews")
  la_risk_predictions       ComplianceRiskPrediction[]   @relation("LARiskPredictions")
  la_compliance_alerts      ComplianceAlert[]            @relation("LAComplianceAlerts")
  la_provision_costs        ProvisionCost[]              @relation("LAProvisionCosts")
  la_funding_bands          FundingBand[]                @relation("LAFundingBands")
  la_ehcp_costs             EHCPCostCalculation[]        @relation("LAEHCPCosts")
  la_golden_thread_analyses GoldenThreadAnalysis[]       @relation("LAGoldenThreadAnalyses")
  la_sen2_returns           SEN2ReturnData[]             @relation("LASEN2Returns")

  @@index([subdomain])
  @@index([tenant_type])
  @@index([status])
}

model users {
  id            Int    @id @default(autoincrement())
  tenant_id     Int
  email         String @unique
  password_hash String
  name          String
  role          String
  avatar_url    String?  // Profile photo/avatar URL

  // Additional auth fields
  firstName              String?
  lastName               String?
  permissions            String[]  @default([])
  isEmailVerified        Boolean   @default(false)
  emailVerificationToken String?
  resetPasswordToken     String?
  resetPasswordExpires   DateTime?

  // Status and tracking
  is_active  Boolean   @default(true)
  last_login DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())

  // Onboarding tracking
  onboarding_completed    Boolean   @default(false)
  onboarding_step         Int       @default(0) // 0-5, tracks current step
  onboarding_started_at   DateTime?
  onboarding_completed_at DateTime?
  onboarding_skipped      Boolean   @default(false)

  // Beta programme
  beta_tester      Boolean   @default(false)
  beta_code_used   String?
  beta_joined_at   DateTime?
  beta_feedback_count Int    @default(0)

  // Relations - Tenant
  tenants       tenants         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  ehcp_versions ehcp_versions[]

  // Relations - Educational
  assessments               assessments[]
  conducted_assessments     AssessmentInstance[]
  cases                     cases[]
  interventions_created     interventions[]      @relation("interventions_created_byTousers")
  interventions_implemented interventions[]      @relation("interventions_implemented_byTousers")

  // Relations - Gamification
  gamification_achievements gamification_achievements[]
  gamification_badges       gamification_badges[]
  gamification_scores       gamification_scores[]

  // Relations - Help System
  help_preferences  help_preferences?
  help_viewed_items help_viewed_items[]

  // Relations - Onboarding
  // onboarding_progress onboarding_progress?

  // Relations - User Types
  parents       parents?
  professionals professionals?

  // Relations - Training
  enrollments         enrollments[]
  class_enrollments   class_enrollments[]
  subject_enrollments subject_enrollments[]

  // Relations - Gamification Extended
  battle_stats   battle_stats[]
  merits         merits[]
  equipped_items equipped_items[]
  squad_members  squad_members[]

  // Relations - Networking
  forums_created        forums[]        @relation("ForumCreator")
  forum_threads         forum_threads[]
  forum_replies         forum_replies[]
  friendships_initiated friendships[]   @relation("FriendshipInitiator")
  friendships_received  friendships[]   @relation("FriendshipReceiver")

  // Relations - Research
  research_studies          research_studies[]
  research_collaborations   research_collaborators[]
  research_participants     research_participants[]
  research_ethics_approvals research_ethics_approvals[]
  research_analyses         research_analyses[]

  // Relations - Accessibility
  accessibility_settings  accessibility_settings?
  user_preferences        user_preferences?
  learning_style          learning_style?
  speech_recognition_logs speech_recognition_logs[]
  speech_synthesis_logs   speech_synthesis_logs[]
  translation_logs        translation_logs[]

  // Relations - Institutional Management
  departmentMemberships DepartmentMember[]  @relation("DepartmentMembers")
  departmentManagements DepartmentManager[] @relation("DepartmentManagers")
  institutionAdmins     InstitutionAdmin[]  @relation("InstitutionAdmins")

  // Relations - Waitlist & Problem Solver
  problem_solver_queries problem_solver_queries[]

  // Relations - Study Buddy (AI Integration)
  study_buddy_recommendations StudyBuddyRecommendation[]
  user_learning_profile       UserLearningProfile?
  study_buddy_interactions    StudyBuddyInteraction[]
  predictive_insights         PredictiveInsight[]
  conversational_ai_sessions  ConversationalAISession[]

  // Relations - Training Extensions
  course_reviews            CourseReview[]
  certificates              Certificate[]
  training_purchases        TrainingPurchase[]
  interactive_responses     InteractiveResponse[]
  learning_path_enrollments LearningPathEnrollment[]
  course_enrollments        CourseEnrollment[]
  cpd_logs                  CPDLog[]
  onboarding_progress       onboarding_progress?
  legal_signatures          LegalSignature[]

  // Relations - AI & Feedback
  recommendations         Recommendation[]
  contentInteractions     ContentInteraction[]
  feedback                Feedback[]
  surveyResponses         SurveyResponse[]
  userInterviews          UserInterview[]
  analyticsEvents         AnalyticsEvent[]
  
  // Relations - Ethics
  ethicsAssessments       EthicsAssessment[] @relation("Assessor")
  ethicsReviews           EthicsAssessment[] @relation("Reviewers")
  ethicsIncidents         EthicsIncident[]   @relation("IncidentAssignee")
  
  // Relations - Games
  gamePlayers             GamePlayer[]
  
  // Relations - Algorithms
  algorithms              Algorithm[]
  algorithmUsages         AlgorithmUsage[]
  
  // Relations - Profiles
  edPsychProfile          EdPsychProfile?
  researcherProfile       ResearcherProfile?

  // Relations - Messaging
  sent_messages     ParentTeacherMessage[] @relation("SentMessages")
  received_messages ParentTeacherMessage[] @relation("ReceivedMessages")

  // Relations - Orchestration
  class_rosters       ClassRoster[]
  lesson_plans        LessonPlan[]
  multi_agency_access MultiAgencyAccess[]
  parent_child_links  ParentChildLink[]
  voice_commands      VoiceCommand[]
  
  // Relations - LA EHCP System (Enterprise)
  caseworker_applications    EHCPApplication[]    @relation("CaseworkerApplications")
  ep_applications            EHCPApplication[]    @relation("EPApplications")
  health_applications        EHCPApplication[]    @relation("HealthApplications")
  social_applications        EHCPApplication[]    @relation("SocialApplications")
  decision_applications      EHCPApplication[]    @relation("DecisionMaker")
  created_applications       EHCPApplication[]    @relation("ApplicationCreator")
  ehcp_contributions         EHCPContribution[]   @relation("Contributor")
  ehcp_qa_reviews            EHCPContribution[]   @relation("QAReviewer")
  ehcp_timeline_events       EHCPTimelineEvent[]  @relation("TimelineActor")
  ehcp_messages_sent         EHCPCommunication[]  @relation("MessageSender")
  ehcp_documents_uploaded    EHCPDocument[]       @relation("DocumentUploader")
  ehcp_panels_chaired        EHCPPanelDecision[]  @relation("PanelChair")

  // Relations - Marketplace & Compliance
  professional_compliance ProfessionalCompliance?
  marketplace_profile     MarketplaceProfessional?
  service_listings        ServiceListing[]
  ep_contracts            ServiceContract[]        @relation("EPContracts")
  marketplace_reviews     MarketplaceReview[]

  // Relations - System
  integration_settings IntegrationSettings[]
  sync_logs            SyncLog[]
  secure_documents     SecureDocument[]
  beta_access_codes    BetaAccessCode[]
  beta_access_usages   BetaAccessCodeUsage[]
  audit_logs           AuditLog[]
  user_activities      UserActivity[]
  user_interests       UserInterest[]
  squad_memberships    SquadMember[]

  // Relations - EHCP Module Extensions
  mediation_cases_officer     MediationCase[]             @relation("MediationCaseOfficer")
  tribunal_cases_lead         TribunalCase[]              @relation("TribunalLeadOfficer")
  tribunal_docs_submitted     TribunalDocument[]          @relation("TribunalDocSubmitter")
  phase_transfers_officer     PhaseTransfer[]             @relation("PhaseTransferOfficer")
  phase_transfer_events       PhaseTransferEvent[]        @relation("PhaseTransferEventRecorder")
  annual_reviews_officer      AnnualReview[]              @relation("AnnualReviewOfficer")
  annual_review_contributions AnnualReviewContribution[]  @relation("AnnualReviewContributor")
  compliance_alerts_ack       ComplianceAlert[]           @relation("ComplianceAlertAcknowledger")
  ehcp_costs_approved         EHCPCostCalculation[]       @relation("CostApprover")
  golden_thread_reviews       GoldenThreadAnalysis[]      @relation("GoldenThreadReviewer")

  @@index([tenant_id])
  @@index([email])
  @@index([is_active])
  @@index([role])
}

// ============================================================================
// EDUCATIONAL MODELS (TENANT-SCOPED)
// ============================================================================

model students {
  id            Int      @id @default(autoincrement())
  tenant_id     Int
  unique_id     String
  first_name    String
  last_name     String
  date_of_birth DateTime
  year_group    String
  sen_status    String?

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  tenants              tenants              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  cases                cases[]
  assessment_instances AssessmentInstance[]
  assessment_outcomes  AssessmentOutcome[]

  // Relations - Platform Orchestration Layer
  student_profile    StudentProfile?
  lesson_assignments StudentLessonAssignment[]
  progress_snapshots StudentProgressSnapshot[]
  parent_links       ParentChildLink[]

  // Relations - Parent-Teacher Messaging
  parent_teacher_messages ParentTeacherMessage[]

  // Relations - Institutional Management
  studentOutcomePredictions StudentOutcomePrediction[]

  @@unique([tenant_id, unique_id])
  @@index([tenant_id])
  @@index([sen_status])
  @@index([year_group])
}

model cases {
  id            Int      @id @default(autoincrement())
  tenant_id     Int
  student_id    Int
  assigned_to   Int?
  status        String
  priority      String
  type          String
  referral_date DateTime

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  tenants              tenants              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  students             students             @relation(fields: [student_id], references: [id], onDelete: Cascade)
  users                users?               @relation(fields: [assigned_to], references: [id])
  assessments          assessments[]
  assessment_instances AssessmentInstance[]
  interventions        interventions[]

  @@index([tenant_id])
  @@index([student_id])
  @@index([status])
  @@index([priority])
}

model assessments {
  id              Int       @id @default(autoincrement())
  tenant_id       Int
  case_id         Int
  assessment_type String
  scheduled_date  DateTime?
  completion_date DateTime?
  status          String
  created_by      Int?

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  tenants tenants @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  cases   cases   @relation(fields: [case_id], references: [id], onDelete: Cascade)
  users   users?  @relation(fields: [created_by], references: [id])

  @@index([tenant_id])
  @@index([case_id])
  @@index([status])
}

model interventions {
  id                Int       @id @default(autoincrement())
  tenant_id         Int
  case_id           Int
  intervention_type String
  start_date        DateTime?
  end_date          DateTime?
  status            String
  created_by        Int?
  implemented_by    Int?

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  tenants     tenants @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  cases       cases   @relation(fields: [case_id], references: [id], onDelete: Cascade)
  creator     users?  @relation("interventions_created_byTousers", fields: [created_by], references: [id])
  implementer users?  @relation("interventions_implemented_byTousers", fields: [implemented_by], references: [id])

  @@index([tenant_id])
  @@index([case_id])
  @@index([status])
}

// ============================================================================
// USER TYPE EXTENSIONS
// ============================================================================

model professionals {
  id                Int       @id @default(autoincrement())
  user_id           Int       @unique
  tenant_id         Int
  professional_type String
  specialisation    String?
  qualifications    String[]
  student_ids       Int[]
  last_login        DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  users                       users                         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tenants                     tenants                       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  professional_portal_metrics professional_portal_metrics[]

  @@index([tenant_id])
  @@index([professional_type])
}

model professional_portal_metrics {
  id              Int      @id @default(autoincrement())
  professional_id Int
  metric_type     String
  metric_value    Float
  measured_at     DateTime @default(now())
  metadata        Json?

  // Relations
  professionals professionals @relation(fields: [professional_id], references: [id], onDelete: Cascade)

  @@index([professional_id])
  @@index([measured_at])
}

model parents {
  id                       Int       @id @default(autoincrement())
  user_id                  Int       @unique
  child_ids                Int[]
  notification_preferences Json?
  last_login               DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  users                    users                      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent_portal_activities parent_portal_activities[]
  parent_permissions       parent_permissions[]
  engagementActivities     ParentEngagementActivity[]
}

model parent_portal_activities {
  id            Int       @id @default(autoincrement())
  parent_id     Int
  child_id      Int
  activity_type String
  activity_data Json
  status        String?   @default("unread")
  viewed_at     DateTime?
  created_at    DateTime  @default(now())

  // Relations
  parents parents @relation(fields: [parent_id], references: [id], onDelete: Cascade)

  @@index([parent_id])
  @@index([child_id])
  @@index([status])
}

model parent_permissions {
  id          Int      @id @default(autoincrement())
  parent_id   Int
  canViewData Boolean  @default(true)
  canMessage  Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  // Relations
  parents parents @relation(fields: [parent_id], references: [id], onDelete: Cascade)

  @@index([parent_id])
}

// ============================================================================
// TRAINING & EDUCATION PLATFORM (TENANT-SCOPED)
// ============================================================================

model courses {
  id          String   @id @default(cuid())
  tenant_id   Int
  title       String
  description String
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  // Relations
  tenants     tenants       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  enrollments enrollments[]
  // reviews     CourseReview[]
  // certificates Certificate[]

  @@index([tenant_id])
}

model enrollments {
  id           String    @id @default(cuid())
  tenant_id    Int
  user_id      Int
  course_id    String
  status       String    @default("active")
  progress     Int       @default(0)
  started_at   DateTime  @default(now())
  completed_at DateTime?
  updated_at   DateTime  @default(now())

  // Training Platform Extensions
  purchase_id        String?
  access_granted_via String? // "purchase", "subscription", "trial", "admin_grant"
  access_expires_at  DateTime?
  is_lifetime_access Boolean   @default(false)

  // Relations
  tenants           tenants           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  users             users             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  courses           courses           @relation(fields: [course_id], references: [id], onDelete: Cascade)
  training_purchase TrainingPurchase? @relation(fields: [purchase_id], references: [id])

  @@unique([user_id, course_id])
  @@index([tenant_id])
  @@index([user_id])
  @@index([course_id])
}

model academic_years {
  id         String   @id @default(cuid())
  tenant_id  Int
  year_label String
  start_date DateTime
  end_date   DateTime
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  tenants tenants @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
}

model terms {
  id         String   @id @default(cuid())
  tenant_id  Int
  name       String
  start_date DateTime
  end_date   DateTime
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
  tenants tenants @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
}

model class_enrollments {
  id         String   @id @default(cuid())
  tenant_id  Int
  class_id   String
  student_id Int
  joined_at  DateTime @default(now())

  // Relations
  tenants tenants @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  users   users   @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([class_id])
  @@index([student_id])
}

model subject_enrollments {
  id         String   @id @default(cuid())
  tenant_id  Int
  subject    String
  user_id    Int
  created_at DateTime @default(now())

  // Relations
  tenants tenants @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  users   users   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([user_id])
}

model teacher_subjects {
  id           String   @id @default(cuid())
  tenant_id    Int
  teacher_id   String
  subject_name String
  created_at   DateTime @default(now())

  // Relations
  tenants tenants @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([teacher_id])
}

model timetable_slots {
  id          String @id @default(cuid())
  tenant_id   Int
  class_id    String
  subject     String
  day_of_week String
  start_time  String
  end_time    String

  // Relations
  tenants tenants @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([class_id])
}

// ============================================================================
// GAMIFICATION SYSTEM (TENANT-SCOPED)
// ============================================================================

model gamification_achievements {
  id               Int      @id @default(autoincrement())
  user_id          Int
  achievement_type String
  achievement_name String
  description      String?
  points_awarded   Int
  metadata         Json?
  achieved_at      DateTime @default(now())

  // Relations
  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([achievement_type])
}

model gamification_badges {
  id          Int      @id @default(autoincrement())
  user_id     Int
  badge_type  String
  badge_name  String
  description String?
  image_url   String?
  level       Int?     @default(1)
  metadata    Json?
  awarded_at  DateTime @default(now())

  // Relations
  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([badge_type])
}

model gamification_scores {
  id          Int    @id @default(autoincrement())
  user_id     Int
  score_type  String
  score_value Int
  metadata    Json?

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  // Relations
