  userId      Int?
  action      String
  resource    String
  details     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        users?   @relation(fields: [userId], references: [id])
  tenantId    Int?
  tenant      tenants? @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
}

model Waitlist {
  id               String   @id @default(uuid())
  email            String   @unique
  name             String?
  organization     String?
  organization_type String?
  role             String?
  priority         String   @default("medium")
  status           String   @default("pending")
  
  // Marketing & Tracking
