// ============================================================================
// ETHICS & COMPLIANCE
// ============================================================================

model EthicsAssessment {
  id            String    @id @default(cuid())
  title         String
  description   String    @db.Text
  componentId   String
  componentType String
  assessorId    Int
  status        String    @default("draft") // draft, in_review, approved, rejected, completed
  version       Int       @default(1)
  
  questions     Json      // Array of { question, answer, category }
  ethicalRisks  Json      // Array of { description, severity, category }
  mitigations   Json      // Array of { riskIndex, description, status }
  recommendedMonitors Json // Array of { monitorType, description, configuration }
  tags          String[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now())
  approvedAt    DateTime?

  // Relations
  assessor      users     @relation("Assessor", fields: [assessorId], references: [id])
  reviewers     users[]   @relation("Reviewers")

  @@index([status])
  @@index([componentType])
}

model EthicsIncident {
  id             String    @id @default(cuid())
  title          String
  description    String    @db.Text
  monitorId      String?
  metricId       String?
  metricValue    Float?
  thresholdValue Float?
  
  status         String    @default("open") // open, investigating, mitigating, resolved, dismissed
  severity       String    @default("medium") // low, medium, high, critical
  
  resolutionSteps Json     // Array of { description, status, createdAt, completedAt }
  tags           String[]

  detectedAt     DateTime  @default(now())
  resolvedAt     DateTime?
  
  assignedToId   Int?
  assignedTo     users?    @relation("IncidentAssignee", fields: [assignedToId], references: [id])

  monitor        EthicsMonitor? @relation(fields: [monitorId], references: [id])

  @@index([status])
  @@index([severity])
}

model EthicsMonitor {
  id          String    @id @default(cuid())
  name        String
  description String    @db.Text
  
  metrics     Json      // Array of { id, name, category }
  thresholds  Json      // Object of { metricId: { type, value } }
  
  enabled     Boolean   @default(true)
  frequency   String    @default("daily")
  severity    String    @default("medium")
  tags        String[]
  
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())

  incidents   EthicsIncident[]

  @@index([enabled])
}

// ============================================================================
// BATTLE ROYALE GAMIFICATION (REAL-TIME)
// ============================================================================

model BattleRoyaleGame {
  id             String   @id @default(cuid())
  name           String
  subject        String
  topic          String
  yearGroup      String
  maxPlayers     Int
  currentPlayers Int      @default(0)
  status         String   // waiting, starting, active, ending, completed
  gameMode       String
  difficulty     String
  duration       Int
  createdAt      DateTime @default(now())
  startedAt      DateTime?
  endedAt        DateTime?
  
  players        GamePlayer[]
  events         GameEvent[]
  
  // Complex objects stored as JSON
  gameMap        Json?
  powerUps       Json?
  leaderboard    Json?
}

model GamePlayer {
  id             String   @id @default(cuid())
  gameId         String
  userId         Int
  
  // Game specific stats
  score          Int      @default(0)
  position       Int?
  kills          Int      @default(0)
  survivalTime   Int      @default(0)
  status         String   @default("active") // active, eliminated
  
  game           BattleRoyaleGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user           users            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
}

model GameEvent {
  id             String   @id @default(cuid())
  gameId         String
  type           String
  timestamp      DateTime @default(now())
  playerId       String?
  data           Json?
  
  game           BattleRoyaleGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  @@index([gameId])
}

// ============================================================================
// ALGORITHM MARKETPLACE
// ============================================================================

model Algorithm {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  tags        String[]
  price       Float
  currency    String   @default("GBP")
  
  creatorId   Int
  creator     users    @relation(fields: [creatorId], references: [id])
  
  versions    AlgorithmVersion[]
  licenses    AlgorithmLicense[]
  usages      AlgorithmUsage[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  
  @@index([creatorId])
}

model AlgorithmVersion {
  id          String   @id @default(cuid())
  algorithmId String
  version     String
  code        String?  // Or URL to code
  changelog   String?
  status      String   @default("draft") // draft, published, deprecated
  
  algorithm   Algorithm @relation(fields: [algorithmId], references: [id], onDelete: Cascade)
  usages      AlgorithmUsage[]
  
  createdAt   DateTime @default(now())
  
  @@index([algorithmId])
}

model AlgorithmLicense {
  id          String   @id @default(cuid())
  algorithmId String
  tenantId    Int
  type        String   // subscription, perpetual, usage-based
  status      String   @default("active")
  
  startsAt    DateTime @default(now())
  expiresAt   DateTime?
  
  algorithm   Algorithm @relation(fields: [algorithmId], references: [id])
  tenant      tenants   @relation(fields: [tenantId], references: [id])
  
  @@index([algorithmId])
  @@index([tenantId])
}

model AlgorithmUsage {
  id          String   @id @default(cuid())
  algorithmId String
  versionId   String?
  tenantId    Int
  userId      Int?
  
  executionTime Int    // ms
  status      String   // success, failure
  cost        Float    @default(0)
  
  timestamp   DateTime @default(now())
  
  algorithm   Algorithm @relation(fields: [algorithmId], references: [id])
  version     AlgorithmVersion? @relation(fields: [versionId], references: [id])
  tenant      tenants   @relation(fields: [tenantId], references: [id])
  user        users?    @relation(fields: [userId], references: [id])
  
  @@index([algorithmId])
  @@index([tenantId])
  @@index([timestamp])
}

// ============================================================================
// RECOMMENDATION ENGINE
// ============================================================================

model Recommendation {
  id          String   @id @default(cuid())
  userId      Int
  contentId   String
  score       Float
  reason      String
  status      String   @default("ACTIVE")
  notes       String?
  clickedAt   DateTime?
  dismissedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  user    users   @relation(fields: [userId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([contentId])
  @@index([status])
}

model ContentInteraction {
  id                   String   @id @default(cuid())
  userId               Int
  contentId            String
  interactionType      String
  durationSeconds      Int?
  completionPercentage Float?
  rating               Int?
  bookmarked           Boolean  @default(false)
  createdAt            DateTime @default(now())

  user    users   @relation(fields: [userId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([contentId])
  @@index([interactionType])
}

model ContentSimilarity {
  id              String   @id @default(cuid())
  contentIdA      String
  contentIdB      String
  similarityScore Float
  similarityType  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())

  contentA Content @relation("ContentSimilarityA", fields: [contentIdA], references: [id], onDelete: Cascade)
  contentB Content @relation("ContentSimilarityB", fields: [contentIdB], references: [id], onDelete: Cascade)

  @@index([contentIdA])
  @@index([contentIdB])
}

model AssessmentContentLink {
  id               String   @id @default(cuid())
  assessmentResultId String
  contentId        String
  relevanceScore   Float
  linkType         String
  createdAt        DateTime @default(now())

  assessmentResult AssessmentResult @relation(fields: [assessmentResultId], references: [id], onDelete: Cascade)
  content          Content          @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([assessmentResultId])
  @@index([contentId])
}

