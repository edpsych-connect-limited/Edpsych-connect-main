// ============================================================================
// AUDIT & LEGAL MODELS
// ============================================================================

model AuditLog {
  id             String   @id @default(uuid())
  userId         String?
  performedById  String?
  institutionId  String?
  subscriptionId String?
  action         String
  resource       String?
  description    String?
  details        Json?
  entityType     String?
  entityId       String?
  changes        Json?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  timestamp      DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([performedById])
  @@index([institutionId])
  @@index([subscriptionId])
  @@index([resource])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@index([action])
  @@map("audit_logs")
}

model LegalDocument {
  id            String   @id @default(uuid())
  type          String
  version       String
  content       String   @db.Text
  effectiveDate DateTime
  status        String   @default("active")
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
  @@index([version])
  @@index([status])
  @@index([effectiveDate])
}

// ============================================================================
// USER PREFERENCES MODEL
// ============================================================================

model UserPreference {
  id              String   @id @default(uuid())
  userId          String   @unique
  category        String?
  type            String?
  value           Json?
  theme           String?  @default("light")
  language        String?  @default("en")
  notifications   Json?
  accessibility   Json?
  privacy         Json?
  displaySettings Json?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([type])
}

// ============================================================================
// VOLUME DISCOUNT MODEL
// ============================================================================

model VolumeDiscountTier {
  id              String   @id @default(uuid())
  tier            String
  minQuantity     Int
  maxQuantity     Int?
  discountPercent Float
  description     String?
  isActive        Boolean  @default(true)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tier])
  @@index([minQuantity])
  @@index([isActive])
}

// ============================================================================
// INSTITUTIONAL MANAGEMENT MODELS
// ============================================================================

model Institution {
  id                 String    @id @default(uuid())
  name               String
  type               String
  size               String
  address            String?
  city               String?
  region             String?
  postcode           String?
  country            String?
  phone              String?
  email              String
  website            String?
  logoUrl            String?
  notes              String?   @db.Text
  tags               String[]  @default([])
  customFields       Json?
  verificationStatus String    @default("PENDING")
  verifiedAt         DateTime?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdBy          String?

  contacts      InstitutionContact[]
  departments   Department[]
  subscriptions InstitutionSubscription[]
  admins        InstitutionAdmin[]

  @@index([name])
  @@index([type])
  @@index([verificationStatus])
  @@index([isActive])
  @@index([email])
}

model InstitutionContact {
  id               String   @id @default(uuid())
  institutionId    String
  firstName        String
  lastName         String
  email            String
  phone            String?
  role             String?
  isPrimaryContact Boolean  @default(false)
  jobTitle         String?
  notes            String?  @db.Text
  departmentId     String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([institutionId])
  @@index([email])
  @@index([isPrimaryContact])
  @@index([departmentId])
}

model Department {
  id                 String   @id @default(uuid())
  institutionId      String
  name               String
  description        String?  @db.Text
  type               String
  parentDepartmentId String?
  headOfDepartmentId String?
  status             String   @default("ACTIVE")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          String

  institution      Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  parentDepartment Department?          @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments Department[]         @relation("DepartmentHierarchy")
  contacts         InstitutionContact[]
  users            DepartmentMember[]
  managers         DepartmentManager[]

  @@index([institutionId])
  @@index([name])
  @@index([type])
  @@index([status])
  @@index([parentDepartmentId])
  @@index([headOfDepartmentId])
}

// Join table for Department members
model DepartmentMember {
  id           String   @id @default(uuid())
  departmentId String
  userId       Int
  role         String?
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       users      @relation("DepartmentMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

// Join table for Department managers
model DepartmentManager {
  id           String   @id @default(uuid())
  departmentId String
  userId       Int
  assignedAt   DateTime @default(now())
  assignedBy   String?
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       users      @relation("DepartmentManagers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

// Institution Subscription model
model InstitutionSubscription {
  id                 String   @id @default(uuid())
  institutionId      String
  plan               String
  status             String
  licenseCount       Int      @default(1)
  price              Float    @default(0)
  paymentMethod      String?
  billingCycle       String   @default("ANNUALLY")
  autoRenew          Boolean  @default(true)
  discountPercentage Float?
  discountCode       String?
  startDate          DateTime
  endDate            DateTime
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

// Join table for Institution admins
model InstitutionAdmin {
  id            String   @id @default(uuid())
  institutionId String
  userId        Int
  assignedAt    DateTime @default(now())
  assignedBy    String?
  createdAt     DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user        users       @relation("InstitutionAdmins", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([institutionId, userId])
  @@index([institutionId])
  @@index([userId])
}

// ============================================================================
// PHASE 4: TRAINING PLATFORM EXTENSIONS
// ============================================================================

model CourseQuiz {
  id           String   @id @default(uuid())
  courseId     String
  moduleId     String?
  lessonId     String?
  title        String
  description  String?  @db.Text
  timeLimit    Int? // in minutes
  passingScore Int      @default(70) // percentage
  orderIndex   Int
  isRequired   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  course    Course         @relation(fields: [courseId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([courseId])
  @@index([moduleId])
  @@index([lessonId])
  @@index([orderIndex])
}

model QuizQuestion {
  id            String   @id @default(uuid())
  quizId        String
  questionText  String   @db.Text
  questionType  String // multiple_choice, true_false, short_answer, essay
  options       Json? // For multiple choice: ["Option 1", "Option 2", ...]
