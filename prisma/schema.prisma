// ============================================================================
// TIME SAVINGS METRICS (Zero Gap Project)
// Individual time savings records for each automated action
// ============================================================================

model TimeSavingsMetric {
  id                      Int      @id @default(autoincrement())
  tenantId                Int      @map("tenant_id")
  userId                  Int?     @map("user_id")
  
  // Feature Classification
  featureCategory         String   @map("feature_category") // ehcp, iep, assessment, etc.
  featureName             String   @map("feature_name")     // Human readable name
  actionType              String   @map("action_type")      // document_generation, report_creation, etc.
  
  // Time Measurements
  traditionalTimeMinutes  Int      @map("traditional_time_minutes") // Industry benchmark
  automatedTimeMinutes    Int      @map("automated_time_minutes")   // Actual time with automation
  timeSavedMinutes        Int      @map("time_saved_minutes")       // Difference
  
  // Evidence
  evidenceType            String   @map("evidence_type") // measured, estimated, reported, calculated
  metadata                String?  @db.Text              // JSON with additional context
  
  recordedAt              DateTime @default(now()) @map("recorded_at")
  
  tenant                  tenants  @relation("TenantTimeSavingsMetrics", fields: [tenantId], references: [id])
  user                    users?   @relation("UserTimeSavingsMetrics", fields: [userId], references: [id])
  
  @@index([tenantId])
  @@index([userId])
  @@index([featureCategory])
  @@index([recordedAt])
  @@map("time_savings_metrics")
}

// ============================================================================
// TIME SAVINGS REPORTS (Zero Gap Project)
// Aggregated time savings reports for periods
