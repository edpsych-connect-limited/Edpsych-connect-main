// TRANSITION PLANNING
// ============================================================================

model TransitionPlan {
  id                  String   @id @default(cuid())
  studentId           Int
  student             students @relation(fields: [studentId], references: [id])
  transitionType      String
  currentSettingId    String?
  targetSettingId     String?
  targetDate          DateTime
  keyWorker           Json?    // { id, name, role, contactEmail }
  preparationAreas    Json?    // [{ area, priority, strategies }]
  supportRequirements Json?    // { academic: [], ... }
  phases              Json?    // [{ name, startDate, status, tasks }]
  status              String   @default("DRAFT")
  createdById         String?
  updatedById         String?
  
  meetings            TransitionMeeting[]
  documents           TransitionDocument[]
  checklists          TransitionChecklist[]
  communications      TransitionCommunication[]
  actions             TransitionAction[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TransitionMeeting {
  id               String         @id @default(cuid())
  transitionPlanId String
  transitionPlan   TransitionPlan @relation(fields: [transitionPlanId], references: [id])
  meetingType      String
  scheduledDate    DateTime
  participants     Json           // [{ name, role, organisation, email }]
  agenda           Json           // String[]
  venue            String?
  virtualLink      String?
  notes            String?
  outcomes         String[]
  actions          Json?          // [{ description, assignedTo, dueDate }]
  nextSteps        String?
  actualAttendees  Json?          // [{ name, role }]
  status           String         @default("SCHEDULED")
  completedAt      DateTime?
  createdById      String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TransitionDocument {
  id               String         @id @default(cuid())
  transitionPlanId String
  transitionPlan   TransitionPlan @relation(fields: [transitionPlanId], references: [id])
  documentType     String
  title            String
  content          Json?
  attachmentUrl    String?
  confidential     Boolean        @default(false)
  status           String         @default("DRAFT")
  uploadedById     String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TransitionChecklist {
  id               String         @id @default(cuid())
  transitionPlanId String
  transitionPlan   TransitionPlan @relation(fields: [transitionPlanId], references: [id])
  phase            String
  items            Json           // [{ task, responsible, dueDate, notes }]
  createdById      String?
  updatedById      String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([transitionPlanId, phase])
}

model TransitionCommunication {
  id               String         @id @default(cuid())
  transitionPlanId String
  transitionPlan   TransitionPlan @relation(fields: [transitionPlanId], references: [id])
  date             DateTime
  type             String
  summary          String
  sender           String?
  recipient        String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TransitionAction {
  id               String         @id @default(cuid())
  transitionPlanId String
  transitionPlan   TransitionPlan @relation(fields: [transitionPlanId], references: [id])
  description      String
  assignedTo       String
  dueDate          DateTime?
  priority         String         @default("MEDIUM")
  status           String         @default("PENDING")
  createdById      String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}


// ============================================================================
// AI TUTORING SYSTEM
// ============================================================================

model TutoringSession {
  id            String   @id @default(cuid())
  student_id    Int
  topic_id      String
  session_type  String   @default("practice") // practice, assessment, review
  difficulty    String   @default("adaptive")
  status        String   @default("active") // active, completed
  
  start_time    DateTime @default(now())
  end_time      DateTime?
  
  // Progress
  questions_answered Int @default(0)
  correct_answers    Int @default(0)
  current_streak     Int @default(0)
  time_spent         Int @default(0) // seconds
  
  // Assessment
  pre_test_score     Float?
  current_score      Float?
  mastery_level      Float?
  
  // Data
  objectives         String[]
  learning_path      Json? // Array of steps
  hint_usage         Json?
  completion_summary Json?
  
  // Relations
  student       students @relation(fields: [student_id], references: [id], onDelete: Cascade)
  messages      TutoringMessage[]
  
  @@index([student_id])
  @@index([topic_id])
  @@index([status])
}

model TutoringMessage {
  id            String   @id @default(cuid())
  session_id    String
  type          String   // student, tutor
  content       String   @db.Text
  response_type String?  // text, multiple_choice, interactive
  
  // Metadata
  time_spent    Int?
  confidence    Float?
  action        Json?    // NextAction
  question      Json?    // Question details
  
  timestamp     DateTime @default(now())
  
  // Relations
  session       TutoringSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  
  @@index([session_id])
}

model StudentTopicMastery {
  id              String   @id @default(cuid())
  student_id      Int
  topic_id        String
  
  knowledge_level Float    @default(0.0)
  confidence      Float    @default(0.0)
  
  last_updated    DateTime @default(now())
  
  progress_history Json?   // Array of history items
  
  // Relations
  student         students @relation(fields: [student_id], references: [id], onDelete: Cascade)
  
  @@unique([student_id, topic_id])
  @@index([student_id])
}


model ConsentType {
  id          String   @id @default(uuid())
  name        String
  description String
  required    Boolean
  version     Int
  active      Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  records     ConsentRecord[]

  @@map("consent_types")
}

model ConsentRecord {
  id                String    @id @default(uuid())
  user_id           Int
  consent_type_id   String
  consented         Boolean
  consent_text      String
  consent_timestamp DateTime  @default(now())
  withdrawal_timestamp DateTime?
  valid_until       DateTime?
  consent_version   Int

  user              users       @relation(fields: [user_id], references: [id])
  consent_type      ConsentType @relation(fields: [consent_type_id], references: [id])

  @@map("consent_records")
}

model DataSubjectRequest {
  id              String    @id @default(uuid())
  user_id         Int
  request_type    String
  status          String
  request_details Json?
  submitted_at    DateTime  @default(now())
  processed_at    DateTime?
  completed_at    DateTime?
  expires_at      DateTime
  response_data   Json?
  rejection_reason String?

  user            users     @relation(fields: [user_id], references: [id])

  @@map("data_subject_requests")
}

model PrivacyPolicy {
  id                String   @id @default(uuid())
  version           Int
  title             String
  content           String   @db.Text
  effective_date    DateTime
  published_at      DateTime @default(now())
  requires_reconsent Boolean

  @@map("privacy_policies")
}

