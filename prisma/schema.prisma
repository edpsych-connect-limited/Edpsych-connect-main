  quiz    CourseQuiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
  @@index([userId])
}

model QuizAnswer {
  id           String   @id @default(uuid())
  attemptId    String
  questionId   String
