  complaint_indicators Boolean @default(false)
  
  // Key Phrases
  concerning_phrases   String[]
  
  // Risk Score
  escalation_risk     Float   @default(0) // 0-100
  
  // Analysis Metadata
  analyzed_at         DateTime @default(now())
  model_version       String
  confidence          Float   @default(0)
  
  @@index([ehcp_id])
  @@index([student_id])
  @@index([parent_id])
  @@index([sentiment_label])
}

// ============================================================================
// CODING CURRICULUM (Developers of Tomorrow)
// ============================================================================

model CodingCourse {
  id              String   @id @default(cuid())
  
  // Course Info
  title           String
  description     String   @db.Text
  level           String   // blocks, python, react
  difficulty      Int      @default(1) // 1-5
  
  // Target Audience
  min_age         Int      @default(7)
  max_age         Int      @default(18)
  
  // SEND-Specific Design
  cognitive_load_rating    Int    @default(2) // 1-5
  multi_sensory_elements   String[] @default([])
  neurodiverse_adaptations Json?
  
  // Course Structure
  total_lessons   Int      @default(0)
  estimated_hours Float    @default(0)
  
  // Status
  is_published    Boolean  @default(false)
  
  // Audit
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())
  
  // Relations
  lessons         CodingLesson[]
  enrollments     CodingEnrollment[]
  
  @@index([level])
}

model CodingLesson {
  id              String   @id @default(cuid())
  course_id       String
  
  // Lesson Info
  title           String
  description     String   @db.Text
  lesson_order    Int
  
  // Content
  introduction    String   @db.Text
  instructions    Json     // Step-by-step with cognitive load markers
  starter_code    String?  @db.Text
  solution_code   String?  @db.Text
  
  // SEND Adaptations Available
  has_audio_version     Boolean @default(false)
  has_visual_guide      Boolean @default(false)
  has_simplified_version Boolean @default(false)
  
  // assessments
  success_criteria String[]
  hints           String[]
  
  // Metadata
  estimated_minutes Int    @default(15)
  cognitive_load    Int    @default(2) // 1-5
  
  // Audit
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())
  
  // Relations
  course          CodingCourse @relation(fields: [course_id], references: [id], onDelete: Cascade)
  completions     CodingLessonCompletion[]
  
  @@index([course_id])
}

model CodingEnrollment {
  id              String   @id @default(cuid())
  student_id      Int
  course_id       String
  
  // Progress
  started_at      DateTime @default(now())
  last_activity   DateTime @default(now())
  lessons_completed Int    @default(0)
  current_lesson_id String?
  
  // Performance
  average_attempts Float   @default(1)
  total_time_minutes Int   @default(0)
  
  // Certificate
  completed_at    DateTime?
  certificate_id  String?
  
  // Relations
  student         students     @relation("CodingStudent", fields: [student_id], references: [id], onDelete: Cascade)
  course          CodingCourse @relation(fields: [course_id], references: [id], onDelete: Cascade)
  
  @@unique([student_id, course_id])
  @@index([student_id])
  @@index([course_id])
}

