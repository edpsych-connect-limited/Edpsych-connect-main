// ============================================================================
// SEN2 STATUTORY RETURNS (DfE Compliance)
// ============================================================================

enum SEN2PrimaryNeed {
  SPLD    // Specific Learning Difficulty
  MLD     // Moderate Learning Difficulty
  SLD     // Severe Learning Difficulty
  PMLD    // Profound & Multiple Learning Difficulty
  SEMH    // Social, Emotional and Mental Health
  SLCN    // Speech, Language and Communication Needs
  HI      // Hearing Impairment
  VI      // Visual Impairment
  MSI     // Multi-Sensory Impairment
  PD      // Physical Disability
  ASD     // Autistic Spectrum Disorder
  OTH     // Other Difficulty/Disability
  NSA     // No Specialist assessments of Need
}

enum SEN2PlacementType {
  MAINSTREAM_MAINTAINED
  MAINSTREAM_ACADEMY
  MAINTAINED_SPECIAL
  ACADEMY_SPECIAL
  NON_MAINTAINED_SPECIAL
  INDEPENDENT_SPECIAL
  INDEPENDENT_MAINSTREAM
  HOSPITAL_SCHOOL
  ALTERNATIVE_PROVISION
  POST_16_FE
  POST_16_SPECIALIST
  ELECTIVE_HOME_EDUCATION
  AWAITING_PLACEMENT
  OTHER
}

model SEN2Return {
  id              String   @id @default(cuid())
  la_tenant_id    Int
  
  // Collection Period
  collection_year Int              // e.g., 2025
  reference_date  DateTime         // Census date (usually January)
  
  // Submission Details
  submission_status String @default("draft") // draft, validated, submitted, accepted
  submitted_at      DateTime?
  submitted_by_id   Int?
  dfe_submission_id String?        // DfE confirmation reference
  
  // Summary Statistics (auto-calculated)
  total_ehcps             Int @default(0)
  new_ehcps_issued        Int @default(0)
  ehcps_ceased            Int @default(0)
  ehcps_transferred_in    Int @default(0)
  ehcps_transferred_out   Int @default(0)
  
  // Timeline Compliance
  assessments_within_20_weeks    Int @default(0)
  assessments_exceeding_20_weeks Int @default(0)
  timeline_compliance_rate       Float @default(0)
  
  // Metadata
  generated_at    DateTime @default(now())
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())
  
  // Relations
  la_tenant       tenants  @relation("LASen2Returns", fields: [la_tenant_id], references: [id])
  submitted_by    users?   @relation("Sen2Submitter", fields: [submitted_by_id], references: [id])
  
  // Breakdowns
  need_breakdowns       SEN2NeedBreakdown[]
  placement_breakdowns  SEN2PlacementBreakdown[]
  age_breakdowns        SEN2AgeBreakdown[]
  timeline_details      SEN2TimelineDetail[]
  validation_results    SEN2ValidationResult[]
  audit_trail           SEN2AuditEntry[]
  
  // Historical Comparison
  previous_year_return_id String?
  previous_year_return    SEN2Return? @relation("YearOverYear", fields: [previous_year_return_id], references: [id])
  next_year_returns       SEN2Return[] @relation("YearOverYear")
  
  @@unique([la_tenant_id, collection_year])
  @@index([la_tenant_id])
  @@index([collection_year])
}

model SEN2NeedBreakdown {
  id              String   @id @default(cuid())
  sen2_return_id  String
  
  primary_need    SEN2PrimaryNeed
  count           Int      @default(0)
  percentage      Float    @default(0)
  
  // Year-over-year change
  previous_count  Int?
  change_count    Int?
  change_percent  Float?
  
  // Source data (for audit trail)
  source_ehcp_ids String[] // Array of EHCP IDs contributing to this count
  
  sen2_return     SEN2Return @relation(fields: [sen2_return_id], references: [id], onDelete: Cascade)
  
  @@unique([sen2_return_id, primary_need])
  @@index([sen2_return_id])
}

model SEN2PlacementBreakdown {
  id              String   @id @default(cuid())
  sen2_return_id  String
  
  placement_type  SEN2PlacementType
  count           Int      @default(0)
  percentage      Float    @default(0)
  
  // Year-over-year change
  previous_count  Int?
  change_count    Int?
  change_percent  Float?
  
  // Source data
  source_ehcp_ids String[]
  
  sen2_return     SEN2Return @relation(fields: [sen2_return_id], references: [id], onDelete: Cascade)
  
  @@unique([sen2_return_id, placement_type])
  @@index([sen2_return_id])
}

model SEN2AgeBreakdown {
  id              String   @id @default(cuid())
  sen2_return_id  String
  
  age_band        String   // "Under 5", "5-10", "11-15", "16-19", "20-25"
  count           Int      @default(0)
  percentage      Float    @default(0)
  
  // Year-over-year
  previous_count  Int?
  change_percent  Float?
  
  source_ehcp_ids String[]
  
  sen2_return     SEN2Return @relation(fields: [sen2_return_id], references: [id], onDelete: Cascade)
  
  @@unique([sen2_return_id, age_band])
  @@index([sen2_return_id])
}

model SEN2TimelineDetail {
  id              String   @id @default(cuid())
  sen2_return_id  String
  ehcp_id         String
  
  // EHCP Details
  child_name      String
  referral_date   DateTime
  final_date      DateTime?
  
  // Timeline Calculation
  working_days_taken Int?
  within_20_weeks    Boolean @default(false)
  exception_applied  Boolean @default(false)
  exception_reason   String?
  
  sen2_return     SEN2Return @relation(fields: [sen2_return_id], references: [id], onDelete: Cascade)
  
  @@index([sen2_return_id])
  @@index([ehcp_id])
}

model SEN2ValidationResult {
  id              String   @id @default(cuid())
  sen2_return_id  String
  
  validation_type String   // category_check, date_logic, totals_match, anomaly_detection
  status          String   // pass, warning, error
  field           String?  // Which field failed
  message         String
  
  // For anomalies
  expected_value  String?
  actual_value    String?
  threshold       Float?
  
  validated_at    DateTime @default(now())
  
  sen2_return     SEN2Return @relation(fields: [sen2_return_id], references: [id], onDelete: Cascade)
  
  @@index([sen2_return_id])
}

model SEN2AuditEntry {
  id              String   @id @default(cuid())
  sen2_return_id  String
  
  action          String   // generated, validated, edited, submitted, exported
  details         Json?
  
  performed_by_id Int
  performed_at    DateTime @default(now())
  
  sen2_return     SEN2Return @relation(fields: [sen2_return_id], references: [id], onDelete: Cascade)
  performed_by    users    @relation("Sen2AuditUser", fields: [performed_by_id], references: [id])
  
  @@index([sen2_return_id])
  @@index([performed_by_id])
}

// ============================================================================
// GOLDEN THREAD COHERENCE ANALYSIS
// ============================================================================

model EHCPNeed {
  id          String   @id @default(cuid())
  ehcp_id     String
  
  // Need Details
  section     String   @default("B") // B, C, D (EHCP sections)
  need_type   String   // cognition_learning, communication, sensory, social_emotional, physical
  description String   @db.Text
  severity    String   @default("moderate") // mild, moderate, severe
  
  // Evidence Base
  evidence_sources String[] // assessments IDs that support this need
  
  // Ordering
  display_order Int @default(0)
  
  // Audit
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
  created_by  Int?
  
  // Relations
  ehcp        ehcps    @relation(fields: [ehcp_id], references: [id], onDelete: Cascade)
  
  // Links to provisions
  provision_links NeedProvisionLink[]
  
  @@index([ehcp_id])
}

model EHCPProvision {
  id          String   @id @default(cuid())
  ehcp_id     String
  
  // provisions Details
  section     String   @default("F") // F, G, H (EHCP sections)
  provision_type String // educational, health, social_care
  description String   @db.Text
  
  // Quantification
  hours_per_week  Float?
  frequency       String? // daily, weekly, termly, annually
  delivered_by    String? // TA, Teacher, SALT, OT, etc.
  location        String? // classroom, withdrawal, home, clinic
  
  // Costing (for Element 3 calculations)
  annual_cost     Float?
  funding_source  String? // element_2, element_3, high_needs, health
  
  // Status
  status          String @default("active") // active, proposed, ceased
  start_date      DateTime?
  end_date        DateTime?
  
  // Audit
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
  created_by  Int?
  
  // Relations
  ehcp        ehcps    @relation(fields: [ehcp_id], references: [id], onDelete: Cascade)
  
  // Links
  need_links    NeedProvisionLink[]
  outcome_links ProvisionOutcomeLink[]
  
  @@index([ehcp_id])
}

model EHCPOutcome {
  id          String   @id @default(cuid())
  ehcp_id     String
  
  // Outcome Details
  section     String   @default("E") // E = Outcomes
  outcome_area String  // communication, cognition, social, independence, academic, life_skills
  description  String  @db.Text
  
  // SMART Criteria
  is_specific     Boolean @default(false)
  is_measurable   Boolean @default(false)
  is_achievable   Boolean @default(false)
  is_relevant     Boolean @default(false)
  is_timebound    Boolean @default(false)
  smart_score     Int     @default(0) // 0-5
  
  // Timeline
  target_date     DateTime?
  review_date     DateTime?
  
  // Progress Tracking
  baseline_level  String?
  current_level   String?
  target_level    String?
  progress_status String @default("not_started") // not_started, in_progress, achieved, not_achieved
  
  // Evidence
  evidence_notes  String? @db.Text
  
  // Audit
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
  created_by  Int?
  
  // Relations
  ehcp        ehcps    @relation(fields: [ehcp_id], references: [id], onDelete: Cascade)
  
  // Links
  provision_links ProvisionOutcomeLink[]
  progress_reviews OutcomeProgressReview[]
  
  @@index([ehcp_id])
}

model NeedProvisionLink {
  id              String   @id @default(cuid())
  
  need_id         String
  provision_id    String
  
  // Link Quality
  strength        String @default("moderate") // weak, moderate, strong
  evidence_based  Boolean @default(false) // Is this an evidence-based intervention?
  
  // Justification
  rationale       String? @db.Text
  
  created_at      DateTime @default(now())
  
  need            EHCPNeed      @relation(fields: [need_id], references: [id], onDelete: Cascade)
  provision       EHCPProvision @relation(fields: [provision_id], references: [id], onDelete: Cascade)
  
  @@unique([need_id, provision_id])
  @@index([need_id])
  @@index([provision_id])
}

model ProvisionOutcomeLink {
  id              String   @id @default(cuid())
  
  provision_id    String
  outcome_id      String
  
  // Link Quality
  strength        String @default("moderate")
  
  // Expected Impact
  expected_impact String? @db.Text
  
  created_at      DateTime @default(now())
  
  provision       EHCPProvision @relation(fields: [provision_id], references: [id], onDelete: Cascade)
  outcome         EHCPOutcome   @relation(fields: [outcome_id], references: [id], onDelete: Cascade)
  
  @@unique([provision_id, outcome_id])
  @@index([provision_id])
  @@index([outcome_id])
}

model OutcomeProgressReview {
  id          String   @id @default(cuid())
  outcome_id  String
  
  review_date DateTime
  reviewer_id Int
  
  // Progress assessments
  previous_level String?
  current_level  String?
  progress_made  String   // significant, some, none, regression
  
  // Evidence
  evidence       String?  @db.Text
  
  // Next Steps
  recommendations String? @db.Text
  
  created_at     DateTime @default(now())
  
  outcome        EHCPOutcome @relation(fields: [outcome_id], references: [id], onDelete: Cascade)
  reviewer       users       @relation("OutcomeReviewer", fields: [reviewer_id], references: [id])
  
  @@index([outcome_id])
  @@index([reviewer_id])
}

model EHCPCoherenceAnalysis {
  id          String   @id @default(cuid())
  ehcp_id     String   @unique
  
  // Analysis Results
  overall_score       Float   @default(0) // 0-100
  needs_coverage      Float   @default(0) // % of needs with provisions
  provisions_justified Float  @default(0) // % of provisions linked to needs
  outcomes_measurable Float   @default(0) // % of outcomes that are SMART
  
  // Issue Counts
  unlinked_needs      Int     @default(0)
  unlinked_provisions Int     @default(0)
  weak_links          Int     @default(0)
  unmeasurable_outcomes Int   @default(0)
  
  // Detailed Analysis (Golden Thread)
  tenant_id           Int?
  status              String?
  thread_count        Int     @default(0)
  complete_threads    Int     @default(0)
  incomplete_threads  Int     @default(0)
  gap_count           Int     @default(0)
  critical_gaps       Int     @default(0)
  major_gaps          Int     @default(0)
  minor_gaps          Int     @default(0)
  analysis_data       Json?

  // Recommendations
  recommendations     Json?   // Array of improvement suggestions
  
  // Analysis Metadata
  analyzed_at         DateTime @default(now())
  analysis_version    String   @default("1.0")
  
  ehcp                ehcps    @relation(fields: [ehcp_id], references: [id], onDelete: Cascade)
  
  @@index([ehcp_id])
}

// ============================================================================
// STUDENT LEARNING PROFILES (Enhanced Differentiation)
// ============================================================================

model StudentLearningProfile {
  id          String   @id @default(cuid())
  student_id  Int      @unique
  
  // Learning Preferences
  visual_learner      Boolean @default(false)
  auditory_learner    Boolean @default(false)
  kinesthetic_learner Boolean @default(false)
  reading_preference  Boolean @default(false)
  
  // SEND Indicators
  has_dyslexia        Boolean @default(false)
  dyslexia_severity   String? // mild, moderate, severe
  preferred_font      String? // OpenDyslexic, Lexie, Arial, default
  
  has_dyscalculia     Boolean @default(false)
  has_dyspraxia       Boolean @default(false)
  
  has_adhd            Boolean @default(false)
  adhd_type           String? // inattentive, hyperactive, combined
  chunk_size_preference Int @default(3) // Number of steps before break
  
  has_asd             Boolean @default(false)
  sensory_sensitivities Json? // {visual: [], auditory: [], tactile: []}
  
  // Cognitive Profile
  working_memory_level    String @default("average") // below, average, above
  processing_speed_level  String @default("average")
  verbal_comprehension    String @default("average")
  perceptual_reasoning    String @default("average")
  
  // Reading Level
  reading_age_months      Int?   // Reading age in months
  reading_level           String @default("age_appropriate") // below, age_appropriate, above
  vocabulary_tier         Int    @default(2) // 1=basic, 2=academic, 3=advanced
  
  // Time Accommodations
  time_multiplier         Float  @default(1.0) // 1.5 = 50% extra time
  needs_breaks            Boolean @default(false)
  break_frequency_minutes Int?   // Minutes between breaks
  
  // Visual Accommodations
  preferred_bg_color      String? // cream, blue, yellow, white
  preferred_text_size     String @default("medium") // small, medium, large, xlarge
  needs_visual_supports   Boolean @default(false)
  
  // Audio Accommodations
  needs_text_to_speech    Boolean @default(false)
  tts_speed               Float   @default(1.0)
  
  // Engagement Profile
  gamification_response   String @default("positive") // positive, neutral, negative
  competition_response    String @default("positive")
  collaboration_preference Boolean @default(true)
  
  // Confidence & Anxiety
  anxiety_triggers        String[]  @default([])
  confidence_level        String @default("average")
  
  // Profile Metadata
  profile_completeness    Float @default(0) // 0-100%
  last_assessment_date    DateTime?
  next_review_date        DateTime?
  
  // Audit
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
  created_by  Int?
  
  student     students @relation("LearningProfile", fields: [student_id], references: [id], onDelete: Cascade)
  
  @@index([student_id])
}

// ============================================================================
// INDIVIDUAL LESSON DIFFERENTIATION
// ============================================================================

model DifferentiatedLessonVersion {
  id              String   @id @default(cuid())
  lesson_plan_id  String
  student_id      Int
  
  // Differentiation Applied
  difficulty_level String  // below, at, above, well_above
  
  // Content Adaptations
  adapted_content  Json    // Full lesson content with adaptations
  
  // Specific Adaptations Applied
