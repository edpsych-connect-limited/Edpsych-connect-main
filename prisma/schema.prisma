  color_adaptation    String?  // Background color
  text_size           String?
  chunking_applied    Boolean @default(false)
  visual_supports     Json?   // Array of {type, location, description}
  vocabulary_simplified Boolean @default(false)
  time_adjustment     Float   @default(1.0) // Multiplier
  
  // Generated Text Versions
  instructions_original String? @db.Text
  instructions_adapted  String? @db.Text
  
  // Generation Metadata
  generated_at    DateTime @default(now())
  generation_time_ms Int?
  ai_model_used   String?
  
  // Teacher Review
  teacher_reviewed Boolean @default(false)
  teacher_modified Boolean @default(false)
  modifications    Json?
  
  // Assignment Status
