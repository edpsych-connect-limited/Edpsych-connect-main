// ============================================================================
// ASSESSMENT FRAMEWORKS EXTENSION
// EdPsych Connect Proprietary Assessment Tools (ECCA, ECCP, ECWA, etc.)
// ============================================================================

// ============================================================================
// EVIDENCE-BASED ASSESSMENT FRAMEWORKS
// EdPsych Connect Limited - Proprietary Assessment Tools
// ============================================================================
//
// This schema extension provides the foundation for:
// - ECCA: EdPsych Connect Cognitive Assessment
// - ECCP: EdPsych Connect Communication Profile
// - ECWA: EdPsych Connect Wellbeing Assessment
// - ECSMS: EdPsych Connect Sensory & Motor Screen
// - ECSEF: EdPsych Connect Social-Emotional Functioning
//
// Key Principles:
// - EP-controlled workflow (guidance, not automation)
// - Evidence-based content (Vygotsky, Feuerstein, contemporary research)
// - Collaborative input (EP, parent, teacher, child)
// - Copyright-safe (original EdPsych Connect content)
// - Professional interpretation required at all stages
// ============================================================================

// ----------------------------------------------------------------------------
// ASSESSMENT FRAMEWORK DEFINITION (Template)
// ----------------------------------------------------------------------------

model AssessmentFramework {
  id           String @id @default(uuid())
  name         String // "EdPsych Connect Cognitive Assessment"
  abbreviation String @unique // "ECCA"
  version      String @default("1.0")
  domain       String // "Cognitive & Learning", "Communication", etc.

  // Description and purpose
  description   String @db.Text
  purpose       String @db.Text
  age_range_min Int? // Minimum age in years
  age_range_max Int? // Maximum age in years

  // Evidence base and research foundations
  evidence_base          Json // Citations, research foundations
  theoretical_frameworks String[] // ["Vygotsky", "Feuerstein", "Information Processing"]

  // Administration guidelines
  administration_guide  Json // Step-by-step EP guidance
  time_estimate_minutes Int? // Typical administration time

  // Interpretation framework
  interpretation_guide    Json // How to interpret observations
  qualitative_descriptors Json // Strength-based descriptors

  // Content structure
  domains AssessmentDomain[]

  // Status and metadata
  status           String   @default("active") // active, draft, archived
  is_proprietary   Boolean  @default(true)
  copyright_holder String   @default("EdPsych Connect Limited")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Relations
  instances AssessmentInstance[]

  @@index([abbreviation])
  @@index([domain])
  @@index([status])
}

// ----------------------------------------------------------------------------
// ASSESSMENT DOMAINS (Areas to assess within a framework)
// ----------------------------------------------------------------------------

model AssessmentDomain {
  id           String @id @default(uuid())
  framework_id String

  // Domain identification
  name        String // "Working Memory", "Attention & Executive Function"
  description String @db.Text
  order_index Int // Display order

  // EP Guidance for this domain
  observation_prompts Json // Prompts to guide EP observation
  task_suggestions    Json // Suggested tasks/activities
  key_indicators      Json // What to look for (strengths and needs)

  // Collaborative input questions
  parent_questions  Json // Questions for parent input
  teacher_questions Json // Questions for teacher input
  child_prompts     Json? // Age-appropriate child input prompts

  // Interpretation support
  interpretation_guidance Json // How to interpret observations in this domain
  strength_descriptors    Json // Qualitative descriptors for strengths
  need_descriptors        Json // Qualitative descriptors for needs

  // Evidence-based interventions (linked)
  suggested_interventions Json // UK evidence-based interventions

  // Relations
  framework    AssessmentFramework @relation(fields: [framework_id], references: [id], onDelete: Cascade)
  observations DomainObservation[]

  @@index([framework_id])
  @@index([order_index])
}

// ----------------------------------------------------------------------------
// ASSESSMENT INSTANCE (Specific assessment being conducted)
// ----------------------------------------------------------------------------

model AssessmentInstance {
  id           String @id @default(uuid())
  tenant_id    Int
  framework_id String
  case_id      Int
  student_id   Int

  // Assessment metadata
  title           String? // Optional custom title
  conducted_by    Int // EP user ID
  assessment_date DateTime?

  // Status tracking
  status              String @default("draft") // draft, in_progress, collaborative_input, interpretation, completed
  progress_percentage Int    @default(0)

  // Collaborative input status
  parent_input_requested  Boolean @default(false)
  parent_input_received   Boolean @default(false)
  teacher_input_requested Boolean @default(false)
  teacher_input_received  Boolean @default(false)
  child_input_requested   Boolean @default(false)
  child_input_received    Boolean @default(false)

  // EP observations and interpretation
  ep_summary         String? @db.Text
  ep_interpretation  String? @db.Text
  ep_recommendations Json? // Linked to EHCP sections

  // Links to outputs
  linked_ehcp_id   String? // If contributed to EHCP
  linked_report_id String? // If generated report

  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  completed_at DateTime?

  // Relations
  framework           AssessmentFramework       @relation(fields: [framework_id], references: [id])
  domain_observations DomainObservation[]
  collaborations      AssessmentCollaboration[]

  @@index([tenant_id])
  @@index([framework_id])
  @@index([case_id])
  @@index([student_id])
  @@index([conducted_by])
  @@index([status])
}

// ----------------------------------------------------------------------------
// DOMAIN OBSERVATIONS (EP's observations for each domain)
// ----------------------------------------------------------------------------

model DomainObservation {
  id          String @id @default(uuid())
  instance_id String
  domain_id   String

  // EP Observations
  observations       String @db.Text // EP's narrative observations
  observed_strengths Json // Structured strengths data
  observed_needs     Json // Structured needs data

  // Context
  observation_context String? @db.Text // Where/when/how observed
  tasks_used          Json? // Specific tasks or activities used

  // Qualitative assessment
  strength_descriptors String[] // Selected from domain's descriptors
  need_descriptors     String[] // Selected from domain's descriptors

  // Professional interpretation
  interpretation String? @db.Text
  significance   String? @db.Text // Why this matters for the child

  // Evidence-to-provision
  suggested_provisions Json? // Linked interventions/provisions

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  instance AssessmentInstance @relation(fields: [instance_id], references: [id], onDelete: Cascade)
  domain   AssessmentDomain   @relation(fields: [domain_id], references: [id])

  @@index([instance_id])
  @@index([domain_id])
}

// ----------------------------------------------------------------------------
// COLLABORATIVE INPUT (Parent/Teacher/Child perspectives)
// ----------------------------------------------------------------------------

model AssessmentCollaboration {
  id          String @id @default(uuid())
  instance_id String

  // Contributor identification
  contributor_type  String // "parent", "teacher", "child", "other_professional"
  contributor_name  String?
  contributor_email String?
  contributor_role  String? // For professionals

  // Input data
  responses       Json // Structured responses to domain questions
  narrative_input String? @db.Text // Free-text input

  // Context
  relationship_to_child String? // "Mother", "Class Teacher", etc.
  observation_context   String? // "Home environment", "Classroom", etc.

  // Metadata
  submitted_at       DateTime  @default(now())
  invitation_sent_at DateTime?
  invitation_method  String? // "email", "paper_form", "in_person"
  invitation_token   String?   @unique // Secure token for form access
  token_expires_at   DateTime? // Token expiration (30 days default)

  // Status
  status        String    @default("pending") // pending, received, integrated
  integrated_at DateTime?
  integrated_by Int? // EP who integrated the input

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  instance AssessmentInstance @relation(fields: [instance_id], references: [id], onDelete: Cascade)

  @@index([instance_id])
  @@index([contributor_type])
  @@index([status])
}

// ----------------------------------------------------------------------------
// ASSESSMENT GUIDANCE (Evidence-based content for EPs)
// ----------------------------------------------------------------------------

model AssessmentGuidance {
  id String @id @default(uuid())

  // Categorization
  category String // "observation_technique", "interpretation_principle", "research_update"
  topic    String // "Working Memory Assessment", "Dynamic Assessment Principles"

  // Content
  title            String
  summary          String @db.Text
  detailed_content String @db.Text

  // Evidence base
  research_citations Json // Structured citations
  evidence_strength  String? // "strong", "moderate", "emerging"

  // Practical application
  practical_tips    Json? // How to apply in practice
  example_scenarios Json? // Real-world examples
  common_pitfalls   Json? // What to avoid

  // Target domains/frameworks
  relevant_frameworks String[] // Which frameworks this applies to
  relevant_domains    String[] // Which domains this applies to

  // Status and metadata
  status      String    @default("published") // draft, published, archived
  author      String?
  reviewed_by String?
  review_date DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([category])
  @@index([topic])
  @@index([status])
}

// ----------------------------------------------------------------------------
// ASSESSMENT TEMPLATES (Pre-filled scenarios for common cases)
// ----------------------------------------------------------------------------

model AssessmentTemplate {
  id           String @id @default(uuid())
  framework_id String

  // Template identification
  name        String // "Year 3 Reading Difficulties - Working Memory Focus"
  description String @db.Text
  use_case    String @db.Text // When to use this template

  // Age/stage appropriateness
  age_range_min Int?
  age_range_max Int?
  year_group    String?

  // Pre-populated content
  suggested_domains   String[] // Which domains to prioritize
  observation_prompts Json // Pre-filled observation prompts
  task_suggestions    Json // Suggested tasks

  // Metadata
  usage_count Int     @default(0)
  created_by  String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([framework_id])
  @@index([age_range_min, age_range_max])
}

// ----------------------------------------------------------------------------
// ASSESSMENT OUTCOMES TRACKING (Evidence of impact)
// ----------------------------------------------------------------------------

model AssessmentOutcome {
  id          String @id @default(uuid())
  tenant_id   Int
  instance_id String
  student_id  Int

  // Outcome tracking
  outcome_type        String // "provision_implemented", "progress_observed", "ehcp_issued"
  outcome_description String @db.Text

  // Evidence of impact
  evidence_data Json? // Quantitative/qualitative evidence
  impact_rating String? // "significant", "moderate", "minimal"

  // Timeline
  baseline_date DateTime?
  outcome_date  DateTime
  followup_date DateTime?

  // User contribution to research (opt-in)
  contributed_to_research Boolean @default(false)
  anonymized_data         Json? // Anonymized version for research

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@index([instance_id])
  @@index([student_id])
  @@index([outcome_type])
  @@index([contributed_to_research])
}

// ============================================================================
// NOTES ON USAGE:
// ============================================================================
//
// 1. EP WORKFLOW:
//    - EP selects framework (ECCA, ECCP, etc.)
//    - System creates AssessmentInstance
//    - EP follows domain-by-domain guidance
//    - EP records observations in DomainObservation
//    - System prompts for collaborative input
//    - EP integrates collaborative input
//    - EP provides professional interpretation
//    - EP generates recommendations
//
// 2. COLLABORATIVE INPUT:
//    - EP invites parents/teachers via AssessmentCollaboration
//    - Contributors respond to domain-specific questions
//    - EP reviews and integrates input into assessment
//    - All perspectives visible but EP maintains professional control
//
// 3. DATA OWNERSHIP:
//    - All AssessmentInstance data owned by tenant
//    - AssessmentOutcome can be contributed to research (opt-in)
//    - Anonymization applied to contributed data
//    - User can export all assessment data anytime
//
// 4. EVIDENCE BASE:
//    - AssessmentFramework contains research foundations
//    - AssessmentGuidance provides ongoing professional development
//    - AssessmentOutcome tracks real-world effectiveness
//    - Contributes to EdPsych Connect's research foundation
//
// ============================================================================

// ============================================================================
// TRAINING MONETIZATION EXTENSION
// EdPsych Connect CPD Training Platform
// ============================================================================

// ============================================================================
// TRAINING MONETIZATION SYSTEM
// EdPsych Connect Limited - Evidence-Based CPD Training Platform
// ============================================================================
//
// Market-Rate Pricing Strategy:
// - Self-service (no facilitators) = competitive pricing
// - Interactive + engaging = premium value
// - Evidence-based content = quality positioning
// - 20-30% below BPS but more interactive
//
// Pricing Structure:
// - Short courses (2-4 hours): £49-79
// - Standard courses (8-12 hours): £99-149
// - Comprehensive courses (20+ hours): £199-299
// - Course bundles: 20-25% discount
// - Annual unlimited access: £599
// ============================================================================

// ----------------------------------------------------------------------------
// TRAINING PRODUCT CATALOG
// ----------------------------------------------------------------------------

model TrainingProduct {
  id String @id @default(uuid())

  // Product identification
  type        String // "single_course", "course_bundle", "annual_unlimited"
  name        String
  description String @db.Text
  slug        String @unique

  // Pricing (in pence for Stripe)
  price_gbp          Int // Price in pence (e.g., 9900 = £99.00)
  original_price_gbp Int? // Original price before discount
  currency           String @default("GBP")

  // CPD Hours
  cpd_hours Float? // Total CPD hours awarded

  // Product content (for single courses)
  course_id String? // Links to Course model

  // Product content (for bundles)
  included_course_ids String[] // Array of course IDs

  // Validity period
  access_duration_days Int? // NULL = lifetime access, otherwise days

  // Stripe integration
  stripe_product_id String? @unique
  stripe_price_id   String? @unique

  // Status and metadata
  status      String  @default("active") // active, archived, draft
  is_featured Boolean @default(false)
  sort_order  Int     @default(0)

  // Marketing
  promotional_text String?
  benefits         String[] // Array of benefit strings
  target_audience  String[] // ["Educational Psychologists", "SENCOs", etc.]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  purchases TrainingPurchase[]

  @@index([type])
  @@index([status])
  @@index([is_featured])
  @@index([slug])
}

// ----------------------------------------------------------------------------
// TRAINING PURCHASES (Orders)
// ----------------------------------------------------------------------------

model TrainingPurchase {
  id String @id @default(uuid())

  // Customer
  user_id Int
  email   String // Captured at purchase

  // Product
  product_id   String
  product_name String // Snapshot at purchase time
  product_type String // Snapshot at purchase time

  // Pricing
  amount_paid_pence     Int // Amount paid in pence
  currency              String  @default("GBP")
  discount_code         String? // If discount applied
  discount_amount_pence Int? // Discount in pence

  // Access granted
  course_ids           String[] // Courses user gets access to
  access_duration_days Int? // NULL = lifetime
  access_granted_at    DateTime  @default(now())
  access_expires_at    DateTime? // NULL = lifetime

  // Payment processing (Stripe)
  stripe_customer_id       String?
  stripe_payment_intent_id String? @unique
  stripe_invoice_id        String?
  payment_method           String? // "card", "bank_transfer", etc.
  payment_status           String  @default("pending") // pending, succeeded, failed

  // Receipts and invoices
  receipt_url    String?
  invoice_number String? @unique

  // Status
  status              String    @default("active") // active, refunded, expired, cancelled
  refunded_at         DateTime?
  refund_amount_pence Int?
  refund_reason       String?

  // Metadata
  purchase_metadata Json? // Additional metadata
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  // Relations
  product     TrainingProduct    @relation(fields: [product_id], references: [id])
  enrollments CourseEnrollment[]

  @@index([user_id])
  @@index([product_id])
  @@index([payment_status])
  @@index([status])
  @@index([stripe_payment_intent_id])
}

// ----------------------------------------------------------------------------
// DISCOUNT CODES
// ----------------------------------------------------------------------------

model DiscountCode {
  id String @id @default(uuid())

  // Code identification
  code        String  @unique // e.g., "LAUNCH25", "BPSEP2025"
  name        String // Internal name
  description String?

  // Discount type
  discount_type  String // "percentage", "fixed_amount"
  discount_value Int // Percentage (e.g., 25) or pence (e.g., 2500 = £25)

  // Applicability
  applies_to             String // "all", "specific_products", "course_bundles"
  applicable_product_ids String[] // Empty if applies_to = "all"
  min_purchase_pence     Int? // Minimum purchase amount

  // Usage limits
  max_uses          Int? // NULL = unlimited
  max_uses_per_user Int  @default(1)
  current_uses      Int  @default(0)

  // Validity period
  valid_from  DateTime  @default(now())
  valid_until DateTime?

  // Status
  is_active Boolean @default(true)

  // Metadata
  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([code])
  @@index([is_active])
  @@index([valid_from, valid_until])
}

// ----------------------------------------------------------------------------
// COURSE ENROLLMENT ENHANCEMENTS (extends existing CourseEnrollment)
// ----------------------------------------------------------------------------

// Note: This extends the existing CourseEnrollment model in main schema
// New fields to add to CourseEnrollment:
// - purchase_id: String? (links to TrainingPurchase)
// - access_granted_via: String? ("purchase", "subscription", "trial", "admin_grant")
// - access_expires_at: DateTime?
// - is_lifetime_access: Boolean @default(false)

// ----------------------------------------------------------------------------
// INTERACTIVE ELEMENTS (for engaging self-service delivery)
// ----------------------------------------------------------------------------

model InteractiveElement {
  id String @id @default(uuid())

  // Location
  lesson_id   String // Which lesson this element belongs to
  order_index Int // Order within lesson

  // Element type
  type String // "quiz", "scenario", "reflection", "case_study", "interactive_diagram", "video_quiz", "poll"

  // Content
  title   String?
  content Json // Element-specific content structure

  // Configuration
  is_required   Boolean @default(false) // Must complete to progress?
  passing_score Int? // For quizzes (percentage)
  max_attempts  Int? // NULL = unlimited

  // Metadata
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  responses InteractiveResponse[]

  @@index([lesson_id])
  @@index([order_index])
  @@index([type])
}

model InteractiveResponse {
  id String @id @default(uuid())

  // User and element
  user_id       Int
  element_id    String
  enrollment_id String // Which enrollment (course attempt)

  // Response data
  response_data  Json // Element-specific response
  score          Float? // If applicable (0-100)
  is_correct     Boolean? // For quizzes
  attempt_number Int      @default(1)

  // Time tracking
  time_spent_seconds Int?
  submitted_at       DateTime @default(now())

  // Feedback
  feedback_shown String? @db.Text

  // Relations
  element InteractiveElement @relation(fields: [element_id], references: [id])

  @@index([user_id])
  @@index([element_id])
  @@index([enrollment_id])
  @@index([submitted_at])
}

// ----------------------------------------------------------------------------
// LEARNING PATH SYSTEM (Structured course sequences)
// ----------------------------------------------------------------------------

model LearningPath {
  id String @id @default(uuid())

  // Path identification
  name        String
  description String @db.Text
  slug        String @unique

  // Content
  course_ids         String[] // Ordered array of course IDs
  total_cpd_hours    Float
  estimated_duration Int // Total minutes

  // Pricing
  price_gbp Int? // In pence, if sold as bundle

  // Status
  status      String  @default("active")
  is_featured Boolean @default(false)

  // Metadata
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  enrollments LearningPathEnrollment[]

  @@index([slug])
  @@index([status])
}

model LearningPathEnrollment {
  id String @id @default(uuid())

  // User and path
  user_id Int
  path_id String

  // Progress
  current_course_index Int      @default(0)
  completed_course_ids String[] @default([])
  progress_percentage  Int      @default(0)

  // Status
  status       String    @default("active") // active, completed, abandoned
  started_at   DateTime  @default(now())
  completed_at DateTime?

  // Relations
  path LearningPath @relation(fields: [path_id], references: [id])

  @@unique([user_id, path_id])
  @@index([user_id])
  @@index([path_id])
  @@index([status])
}

// ----------------------------------------------------------------------------
// CERTIFICATE TEMPLATES
// ----------------------------------------------------------------------------

model CertificateTemplate {
  id String @id @default(uuid())

  // Template identification
  name          String
  template_type String // "course_completion", "cpd_hours", "learning_path"

  // Design
  background_image_url String?
  logo_url             String?
  layout_config        Json // Design configuration

  // Text templates
  title_template String // e.g., "Certificate of Completion"
  body_template  String  @db.Text // With placeholders
  footer_text    String?

  // Verification
  includes_qr_code          Boolean @default(true)
  includes_verification_url Boolean @default(true)

  // Status
  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([template_type])
  @@index([is_active])
}

// ----------------------------------------------------------------------------
// GENERATED CERTIFICATES (extends existing Certificate model)
// ----------------------------------------------------------------------------

// Note: The existing Certificate model already has most fields needed
// Enhancement: Add template_id to link to CertificateTemplate
// Enhancement: Add cpd_hours field (already exists)
// Enhancement: Add verification URL generation

// ----------------------------------------------------------------------------
// CPD TRACKING ENHANCEMENTS
// ----------------------------------------------------------------------------

model CPDLog {
  id      String @id @default(uuid())
  user_id Int

  // Activity details
  activity_type        String // "course", "webinar", "reading", "reflection", "other"
  activity_title       String
  activity_description String? @db.Text

  // CPD hours
  cpd_hours    Float
  cpd_category String // "A: Work-based learning", "B: Professional activity", "C: Formal education"

  // Evidence
  certificate_id String? // Links to Certificate if applicable
  evidence_urls  String[] // Supporting evidence

  // Dates
  activity_date DateTime
  logged_at     DateTime @default(now())

  // Status
  status      String    @default("pending") // pending, verified, rejected
  verified_by String?
  verified_at DateTime?

  // Metadata
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([activity_date])
  @@index([cpd_category])
  @@index([status])
}

