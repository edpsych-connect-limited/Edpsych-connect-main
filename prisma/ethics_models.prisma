
// ============================================================================
// ETHICS & COMPLIANCE
// ============================================================================

model EthicsAssessment {
  id            String    @id @default(cuid())
  title         String
  description   String    @db.Text
  componentId   String
  componentType String
  assessorId    Int
  status        String    @default("draft") // draft, in_review, approved, rejected
  version       Int       @default(1)
  
  questions     Json      // Array of { question, answer, category }
  ethicalRisks  Json      // Array of { description, severity, category }
  mitigations   Json      // Array of { riskIndex, description, status }
  recommendedMonitors Json // Array of { monitorType, description, configuration }
  tags          String[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  approvedAt    DateTime?

  // Relations
  assessor      users     @relation("Assessor", fields: [assessorId], references: [id])
  reviewers     users[]   @relation("Reviewers")
  modelVersions AIModelVersion[] @relation("EthicsAssessmentModelVersion")

  @@index([status])
  @@index([componentType])
}

model EthicsIncident {
  id             String    @id @default(cuid())
  title          String
  description    String    @db.Text
  monitorId      String?
  metricId       String?
  metricValue    Float?
  thresholdValue Float?
  
  status         String    @default("open") // open, investigating, mitigating, resolved, dismissed
  severity       String    @default("medium") // low, medium, high, critical
  
  resolutionSteps Json     // Array of { description, status, createdAt, completedAt }
  tags           String[]

  detectedAt     DateTime  @default(now())
  resolvedAt     DateTime?
  
  assignedToId   Int?
  assignedTo     users?    @relation("IncidentAssignee", fields: [assignedToId], references: [id])

  monitor        EthicsMonitor? @relation(fields: [monitorId], references: [id])

  @@index([status])
  @@index([severity])
}

model EthicsMonitor {
  id          String    @id @default(cuid())
  name        String
  description String    @db.Text
  
  metrics     Json      // Array of { id, name, category }
  thresholds  Json      // Object of { metricId: { type, value } }
  
  enabled     Boolean   @default(true)
  frequency   String    @default("daily")
  severity    String    @default("medium")
  tags        String[]
  
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  incidents   EthicsIncident[]

  @@index([enabled])
}

// ============================================================================
// AI MODEL REGISTRY & ETHICAL EVALUATION
// ============================================================================

model AIModel {
  id          String   @id @default(cuid())
  name        String
  provider    String
  description String?  @db.Text
  status      String   @default("active") // active, deprecated, retired
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions    AIModelVersion[]

  @@index([provider])
  @@index([status])
}

model AIModelVersion {
  id                  String   @id @default(cuid())
  modelId             String
  versionLabel        String
  providerModel       String
  status              String   @default("active") // active, deprecated, retired
  releaseDate         DateTime?
  trainingDataSummary String?  @db.Text
  architectureSummary String?  @db.Text
  performanceMetrics  Json?
  limitations         Json?
  ethicsAssessmentId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  model              AIModel            @relation(fields: [modelId], references: [id])
  ethicsAssessment   EthicsAssessment?  @relation("EthicsAssessmentModelVersion", fields: [ethicsAssessmentId], references: [id])
  fairnessEvaluations AIFairnessEvaluation[]
  transparencyReport  AITransparencyReport?

  @@index([modelId])
  @@index([providerModel])
  @@index([status])
}

model AIFairnessEvaluation {
  id             String   @id @default(cuid())
  modelVersionId String
  datasetName    String
  evaluatedAt    DateTime @default(now())
  metrics        Json
  thresholds     Json
  passed         Boolean  @default(false)
  notes          String?  @db.Text
  evaluatorId    Int?

  modelVersion AIModelVersion @relation(fields: [modelVersionId], references: [id])
  evaluator    users?         @relation(fields: [evaluatorId], references: [id])

  @@index([modelVersionId])
  @@index([evaluatedAt])
  @@index([passed])
}

model AITransparencyReport {
  id             String   @id @default(cuid())
  modelVersionId String   @unique
  report         Json
  publishedAt    DateTime?
  createdAt      DateTime @default(now())

  modelVersion AIModelVersion @relation(fields: [modelVersionId], references: [id])
}
